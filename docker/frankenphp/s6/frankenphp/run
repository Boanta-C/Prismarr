#!/command/with-contenv sh
# Load the secrets generated by init.sh (.env.local) into the process
# environment — Caddy reads {env.MERCURE_JWT_SECRET} at startup.
if [ -f /var/www/html/.env.local ]; then
  set -a
  . /var/www/html/.env.local
  set +a
fi
# Caddy needs a writable HOME for its internal data store (XDG paths).
# var/caddy is created and chowned by init.sh.
export HOME=/var/www/html/var/caddy
# Drop privileges: FrankenPHP and all PHP scripts run as www-data (UID 82).
exec s6-setuidgid www-data frankenphp run --config /etc/caddy/Caddyfile
