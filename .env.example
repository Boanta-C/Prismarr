# Prismarr — Template d'environnement
# Copiez ce fichier en symfony/.env.local et ajustez les valeurs
#
# Au premier démarrage, rendez-vous sur http://localhost:7070
# Le setup wizard vous guidera pour configurer vos services (Radarr, Sonarr, etc.)

# ════════════════════════════════════════════════════════════════════════════
#  Symfony
# ════════════════════════════════════════════════════════════════════════════
APP_ENV=prod
# Générez avec : openssl rand -hex 32
APP_SECRET=change_me_before_first_start

# ════════════════════════════════════════════════════════════════════════════
#  Prismarr UI
# ════════════════════════════════════════════════════════════════════════════
# Port d'écoute HTTP
PRISMARR_PORT=7070

# Couleur primaire (hex) — défaut indigo
PRISMARR_PRIMARY_COLOR=#6366f1

# Logo custom (URL ou chemin relatif vers /public/img/…)
# Vide = logo Prismarr par défaut
PRISMARR_LOGO_URL=

# ════════════════════════════════════════════════════════════════════════════
#  Base de données
# ════════════════════════════════════════════════════════════════════════════
# SQLite par défaut — chemin dans le volume persistant
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data/prismarr.db"

# ════════════════════════════════════════════════════════════════════════════
#  Mercure (temps réel — intégré dans FrankenPHP)
# ════════════════════════════════════════════════════════════════════════════
MERCURE_URL=http://localhost:7070/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:7070/.well-known/mercure
# Générez avec : openssl rand -hex 32
MERCURE_JWT_SECRET=change_me_before_first_start

# ════════════════════════════════════════════════════════════════════════════
#  APIs externes médias
# ════════════════════════════════════════════════════════════════════════════
RADARR_URL=http://localhost:7878
RADARR_API_KEY=change_me
SONARR_URL=http://localhost:8989
SONARR_API_KEY=change_me
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=change_me
JELLYSEERR_URL=http://localhost:5055
JELLYSEERR_API_KEY=change_me
QBITTORRENT_URL=http://localhost:8080
QBITTORRENT_USER=admin
QBITTORRENT_PASSWORD=change_me
TMDB_API_KEY=change_me

# Gluetun (optionnel — si qBittorrent tourne derrière VPN)
GLUETUN_URL=
GLUETUN_API_KEY=
GLUETUN_PROTOCOL=
