{% extends 'base.html.twig' %}

{% block title %}Service non configuré{% endblock %}

{% block content %}
  <div class="page-body">
    <div class="container-xl">
      <div class="empty">
        <div class="empty-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               style="color: var(--tblr-primary);">
            <path d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.572 1.065c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.065 -2.572c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37c1 .608 2.296 .07 2.572 -1.065z"/>
            <path d="M9 12l2 2l4 -4"/>
          </svg>
        </div>
        <h2 class="empty-title">Service « {{ service }} » non configuré</h2>
        <p class="empty-subtitle text-muted">
          Prismarr ne peut pas contacter ce service car ses paramètres de connexion n'ont pas encore été renseignés.
          <br>
          Paramètre manquant : <code>{{ key }}</code>
        </p>
        <div class="empty-action">
          <a href="{{ path('app_setup_api_keys') }}" class="btn btn-primary">
            Configurer {{ service }}
          </a>
          <a href="{{ path('app_home') }}" class="btn btn-link">
            Retour à l'accueil
          </a>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
