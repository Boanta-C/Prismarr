{% block javascripts %}
{{ parent() }}
<script>
(function () {
  function mercureUrl(topic) {
    var u = new URL('/.well-known/mercure', window.location.origin);
    u.searchParams.append('topic', topic);
    return u.toString();
  }
  function barColor(v, warn, danger, ok) {
    return v > danger ? 'bg-danger' : (v > warn ? 'bg-warning' : ok);
  }
  function formatUptime(secs) {
    if (secs > 86400) return Math.floor(secs / 86400) + 'j ' + Math.floor((secs % 86400) / 3600) + 'h';
    if (secs > 3600)  return Math.floor(secs / 3600) + 'h ' + Math.floor((secs % 3600) / 60) + 'min';
    return Math.floor(secs / 60) + 'min';
  }
  function formatSpeed(kbs) {
    if (kbs >= 1024) return (kbs / 1024).toFixed(1) + ' MB/s';
    return kbs.toFixed(0) + ' KB/s';
  }
  function setText(id, val, cls) {
    var el = document.getElementById(id);
    if (!el || val === null || val === undefined) return;
    el.textContent = val;
    if (cls !== undefined) el.className = 'h2 mb-0 fw-bold ' + cls;
  }
  function setBar(id, pct, cls) {
    var el = document.getElementById(id);
    if (!el || pct === undefined) return;
    el.style.width = Math.min(Math.max(pct, 0), 100) + '%';
    if (cls) el.className = 'progress-bar ' + cls;
  }
  function setOnce(id, val) {
    var el = document.getElementById(id);
    if (!el || !val || el.textContent === val) return;
    if (el.textContent === '—' || el.textContent === '') el.textContent = val;
  }
  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function init() {
    if (window._argosMacSrc) { window._argosMacSrc.close(); window._argosMacSrc = null; }

    window._argosMacSrc = new EventSource(mercureUrl('/argos/metrics/mac'));
    window._argosMacSrc.onmessage = function (e) {
      var d = JSON.parse(e.data);

      var cores = d.logical_cores || 1;

      // ── CPU ──
      setText('mac-cpu-val', d.cpu !== undefined ? d.cpu + '%' : null,
        d.cpu > 80 ? 'text-danger' : d.cpu > 60 ? 'text-warning' : '');
      setBar('mac-cpu-bar', d.cpu, barColor(d.cpu, 60, 80, 'bg-azure'));
      if (d.cpu_model) {
        setOnce('mac-cpu-model-sub', d.cpu_model + (d.physical_cores ? ' · ' + d.physical_cores + ' cœurs' : ''));
        setOnce('mac-cpu-model', d.cpu_model + (d.physical_cores ? ' · ' + d.physical_cores + 'c' : ''));
      }

      // ── RAM (stacked bar) ──
      if (d.mem_used_mb !== undefined) {
        var totalMb = d.mem_total_mb || 1;
        var usedGb  = (d.mem_used_mb  / 1024).toFixed(1);
        var totalGb = Math.round(d.mem_total_mb / 1024);
        setText('mac-ram-val', usedGb + ' / ' + totalGb + ' GB',
          d.mem_percent > 85 ? 'text-danger' : d.mem_percent > 70 ? 'text-warning' : '');

        setBar('mem-bar-active',     d.mem_active_mb     / totalMb * 100, 'bg-primary');
        setBar('mem-bar-wired',      d.mem_wired_mb      / totalMb * 100, 'bg-warning');
        setBar('mem-bar-compressed', d.mem_compressed_mb / totalMb * 100, 'bg-danger');
        setBar('mem-bar-inactive',   d.mem_inactive_mb   / totalMb * 100, 'bg-secondary');

        var el = document.getElementById('mem-active-val');
        if (el) el.textContent = Math.round(d.mem_active_mb / 1024) + ' GB';
        el = document.getElementById('mem-wired-val');
        if (el) el.textContent = Math.round(d.mem_wired_mb / 1024 * 10) / 10 + ' GB';
        el = document.getElementById('mem-comp-val');
        if (el) el.textContent = Math.round(d.mem_compressed_mb / 1024 * 10) / 10 + ' GB';
      }

      // ── Disque ──
      if (d.disk_used_gb !== undefined) {
        setText('mac-disk-val', d.disk_used_gb + ' / ' + d.disk_total_gb + ' GB',
          d.disk_percent > 90 ? 'text-danger' : d.disk_percent > 75 ? 'text-warning' : '');
        setBar('mac-disk-bar', d.disk_percent, barColor(d.disk_percent, 75, 90, 'bg-teal'));
        var ioEl = document.getElementById('mac-disk-io');
        if (ioEl) ioEl.textContent = d.disk_rw_mbs > 0 ? 'I/O : ' + d.disk_rw_mbs + ' MB/s' : 'I/O : inactif';
      }

      // ── Uptime ──
      if (d.uptime !== undefined) {
        setText('mac-uptime-val', formatUptime(d.uptime), '');
        setOnce('mac-os-sub', d.os_name && d.os_version ? d.os_name + ' ' + d.os_version : '');
      }

      // ── OS info card ──
      if (d.os_name) setOnce('mac-os-info', d.os_name + (d.os_version ? ' ' + d.os_version : ''));

      // ── Réseau ──
      if (d.net_in_kbs !== undefined) {
        var el = document.getElementById('mac-net-in');
        if (el) el.textContent = formatSpeed(d.net_in_kbs);
        el = document.getElementById('mac-net-out');
        if (el) el.textContent = formatSpeed(d.net_out_kbs);
        el = document.getElementById('mac-net-iface');
        if (el && d.net_interface) el.textContent = '(' + d.net_interface + ')';
      }

      // ── Swap ──
      if (d.swap_used_mb !== undefined) {
        var swapLabel = d.swap_total_mb > 0
          ? Math.round(d.swap_used_mb / 1024 * 10) / 10 + ' / ' + Math.round(d.swap_total_mb / 1024) + ' GB'
          : 'Inactif';
        setText('mac-swap-val', swapLabel,
          d.swap_percent > 80 ? 'text-danger' : d.swap_percent > 50 ? 'text-warning' : '');
        setBar('mac-swap-bar', d.swap_percent, barColor(d.swap_percent, 50, 80, 'bg-orange'));
      }

      // ── Processus ──
      if (d.proc_count) setText('mac-proc-count', d.proc_count, '');

      // ── Charge système ──
      if (d.load && d.load.length >= 3) {
        [['mac-load-1', d.load[0]], ['mac-load-5', d.load[1]], ['mac-load-15', d.load[2]]].forEach(function(pair) {
          var el = document.getElementById(pair[0]);
          if (!el) return;
          el.textContent = pair[1].toFixed(2);
          el.className = 'fw-semibold ' + (pair[1] > cores ? 'text-danger' : pair[1] > cores * 0.7 ? 'text-warning' : 'text-success');
        });
      }

      // ── Top processus ──
      if (d.top_procs && d.top_procs.length > 0) {
        var tbody = document.getElementById('mac-procs-tbody');
        if (tbody) {
          tbody.innerHTML = d.top_procs.map(function(p) {
            var cpuClass = p.cpu > 50 ? 'text-danger fw-semibold' : p.cpu > 20 ? 'text-warning fw-semibold' : '';
            var isActive = window._argosProcActive === p.name;
            return '<tr data-proc-name="' + esc(p.name) + '" style="cursor:pointer" title="Voir l\'historique"' +
              (isActive ? ' class="table-active"' : '') + '>' +
              '<td class="text-truncate" style="max-width:130px;font-size:.8rem;">' + esc(p.name) + '</td>' +
              '<td class="text-end ' + cpuClass + '" style="font-size:.8rem;">' + p.cpu.toFixed(1) + '%</td>' +
              '<td class="text-end text-secondary" style="font-size:.8rem;">' + p.mem.toFixed(1) + '%</td>' +
              '</tr>';
          }).join('');
        }
      }

      // ── Agent badge + bandeau hors ligne ──
      var badge  = document.getElementById('mac-agent-badge');
      var banner = document.getElementById('mac-agent-offline-banner');
      if (d.agent_active !== undefined) {
        if (badge) {
          badge.style.display = '';
          if (d.agent_active) {
            badge.textContent = '● Agent actif';
            badge.className = 'badge bg-success-lt text-success ms-1';
          } else {
            badge.textContent = '● Agent arrêté';
            badge.className = 'badge bg-danger-lt text-danger ms-1';
          }
        }
        if (banner) {
          banner.style.setProperty('display', d.agent_active ? 'none' : 'flex', 'important');
        }
      }

      // ── Sync timestamp ──
      var syncEl = document.getElementById('sse-page-sync');
      if (syncEl && d.last_seen) syncEl.textContent = d.last_seen;
    };
  }

  if (!window._argosMacListeners) {
    window._argosMacListeners = true;
    document.addEventListener('turbo:load', init);
    document.addEventListener('DOMContentLoaded', init);
    document.addEventListener('turbo:before-cache', function () {
      if (window._argosMacSrc) { window._argosMacSrc.close(); window._argosMacSrc = null; }
      document.querySelectorAll('.modal-backdrop').forEach(function (el) { el.remove(); });
      document.body.classList.remove('modal-open');
      document.body.style.removeProperty('overflow');
      document.body.style.removeProperty('padding-right');
    });
  }
  init();
})();
</script>

{# ===== JS Modal Détail Container ===== #}
<script>
(function () {

  // ── Helpers ──────────────────────────────────────────────────────────────

  var _current      = null;   // { name, csrfToken, isSystem }
  var _logsInterval = null;   // setInterval ID pour le polling live des logs

  function show(id)  { var el = document.getElementById(id); if (el) el.classList.remove('d-none'); }
  function hide(id)  { var el = document.getElementById(id); if (el) el.classList.add('d-none'); }
  function text(id, t){ var el = document.getElementById(id); if (el) el.textContent = t; }
  function html(id, h){ var el = document.getElementById(id); if (el) el.innerHTML = h; }
  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  var _sparkId = 0;
  function sparklineSvg(data, labels, color) {
    if (!data || data.length < 2) {
      return '<div class="text-center text-secondary small fst-italic py-3">Données insuffisantes (en attente de collecte)</div>';
    }
    var id = 'spk' + (++_sparkId);
    // Viewport
    var W = 540, H = 160;
    var padL = 36, padR = 12, padT = 10, padB = 28;
    var iW = W - padL - padR, iH = H - padT - padB;

    var rawMax = Math.max.apply(null, data.concat([1]));
    var rawMin = Math.min.apply(null, data);
    // Arrondir max au multiple de 25 supérieur
    var gridMax = Math.ceil(rawMax / 25) * 25;
    if (gridMax < 25) gridMax = 25;
    var last = data[data.length - 1];

    // Coordonnées
    var coords = data.map(function (v, i) {
      return {
        x: padL + (i / (data.length - 1)) * iW,
        y: padT + (1 - v / gridMax) * iH,
      };
    });
    var pts  = coords.map(function (c) { return c.x.toFixed(1) + ',' + c.y.toFixed(1); }).join(' ');
    var lc   = coords[coords.length - 1];
    var area = 'M ' + coords.map(function (c) { return c.x.toFixed(1) + ' ' + c.y.toFixed(1); }).join(' L ')
             + ' L ' + lc.x.toFixed(1) + ' ' + (padT + iH)
             + ' L ' + padL + ' ' + (padT + iH) + ' Z';

    // Grille horizontale
    var grid = '', yAxis = '';
    var gridLevels = [0, 25, 50, 75, 100].filter(function (v) { return v <= gridMax; });
    gridLevels.forEach(function (pct) {
      var y = padT + (1 - pct / gridMax) * iH;
      grid  += '<line x1="' + padL + '" y1="' + y.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + y.toFixed(1) + '"'
             + ' stroke="currentColor" stroke-opacity="0.07" stroke-dasharray="4 3"/>';
      yAxis += '<text x="' + (padL - 5) + '" y="' + (y + 3.5).toFixed(1) + '" text-anchor="end"'
             + ' font-size="9" fill="currentColor" opacity="0.45">' + pct + '</text>';
    });

    // Axe X — labels temporels (5 points répartis)
    var xAxis = '';
    if (labels && labels.length >= 2) {
      var picks = [0, Math.round(data.length * 0.25), Math.round(data.length * 0.5), Math.round(data.length * 0.75), data.length - 1];
      picks.forEach(function (idx) {
        if (idx >= labels.length) return;
        var x = padL + (idx / (data.length - 1)) * iW;
        xAxis += '<text x="' + x.toFixed(1) + '" y="' + (H - 6) + '" text-anchor="middle"'
               + ' font-size="9" fill="currentColor" opacity="0.45">' + labels[idx] + '</text>';
      });
    }

    // Axe Y vertical
    var yLine = '<line x1="' + padL + '" y1="' + padT + '" x2="' + padL + '" y2="' + (padT + iH) + '"'
              + ' stroke="currentColor" stroke-opacity="0.15"/>';

    // Stats
    var minV = rawMin.toFixed(1);
    var maxV = rawMax.toFixed(1);
    var lastV = last.toFixed(1);

    return '<div class="mb-1">'
      + '<svg viewBox="0 0 ' + W + ' ' + H + '" style="width:100%;height:160px;display:block;overflow:visible">'
      + '<defs><linearGradient id="' + id + '" x1="0" y1="0" x2="0" y2="1">'
      + '<stop offset="0%" stop-color="' + color + '" stop-opacity="0.35"/>'
      + '<stop offset="75%" stop-color="' + color + '" stop-opacity="0.06"/>'
      + '<stop offset="100%" stop-color="' + color + '" stop-opacity="0.0"/>'
      + '</linearGradient></defs>'
      + grid + yAxis + yLine + xAxis
      + '<path d="' + area + '" fill="url(#' + id + ')"/>'
      + '<polyline points="' + pts + '" fill="none" stroke="' + color + '" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>'
      + '<circle cx="' + lc.x.toFixed(1) + '" cy="' + lc.y.toFixed(1) + '" r="4" fill="' + color + '" stroke="white" stroke-width="1.5"/>'
      + '</svg>'
      + '<div class="d-flex justify-content-between px-1 mt-1" style="font-size:.72rem">'
      + '<span class="text-muted">min <strong>' + minV + '%</strong></span>'
      + '<span style="color:' + color + '" class="fw-bold">' + lastV + '% actuellement</span>'
      + '<span class="text-muted">max <strong>' + maxV + '%</strong></span>'
      + '</div></div>';
  }

  // ── Populate tabs ─────────────────────────────────────────────────────────

  function populateInfos(d) {
    var stateColor = d.state === 'running' ? 'success' : (d.state === 'exited' ? 'danger' : 'warning');

    // Header status
    var dot = document.getElementById('modal-status-dot');
    if (dot) {
      dot.className = 'status-dot bg-' + stateColor + ' flex-shrink-0'
        + (d.state === 'running' ? ' status-dot-animated' : '');
    }
    var badge = document.getElementById('modal-container-badge');
    if (badge) { badge.textContent = d.state; badge.className = 'badge bg-' + stateColor + '-lt ms-1 flex-shrink-0'; }
    text('modal-container-id', d.id ? 'ID: ' + d.id : '');

    // Action buttons state
    if (_current && !_current.isSystem) {
      if (d.state === 'running') {
        show('modal-btn-stop'); show('modal-btn-restart'); hide('modal-btn-start');
      } else {
        hide('modal-btn-stop'); hide('modal-btn-restart'); show('modal-btn-start');
      }
    }

    // Ports
    var portsHtml = d.ports && d.ports.length
      ? d.ports.map(function (p) {
          return '<code class="me-2">' + p.host + ' → ' + p.container + '</code>';
        }).join('')
      : '<span class="text-secondary">Aucun port exposé</span>';

    // Mounts
    var mountsHtml = d.mounts && d.mounts.length
      ? '<ul class="list-unstyled mb-0 small">' + d.mounts.map(function (m) {
          var badge = m.type === 'volume' ? 'bg-azure-lt' : 'bg-secondary-lt';
          return '<li class="mb-1">'
            + '<span class="badge ' + badge + ' me-1">' + m.type + '</span>'
            + '<span class="text-secondary font-monospace">' + (m.source || m.name || '—') + '</span>'
            + ' <span class="text-muted mx-1">→</span>'
            + '<span class="font-monospace">' + m.destination + '</span>'
            + (m.mode === 'ro' ? ' <span class="badge bg-warning-lt ms-1">ro</span>' : '')
            + '</li>';
        }).join('') + '</ul>'
      : '<span class="text-secondary">Aucun volume</span>';

    // Dates
    var startedAt = '—';
    if (d.started_at && d.started_at !== '0001-01-01T00:00:00Z') {
      startedAt = new Date(d.started_at).toLocaleString('fr-FR');
    }
    var finishedAt = '';
    if (d.state !== 'running' && d.finished_at && d.finished_at !== '0001-01-01T00:00:00Z') {
      finishedAt = new Date(d.finished_at).toLocaleString('fr-FR');
    }

    // Networks
    var networksHtml = d.networks && d.networks.length
      ? d.networks.map(function (n) {
          var aliases = n.aliases && n.aliases.length
            ? ' <span class="text-muted small">(' + n.aliases.join(', ') + ')</span>' : '';
          var gw = n.gateway ? ' <span class="text-muted small">gw ' + n.gateway + '</span>' : '';
          return '<div class="mb-1"><span class="badge bg-indigo-lt me-1">' + n.name + '</span>'
            + (n.ip ? '<code class="small">' + n.ip + '</code>' : '') + gw + aliases + '</div>';
        }).join('')
      : '<span class="text-secondary">—</span>';

    // Restart policy
    var rpColor = { 'always': 'success', 'unless-stopped': 'azure', 'on-failure': 'warning', 'no': 'secondary' };
    var rpBadge = '<span class="badge bg-' + (rpColor[d.restart_policy] || 'secondary') + '-lt">'
      + (d.restart_policy || 'no') + '</span>';

    // Exit code
    var exitRow = '';
    if (d.state !== 'running' && d.exit_code !== null && d.exit_code !== undefined) {
      var ecColor = d.exit_code === 0 ? 'success' : 'danger';
      exitRow = '<tr><td class="text-secondary">Exit code</td>'
        + '<td><span class="badge bg-' + ecColor + '-lt font-monospace">' + d.exit_code + '</span>'
        + (finishedAt ? ' <span class="text-muted small ms-2">arrêté le ' + finishedAt + '</span>' : '')
        + '</td></tr>';
    }

    html('modal-infos-content',
      '<table class="table table-sm mb-0">'
      + '<tr><td class="text-secondary" style="width:130px">Image</td>'
      +     '<td><code class="text-truncate d-inline-block" style="max-width:400px">' + d.image + '</code></td></tr>'
      + '<tr><td class="text-secondary">Hostname</td><td><code>' + (d.hostname || '—') + '</code></td></tr>'
      + '<tr><td class="text-secondary">Démarré le</td><td>' + startedAt + '</td></tr>'
      + exitRow
      + '<tr><td class="text-secondary">Restart</td><td>' + rpBadge + '</td></tr>'
      + '<tr><td class="text-secondary align-top">Réseaux</td><td>' + networksHtml + '</td></tr>'
      + '<tr><td class="text-secondary">Ports</td><td>' + portsHtml + '</td></tr>'
      + '<tr><td class="text-secondary align-top">Volumes</td><td>' + mountsHtml + '</td></tr>'
      + '</table>'
      + (d.env && d.env.length ? (
          '<div class="mt-3">'
          + '<div class="d-flex align-items-center justify-content-between mb-2">'
          + '<span class="text-secondary small text-uppercase fw-medium" style="letter-spacing:.05em">Variables d\'environnement</span>'
          + '<span class="badge bg-secondary-lt">' + d.env.length + '</span>'
          + '</div>'
          + '<div style="max-height:320px;overflow-y:auto;border:1px solid var(--tblr-border-color);border-radius:6px">'
          + '<table class="table table-sm mb-0" style="font-size:.73rem">'
          + d.env.map(function (e) {
              var isMasked = e.value === '***';
              return '<tr>'
                + '<td class="font-monospace text-secondary pe-3" style="width:38%;word-break:break-all;white-space:normal">' + esc(e.key) + '</td>'
                + '<td class="font-monospace' + (isMasked ? ' text-muted' : '') + '" style="word-break:break-all;white-space:normal">'
                + (isMasked ? '<span class="badge bg-warning-lt">masked</span>' : esc(e.value))
                + '</td></tr>';
            }).join('')
          + '</table></div></div>'
        ) : '<div class="mt-3 text-secondary small fst-italic">Aucune variable d\'environnement</div>')
    );

    hide('modal-infos-spinner');
    show('modal-infos-content');
  }

  function populateStats(d) {
    var sp = d.sparkline || { labels: [], cpu: [], mem: [] };
    var period = sp.labels && sp.labels.length >= 2
      ? '<span class="text-muted small">' + sp.labels[0] + ' → ' + sp.labels[sp.labels.length - 1] + '</span>'
      : '<span class="text-muted small fst-italic">pas encore de données 24h</span>';

    html('modal-stats-content',
      '<div class="mb-4">'
      + '<div class="d-flex justify-content-between align-items-center mb-2">'
      + '<span class="text-secondary small text-uppercase fw-medium" style="letter-spacing:.05em">CPU — 24h</span>'
      + period + '</div>'
      + sparklineSvg(sp.cpu, sp.labels, 'var(--tblr-primary)') + '</div>'
      + '<div>'
      + '<div class="d-flex justify-content-between align-items-center mb-2">'
      + '<span class="text-secondary small text-uppercase fw-medium" style="letter-spacing:.05em">RAM — 24h</span>'
      + '</div>'
      + sparklineSvg(sp.mem, sp.labels, 'var(--tblr-azure)') + '</div>'
    );

    hide('modal-stats-spinner');
    show('modal-stats-content');
  }

  // ── Open modal ────────────────────────────────────────────────────────────

  function openModal(name, csrfToken, isSystem) {

    _current = { name: name, csrfToken: csrfToken, isSystem: isSystem === '1' };
    if (_logsInterval) { clearInterval(_logsInterval); _logsInterval = null; }

    // Reset
    text('modal-container-name', name);
    text('modal-container-id', '');
    var dot = document.getElementById('modal-status-dot');
    if (dot) dot.className = 'status-dot bg-secondary flex-shrink-0';
    var badge = document.getElementById('modal-container-badge');
    if (badge) { badge.textContent = ''; badge.className = 'badge bg-secondary-lt ms-1 flex-shrink-0'; }

    ['infos', 'stats', 'logs'].forEach(function (t) {
      show('modal-' + t + '-spinner');
      hide('modal-' + t + '-content');
    });
    if (document.getElementById('modal-logs-spinner')) {
      document.getElementById('modal-logs-spinner').innerHTML =
        '<div class="spinner-border spinner-border-sm text-secondary"></div>'
        + '<div class="text-secondary small mt-2">Chargement des logs…</div>';
    }

    // Boutons actions
    ['modal-btn-restart', 'modal-btn-stop', 'modal-btn-start'].forEach(function (id) {
      var btn = document.getElementById(id);
      if (btn) btn.classList.add('d-none');
    });
    if (!_current.isSystem) {
      show('modal-btn-restart');
      show('modal-btn-stop'); // affiné après inspect
    }

    // Reset au premier onglet (clic natif car bootstrap global non exposé)
    var firstTab = document.getElementById('modal-tab-infos');
    if (firstTab) firstTab.click();

    // Ouvrir le modal via data-attribute Bootstrap (bootstrap global non exposé par Tabler)
    var trigger = document.getElementById('container-modal-trigger');
    if (trigger) trigger.click();

    // Fetch details (infos + stats)
    fetch('/container/' + encodeURIComponent(name) + '/details')
      .then(function (r) { return r.json(); })
      .then(function (d) { populateInfos(d); populateStats(d); })
      .catch(function () {
        html('modal-infos-spinner', '<div class="text-danger small">Erreur de chargement</div>');
        html('modal-stats-spinner', '<div class="text-danger small">Erreur de chargement</div>');
      });
  }

  // ── Actions ───────────────────────────────────────────────────────────────

  function doAction(action) {
    if (!_current || _current.isSystem) return;
    var body = new URLSearchParams({ _token: _current.csrfToken, action: action });
    fetch('/container/' + encodeURIComponent(_current.name) + '/action', {
      method: 'POST', body: body,
    }).then(function (r) { return r.json(); })
    .then(function (d) {
      if (d.success) {
        // Fermer via data-attribute (bootstrap global non exposé par Tabler)
        var closeBtn = document.querySelector('#container-modal [data-bs-dismiss="modal"]');
        if (closeBtn) closeBtn.click();
        // Le SSE détectera le changement de statut et mettra à jour la grille
      }
    })
    .catch(function () { /* ignore */ });
  }

  // ── Listeners (singleton) ─────────────────────────────────────────────────

  if (!window._argosContainerModalListeners) {
    window._argosContainerModalListeners = true;

    // Clic sur une card container → ouvrir le modal
    document.addEventListener('click', function (e) {
      var intercepted = e.target.closest('button, a, form');
      var card = e.target.closest('[data-container][data-csrf-token]');
if (intercepted) return;
      if (!card) return;
      e.preventDefault();
      openModal(card.dataset.container, card.dataset.csrfToken, card.dataset.system || '0');
    });

    // Onglet Logs → polling live (3 s)
    document.addEventListener('click', function (e) {
      if (!e.target.closest('#modal-tab-logs')) return;
      if (_logsInterval || !_current) return;

      function fetchLogs() {
        if (!_current) return;
        fetch('/container/' + encodeURIComponent(_current.name) + '/logs')
          .then(function (r) { return r.json(); })
          .then(function (d) {
            var pre = document.getElementById('modal-logs-pre');
            if (!pre) return;
            var atBottom = pre.scrollHeight - pre.scrollTop - pre.clientHeight < 60;
            pre.textContent = d.logs || '(aucun log disponible)';
            if (atBottom) pre.scrollTop = pre.scrollHeight;
            hide('modal-logs-spinner');
            show('modal-logs-content');
          })
          .catch(function () {
            html('modal-logs-spinner', '<div class="text-danger small">Erreur de chargement des logs</div>');
          });
      }

      fetchLogs();
      _logsInterval = setInterval(fetchLogs, 3000);
    });

    // Boutons actions
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('#modal-btn-restart, #modal-btn-stop, #modal-btn-start');
      if (!btn) return;
      if (btn.id === 'modal-btn-restart') doAction('restart');
      else if (btn.id === 'modal-btn-stop')    doAction('stop');
      else if (btn.id === 'modal-btn-start')   doAction('start');
    });

    // Boutons icônes sur les cards (restart/stop/start directs, sans ouvrir le modal)
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-card-action]');
      if (!btn) return;
      var card = btn.closest('[data-container][data-csrf-token]');
      if (!card) return;
      var name      = card.dataset.container;
      var csrfToken = card.dataset.csrfToken;
      var action    = btn.dataset.cardAction;
      btn.disabled  = true;
      fetch('/container/' + encodeURIComponent(name) + '/action', {
        method: 'POST',
        body: new URLSearchParams({ _token: csrfToken, action: action }),
      }).then(function (r) { return r.json(); })
      .catch(function () {})
      .finally(function () { btn.disabled = false; });
    });

    // Fermeture modal → réinitialiser l'état + stopper le polling logs
    document.addEventListener('hidden.bs.modal', function (e) {
      if (e.target && e.target.id === 'container-modal') {
        _current = null;
        if (_logsInterval) { clearInterval(_logsInterval); _logsInterval = null; }
      }
    });
  }

})();
</script>

{# ===== JS Historique Métriques Système Mac ===== #}
<script>
(function () {

  function show(id) { var el = document.getElementById(id); if (el) el.classList.remove('d-none'); }
  function hide(id) { var el = document.getElementById(id); if (el) el.classList.add('d-none');    }
  function text(id, t) { var el = document.getElementById(id); if (el) el.textContent = t; }
  function html(id, h) { var el = document.getElementById(id); if (el) el.innerHTML = h;  }

  function avg(arr) {
    if (!arr || arr.length === 0) return 0;
    return arr.reduce(function (s, v) { return s + v; }, 0) / arr.length;
  }

  var _sid = 0;
  function spark(data, labels, color, unit, H) {
    H = H || 160;
    if (!data || data.length < 2) {
      return '<div class="text-center text-secondary small fst-italic py-3">Pas encore assez de données</div>';
    }
    var id   = 'mh' + (++_sid);
    var W    = 700, padL = 54, padR = 36, padT = 14, padB = 34;
    var iW   = W - padL - padR, iH = H - padT - padB;
    var rMax = Math.max.apply(null, data.concat([0.01]));
    var rMin = Math.min.apply(null, data);

    // Grille adaptée à l'unité
    var step, gridMax;
    if (unit === '%') {
      step    = rMax > 75 ? 25 : rMax > 30 ? 10 : 5;
      gridMax = Math.ceil(rMax / step) * step;
      if (gridMax < step) gridMax = step;
    } else {
      step    = Math.pow(10, Math.floor(Math.log(rMax || 1) / Math.LN10));
      gridMax = Math.ceil(rMax / step) * step;
      if (gridMax <= 0) gridMax = 1;
    }

    var avgVal = avg(data);
    var last   = data[data.length - 1];

    var coords = data.map(function (v, i) {
      return { x: padL + (i / (data.length - 1)) * iW, y: padT + (1 - v / gridMax) * iH };
    });
    var pts  = coords.map(function (c) { return c.x.toFixed(1) + ',' + c.y.toFixed(1); }).join(' ');
    var lc   = coords[coords.length - 1];
    var area = 'M ' + coords.map(function (c) { return c.x.toFixed(1) + ' ' + c.y.toFixed(1); }).join(' L ')
             + ' L ' + lc.x.toFixed(1) + ' ' + (padT + iH) + ' L ' + padL + ' ' + (padT + iH) + ' Z';

    // Grille horizontale (4 niveaux)
    var grid = '', yAxis = '';
    for (var lvl = 0; lvl <= 4; lvl++) {
      var v = gridMax * lvl / 4;
      var y = padT + (1 - v / gridMax) * iH;
      var lbl = v >= 1000 ? (v / 1000).toFixed(1) + 'k' : (Number.isInteger(v) ? v : v.toFixed(1));
      grid  += '<line x1="' + padL + '" y1="' + y.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + y.toFixed(1) + '"'
             + ' stroke="currentColor" stroke-opacity="0.07" stroke-dasharray="5 4"/>';
      yAxis += '<text x="' + (padL - 7) + '" y="' + (y + 4).toFixed(1) + '" text-anchor="end"'
             + ' font-size="12" fill="currentColor" opacity="0.6">' + lbl + (unit === '%' ? '%' : '') + '</text>';
    }

    // Axe X — 7 points
    var xAxis = '';
    if (labels && labels.length >= 2) {
      for (var k = 0; k <= 6; k++) {
        var idx = Math.round(k / 6 * (data.length - 1));
        if (idx >= labels.length) continue;
        var x = padL + (idx / (data.length - 1)) * iW;
        xAxis += '<text x="' + x.toFixed(1) + '" y="' + (H - 6) + '" text-anchor="middle"'
               + ' font-size="12" fill="currentColor" opacity="0.55">' + labels[idx] + '</text>';
      }
    }

    // Fond de zone de tracé
    var plotBg = '<rect x="' + padL + '" y="' + padT + '" width="' + iW + '" height="' + iH + '"'
               + ' fill="currentColor" fill-opacity="0.02" rx="2"/>';

    // Bordure de la zone de tracé (4 côtés)
    var plotBorder = '<rect x="' + padL + '" y="' + padT + '" width="' + iW + '" height="' + iH + '"'
                   + ' fill="none" stroke="currentColor" stroke-opacity="0.12" stroke-width="1" rx="2"/>';

    // Axe Y (bordure gauche renforcée) + baseline X
    var yLine    = '<line x1="' + padL + '" y1="' + padT + '" x2="' + padL + '" y2="' + (padT + iH) + '"'
                 + ' stroke="currentColor" stroke-opacity="0.3" stroke-width="1.5"/>';
    var baseline = '<line x1="' + padL + '" y1="' + (padT + iH) + '" x2="' + (W - padR) + '" y2="' + (padT + iH) + '"'
                 + ' stroke="currentColor" stroke-opacity="0.3" stroke-width="1.5"/>';

    // Ligne moyenne + label avec fond
    var avgY    = padT + (1 - avgVal / gridMax) * iH;
    var avgLbl  = avgVal.toFixed(1) + (unit === '%' ? '%' : (unit ? ' ' + unit : ''));
    var avgLn   = '<line x1="' + padL + '" y1="' + avgY.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + avgY.toFixed(1) + '"'
                + ' stroke="' + color + '" stroke-opacity="0.4" stroke-dasharray="6 3" stroke-width="1.5"/>'
                + '<rect x="' + (W - padR + 4) + '" y="' + (avgY - 8).toFixed(1) + '" width="' + (avgLbl.length * 7 + 8) + '" height="15"'
                + ' fill="' + color + '" fill-opacity="0.12" rx="3"/>'
                + '<text x="' + (W - padR + 8) + '" y="' + (avgY + 4).toFixed(1) + '" font-size="11" font-weight="600" fill="' + color + '" opacity="0.9">' + avgLbl + '</text>';

    var lastFmt = unit === '%' ? last.toFixed(1) + '%' : last.toFixed(1) + (unit ? ' ' + unit : '');
    var minFmt  = unit === '%' ? rMin.toFixed(1) + '%' : rMin.toFixed(1) + (unit ? ' ' + unit : '');
    var maxFmt  = unit === '%' ? rMax.toFixed(1) + '%' : rMax.toFixed(1) + (unit ? ' ' + unit : '');
    var avgFmt  = unit === '%' ? avgVal.toFixed(1) + '%' : avgVal.toFixed(1) + (unit ? ' ' + unit : '');

    return '<div style="border:1px solid rgba(128,128,128,.15);border-radius:6px;padding:8px 4px 4px;background:rgba(128,128,128,.02);">'
      + '<svg viewBox="0 0 ' + W + ' ' + H + '" style="width:100%;height:' + H + 'px;display:block;overflow:visible">'
      + '<defs><linearGradient id="' + id + '" x1="0" y1="0" x2="0" y2="1">'
      + '<stop offset="0%" stop-color="' + color + '" stop-opacity="0.4"/>'
      + '<stop offset="85%" stop-color="' + color + '" stop-opacity="0.03"/>'
      + '</linearGradient></defs>'
      + plotBg + grid + yAxis + yLine + baseline + xAxis + avgLn
      + '<path d="' + area + '" fill="url(#' + id + ')"/>'
      + '<polyline points="' + pts + '" fill="none" stroke="' + color + '" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>'
      + '<circle cx="' + lc.x.toFixed(1) + '" cy="' + lc.y.toFixed(1) + '" r="5" fill="' + color + '" stroke="white" stroke-width="2"/>'
      + plotBorder
      + '</svg>'
      + '<div class="d-flex mt-2 mx-1" style="font-size:.8rem;border:1px solid rgba(128,128,128,.15);border-radius:5px;overflow:hidden;">'
      + '<div style="flex:1;text-align:center;padding:4px 6px;border-right:1px solid rgba(128,128,128,.15);"><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.04em;opacity:.55;">Min</div><strong>' + minFmt + '</strong></div>'
      + '<div style="flex:1;text-align:center;padding:4px 6px;border-right:1px solid rgba(128,128,128,.15);"><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.04em;opacity:.55;">Moy</div><strong style="color:' + color + '">' + avgFmt + '</strong></div>'
      + '<div style="flex:1;text-align:center;padding:4px 6px;border-right:1px solid rgba(128,128,128,.15);"><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.04em;opacity:.55;">Max</div><strong style="color:#f59f00;">' + maxFmt + '</strong></div>'
      + '<div style="flex:1.4;text-align:center;padding:4px 8px;background:' + color + '1a;"><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.04em;opacity:.7;">Actuel</div><strong style="color:' + color + ';">' + lastFmt + '</strong></div>'
      + '</div></div>';
  }

  function statOf(arr) {
    if (!arr || arr.length === 0) return { min: 0, max: 0, avg: 0, last: 0 };
    return {
      min:  Math.min.apply(null, arr),
      max:  Math.max.apply(null, arr),
      avg:  avg(arr),
      last: arr[arr.length - 1],
    };
  }

  function renderHistory(d) {
    var labels = d.labels || [];
    var pts    = labels.length;

    hide('mac-history-spinner');
    show('mac-history-content');

    if (pts < 2) {
      show('mac-history-nodata');
      return;
    }
    hide('mac-history-nodata');

    // Période
    var period = labels[0] + ' → ' + labels[labels.length - 1];
    text('mac-history-period', period);
    var ptsBadge = document.getElementById('mac-history-pts');
    if (ptsBadge) { ptsBadge.textContent = pts + ' points'; ptsBadge.style.display = ''; }

    // ── CPU ──
    var cpu = statOf(d.cpu);
    text('mac-h-cpu-cur', cpu.last.toFixed(1) + '%');
    text('mac-h-cpu-min', cpu.min.toFixed(1) + '%');
    text('mac-h-cpu-avg', cpu.avg.toFixed(1) + '%');
    text('mac-h-cpu-max', cpu.max.toFixed(1) + '%');
    html('mac-h-cpu-chart', spark(d.cpu, labels, '#4299e1', '%', 220));

    // ── RAM ──
    var mem = statOf(d.mem);
    text('mac-h-mem-cur', mem.last.toFixed(1) + '%');
    text('mac-h-mem-min', mem.min.toFixed(1) + '%');
    text('mac-h-mem-avg', mem.avg.toFixed(1) + '%');
    text('mac-h-mem-max', mem.max.toFixed(1) + '%');
    html('mac-h-mem-chart', spark(d.mem, labels, '#ae3ec9', '%', 220));

    // ── Disque ──
    var disk = statOf(d.disk);
    text('mac-h-disk-cur', disk.last.toFixed(1) + '%');
    text('mac-h-disk-min', disk.min.toFixed(1) + '%');
    text('mac-h-disk-avg', disk.avg.toFixed(1) + '%');
    text('mac-h-disk-max', disk.max.toFixed(1) + '%');
    html('mac-h-disk-chart', spark(d.disk, labels, '#0ca678', '%', 220));

    // ── Load 1min ──
    var load = statOf(d.load_1);
    text('mac-h-load-cur', load.last.toFixed(2));
    text('mac-h-load-min', load.min.toFixed(2));
    text('mac-h-load-avg', load.avg.toFixed(2));
    text('mac-h-load-max', load.max.toFixed(2));
    html('mac-h-load-chart', spark(d.load_1, labels, '#f76707', '', 220));

    // ── Réseau entrant ──
    var ni = statOf(d.net_in);
    text('mac-h-netin-cur', ni.last.toFixed(0) + ' KB/s');
    html('mac-h-netin-chart', spark(d.net_in, labels, '#2fb344', 'KB/s', 180));

    // ── Réseau sortant ──
    var no = statOf(d.net_out);
    text('mac-h-netout-cur', no.last.toFixed(0) + ' KB/s');
    html('mac-h-netout-chart', spark(d.net_out, labels, '#17a2b8', 'KB/s', 180));

    // ── Swap ──
    var sw = statOf(d.swap);
    text('mac-h-swap-cur', sw.last.toFixed(1) + '%');
    html('mac-h-swap-chart', spark(d.swap, labels, '#d63939', '%', 180));
  }

  // ── Vue active : 'system' ou nom du process ──────────────────────────────
  var _activeView = 'system';
  window._argosProcActive = null;

  function showSystem() {
    _activeView = 'system';
    window._argosProcActive = null;
    // En-tête
    var nameEl = document.getElementById('mac-history-proc-name');
    if (nameEl) nameEl.style.display = 'none';
    var backBtn = document.getElementById('mac-history-back');
    if (backBtn) backBtn.classList.add('d-none');
    // Panels
    show('mac-history-content');
    hide('mac-history-proc');
    // Surbrillance table
    document.querySelectorAll('#mac-procs-tbody tr').forEach(function (r) {
      r.classList.remove('table-active');
    });
  }

  function showProc(procName) {
    _activeView = procName;
    window._argosProcActive = procName;
    var _savedScroll = window.scrollY;
    // En-tête
    var nameEl = document.getElementById('mac-history-proc-name');
    if (nameEl) { nameEl.textContent = '— ' + procName; nameEl.style.display = ''; }
    var backBtn = document.getElementById('mac-history-back');
    if (backBtn) backBtn.classList.remove('d-none');
    // Panels
    hide('mac-history-content');
    show('mac-history-proc');
    // Surbrillance table
    document.querySelectorAll('#mac-procs-tbody tr').forEach(function (r) {
      r.classList.toggle('table-active', r.dataset.procName === procName);
    });

    // Chargement
    hide('mac-history-proc-content');
    hide('mac-history-proc-nodata');
    show('mac-history-proc-spinner');

    fetch('/infrastructure/mac/proc/' + encodeURIComponent(procName) + '/history')
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (_activeView !== procName) return;
        var sp  = d.sparkline || { labels: [], cpu: [], mem: [] };
        var pts = sp.cpu ? sp.cpu.length : 0;

        hide('mac-history-proc-spinner');
        show('mac-history-proc-content');

        if (pts < 2) { show('mac-history-proc-nodata'); return; }

        var cpu = statOf(sp.cpu), mem = statOf(sp.mem);
        text('mac-hp-cpu-cur', cpu.last.toFixed(1) + '%');
        text('mac-hp-cpu-min', cpu.min.toFixed(1) + '%');
        text('mac-hp-cpu-avg', cpu.avg.toFixed(1) + '%');
        text('mac-hp-cpu-max', cpu.max.toFixed(1) + '%');
        html('mac-hp-cpu-chart', spark(sp.cpu, sp.labels, '#4299e1', '%', 320));

        text('mac-hp-mem-cur', mem.last.toFixed(1) + '%');
        text('mac-hp-mem-min', mem.min.toFixed(1) + '%');
        text('mac-hp-mem-avg', mem.avg.toFixed(1) + '%');
        text('mac-hp-mem-max', mem.max.toFixed(1) + '%');
        html('mac-hp-mem-chart', spark(sp.mem, sp.labels, '#f76707', '%', 320));
        window.scrollTo({ top: _savedScroll, behavior: 'instant' });
      })
      .catch(function () {
        if (_activeView !== procName) return;
        hide('mac-history-proc-spinner');
        show('mac-history-proc-content');
        show('mac-history-proc-nodata');
      });
  }

  // ── Chargement système ────────────────────────────────────────────────────
  function load() {
    fetch('/infrastructure/mac/metrics/history')
      .then(function (r) { return r.json(); })
      .then(renderHistory)
      .catch(function () {
        hide('mac-history-spinner');
        show('mac-history-content');
        show('mac-history-nodata');
      });
  }

  // ── Clic sur une ligne du tableau top processus ───────────────────────────
  document.addEventListener('click', function (e) {
    var row = e.target.closest('tr');
    if (!row || !row.dataset.procName) return;
    e.preventDefault();
    var sy = window.scrollY;
    showProc(row.dataset.procName);
    window.scrollTo({ top: sy, behavior: 'instant' });
  });

  // ── Bouton retour "← Système" ─────────────────────────────────────────────
  document.addEventListener('click', function (e) {
    if (!e.target.closest('#mac-history-back')) return;
    showSystem();
  });

  if (!window._argosMacHistoryInit) {
    window._argosMacHistoryInit = true;
    document.addEventListener('turbo:load', load);
    document.addEventListener('DOMContentLoaded', load);
    setInterval(function () {
      if (_activeView === 'system') {
        load();
      } else {
        showProc(_activeView);
      }
    }, 60000);
  }
  load();
})();
</script>

{% endblock %}
