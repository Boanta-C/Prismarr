{% extends 'base.html.twig' %}

{% block title %}{{ device.name }} — Infrastructure{% endblock %}
{% block page_title %}{{ device.name }}{% endblock %}

{% block page_actions %}
  <div class="d-flex align-items-center gap-2">
    <span class="status-dot {% if device.status == 'online' %}status-dot-animated bg-success{% else %}bg-danger{% endif %}"></span>
    <span class="text-secondary small">{{ device.ipAddress ?? device.hostname }}</span>
  </div>
{% endblock %}

{% block body %}
  <div class="alert alert-info">
    Aucun template dédié pour le type <strong>{{ device.type }}</strong>. Polling en cours…
  </div>
{% endblock %}
