{% extends 'base.html.twig' %}

{% block title %}{{ device.name }} — Infrastructure{% endblock %}
{% block page_title %}{{ device.name }}{% endblock %}

{% block page_actions %}
  <div class="d-flex align-items-center gap-2">
    <span class="status-dot {% if device.status == 'online' %}status-dot-animated bg-success{% else %}bg-danger{% endif %}"></span>
    <span class="text-secondary small">{{ device.ipAddress }}</span>
    {% if device.lastSeenAt %}
      <span class="text-secondary small">· <span id="sse-page-sync">{{ device.lastSeenAt|date('H:i:s') }}</span></span>
    {% endif %}
  </div>
{% endblock %}

{% block body %}

{% if unifi_metrics.clients_total is null %}
  <div class="alert alert-info">
    <div class="d-flex align-items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
           class="text-info flex-shrink-0">
        <circle cx="12" cy="12" r="10"/><path d="M12 16v-4m0-4h.01"/>
      </svg>
      <div>
        <div class="fw-semibold">En attente du premier polling UniFi</div>
        <div class="text-secondary small">Vérifie que <code>UNIFI_USER</code> / <code>UNIFI_PASSWORD</code> sont dans <code>.env.local</code>.</div>
      </div>
    </div>
  </div>
{% else %}

  {# ── Compteurs clients ── #}
  <div class="row g-3 mb-4">

    <div class="col-sm-4">
      <div class="card" style="border-top: 3px solid var(--tblr-blue);">
        <div class="card-body p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="avatar bg-blue-lt" style="border-radius: 10px; width:2.5rem; height:2.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                   fill="none" stroke="var(--tblr-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 7m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"/>
                <path d="M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                <path d="M21 21v-2a4 4 0 0 0 -3 -3.85"/>
              </svg>
            </div>
            <div>
              <div class="text-secondary" style="font-size:.72rem; text-transform:uppercase; letter-spacing:.06em;">Clients total</div>
              <div class="h1 mb-0 text-blue fw-bold" id="sse-unifi-total">{{ unifi_metrics.clients_total ?? '—' }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-sm-4">
      <div class="card">
        <div class="card-body p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="avatar bg-azure-lt" style="border-radius: 10px; width:2.5rem; height:2.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                   fill="none" stroke="var(--tblr-azure)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 18l.01 0"/><path d="M9.172 15.172a4 4 0 0 1 5.656 0"/>
                <path d="M6.343 12.343a8 8 0 0 1 11.314 0"/>
                <path d="M3.515 9.515a12 12 0 0 1 16.97 0"/>
              </svg>
            </div>
            <div>
              <div class="text-secondary" style="font-size:.72rem; text-transform:uppercase; letter-spacing:.06em;">WiFi</div>
              <div class="h1 mb-0 text-azure fw-bold" id="sse-unifi-wifi">{{ unifi_metrics.clients_wifi ?? '—' }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-sm-4">
      <div class="card">
        <div class="card-body p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="avatar bg-teal-lt" style="border-radius: 10px; width:2.5rem; height:2.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                   fill="none" stroke="var(--tblr-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 7h4l2 -3h6l2 3h4"/><path d="M3 7v8a1 1 0 0 0 1 1h16a1 1 0 0 0 1 -1v-8"/>
                <path d="M12 12m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"/>
              </svg>
            </div>
            <div>
              <div class="text-secondary" style="font-size:.72rem; text-transform:uppercase; letter-spacing:.06em;">Filaires</div>
              <div class="h1 mb-0 text-teal fw-bold" id="sse-unifi-wired">{{ unifi_metrics.clients_wired ?? '—' }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  {# ── Health réseau + AP details ── #}
  <div class="row g-3 mb-4">

    {% if unifi_health is not empty %}
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header">
            <div class="card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   class="me-2 text-secondary">
                <path d="M4 8l4 -4l4 4l4 -4l4 4"/><path d="M4 16l4 -4l4 4l4 -4l4 4"/>
              </svg>
              État réseau
            </div>
          </div>
          <div class="card-body p-3">
            <div class="d-flex flex-wrap gap-2">
              {% for subsystem, status in unifi_health %}
                <span class="badge {% if status == 'up' %}bg-success-lt text-success{% else %}bg-danger-lt text-danger{% endif %} d-flex align-items-center gap-1 px-2 py-1">
                  <span class="status-dot {% if status == 'up' %}bg-success{% else %}bg-danger{% endif %}" style="width:6px;height:6px;border-radius:50%;display:inline-block;flex-shrink:0;"></span>
                  {{ subsystem|upper }}
                </span>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {# Point d'accès — détails enrichis via AJAX #}
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header">
          <div class="card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 class="me-2 text-secondary">
              <path d="M12 18l.01 0"/><path d="M9.172 15.172a4 4 0 0 1 5.656 0"/>
              <path d="M6.343 12.343a8 8 0 0 1 11.314 0"/>
              <path d="M3.515 9.515a12 12 0 0 1 16.97 0"/>
            </svg>
            Point d'accès
          </div>
        </div>
        <div class="card-body p-3">

          {# Données depuis DB (uptime/TX/RX) toujours disponibles si premier poll fait #}
          {% if unifi_metrics.ap_uptime is not null %}
            <div class="row g-2 text-center mb-3">
              <div class="col-4">
                <div class="text-secondary" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: .04em;">Uptime</div>
                <div class="fw-semibold small mt-1" id="live-ap-uptime">
                  {% set secs = unifi_metrics.ap_uptime %}
                  {% if secs > 86400 %}
                    {{ (secs / 86400)|round(0, 'floor') }}j {{ ((secs % 86400) / 3600)|round(0, 'floor') }}h
                  {% elseif secs > 3600 %}
                    {{ (secs / 3600)|round(0, 'floor') }}h {{ ((secs % 3600) / 60)|round(0, 'floor') }}min
                  {% else %}
                    {{ (secs / 60)|round(0, 'floor') }}min
                  {% endif %}
                </div>
              </div>
              <div class="col-4">
                <div class="text-secondary" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: .04em;">TX</div>
                <div class="fw-semibold small mt-1 text-success">
                  {% if unifi_metrics.ap_tx_bytes is not null %}
                    {% set tx = unifi_metrics.ap_tx_bytes %}
                    {% if tx > 1073741824 %}{{ (tx / 1073741824)|round(1) }} GB
                    {% elseif tx > 1048576 %}{{ (tx / 1048576)|round(1) }} MB
                    {% else %}{{ (tx / 1024)|round(1) }} KB{% endif %}
                  {% else %}—{% endif %}
                </div>
              </div>
              <div class="col-4">
                <div class="text-secondary" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: .04em;">RX</div>
                <div class="fw-semibold small mt-1 text-azure">
                  {% if unifi_metrics.ap_rx_bytes is not null %}
                    {% set rx = unifi_metrics.ap_rx_bytes %}
                    {% if rx > 1073741824 %}{{ (rx / 1073741824)|round(1) }} GB
                    {% elseif rx > 1048576 %}{{ (rx / 1048576)|round(1) }} MB
                    {% else %}{{ (rx / 1024)|round(1) }} KB{% endif %}
                  {% else %}—{% endif %}
                </div>
              </div>
            </div>
            <hr class="my-2">
          {% endif %}

          {# Informations live chargées via AJAX #}
          <div id="live-ap-spinner" class="d-flex align-items-center gap-2 text-secondary small fst-italic">
            <div class="spinner-border spinner-border-sm" role="status"></div>
            Chargement infos AP…
          </div>
          <table class="table table-sm table-borderless mb-0 d-none" id="live-ap-table">
            <tbody>
              <tr>
                <td class="text-secondary" style="font-size:.8rem; width:40%;">Modèle</td>
                <td class="fw-semibold small" id="live-ap-model">—</td>
              </tr>
              <tr>
                <td class="text-secondary" style="font-size:.8rem;">Firmware</td>
                <td class="fw-semibold small" id="live-ap-version">—</td>
              </tr>
              <tr>
                <td class="text-secondary" style="font-size:.8rem;">IP / MAC</td>
                <td class="fw-semibold small" id="live-ap-ipmac">—</td>
              </tr>
              <tr>
                <td class="text-secondary" style="font-size:.8rem;">Satisfaction</td>
                <td class="small" id="live-ap-satisfaction">—</td>
              </tr>
            </tbody>
          </table>

          {# Radios #}
          <div id="live-ap-radios" class="d-none mt-2">
            <div class="text-secondary fw-medium mb-1" style="font-size:.72rem; text-transform:uppercase; letter-spacing:.05em;">Radios</div>
            <div id="live-ap-radios-body" class="d-flex flex-wrap gap-2"></div>
          </div>

        </div>
      </div>
    </div>

  </div>

  {# ── Table clients (chargée via AJAX initial + SSE Mercure) ── #}
  <div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
      <div class="card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="me-2 text-secondary">
          <path d="M9 7m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"/>
          <path d="M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          <path d="M21 21v-2a4 4 0 0 0 -3 -3.85"/>
        </svg>
        Clients connectés
      </div>
      <span class="badge bg-blue-lt text-blue" id="unifi-client-count-badge">
        {{ unifi_metrics.clients_total ?? '…' }}
      </span>
    </div>
    <div class="card-body p-0">
      <div class="d-flex align-items-center gap-2 text-secondary small fst-italic p-3" id="unifi-clients-spinner">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        Chargement de la liste des clients…
      </div>
      <div class="d-none" id="unifi-clients-content">
        <div class="table-responsive">
          <table class="table table-sm table-vcenter table-hover mb-0">
            <thead>
              <tr>
                <th>Hostname</th>
                <th>IP</th>
                <th>Type</th>
                <th class="text-center">Signal / Canal</th>
                <th class="text-end">TX</th>
                <th class="text-end">RX</th>
                <th class="text-center">Satisfaction</th>
                <th>Uptime</th>
              </tr>
            </thead>
            <tbody id="unifi-clients-tbody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

{% endif %}

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function () {
  /* ── Helpers ── */
  function mercureUrl(topic) {
    var u = new URL('/.well-known/mercure', window.location.origin);
    u.searchParams.append('topic', topic);
    return u.toString();
  }
  function setEl(id, val) {
    var el = document.getElementById(id);
    if (el && val !== null && val !== undefined) el.textContent = val;
  }
  function fmtUptime(s) {
    if (!s) return '—';
    var d = Math.floor(s / 86400);
    var h = Math.floor((s % 86400) / 3600);
    var m = Math.floor((s % 3600) / 60);
    if (d > 0) return d + 'j ' + h + 'h';
    if (h > 0) return h + 'h ' + m + 'min';
    return m + 'min';
  }
  function fmtUptimeAp(s) {
    if (!s) return '—';
    var d = Math.floor(s / 86400);
    var h = Math.floor((s % 86400) / 3600);
    var m = Math.floor((s % 3600) / 60);
    if (d > 0) return d + 'j ' + h + 'h';
    if (h > 0) return h + 'h ' + m + 'min';
    return m + 'min';
  }
  function fmtBytes(b) {
    if (b === null || b === undefined) return '—';
    if (b >= 1073741824) return (b / 1073741824).toFixed(1) + ' GB';
    if (b >= 1048576)    return (b / 1048576).toFixed(1) + ' MB';
    if (b >= 1024)       return (b / 1024).toFixed(1) + ' KB';
    return b + ' B';
  }
  function satBadge(score) {
    if (score === null || score === undefined) return '<span class="text-secondary">—</span>';
    var cls = score >= 70 ? 'bg-success-lt text-success' : score >= 40 ? 'bg-warning-lt text-warning' : 'bg-danger-lt text-danger';
    return '<span class="badge ' + cls + '">' + score + '%</span>';
  }
  function protoBadge(proto) {
    if (!proto) return '';
    var map = { ax: 'bg-blue-lt text-blue', ac: 'bg-azure-lt text-azure', n: 'bg-indigo-lt text-indigo', g: 'bg-muted-lt text-muted' };
    var cls = map[proto] || 'bg-muted-lt text-muted';
    return '<span class="badge ' + cls + ' ms-1">' + proto.toUpperCase() + '</span>';
  }
  function signalBadge(signal) {
    if (signal === null || signal === undefined) return '—';
    var cls = signal >= -60 ? 'bg-success-lt text-success' : signal >= -75 ? 'bg-warning-lt text-warning' : 'bg-danger-lt text-danger';
    return '<span class="badge ' + cls + '">' + signal + ' dBm</span>';
  }

  /* ── Rendu table clients ── */
  function renderClients(clients) {
    var tbody = document.getElementById('unifi-clients-tbody');
    if (!tbody) return;
    tbody.innerHTML = '';

    if (!clients || clients.length === 0) {
      tbody.innerHTML = '<tr><td colspan="8" class="text-center text-secondary fst-italic py-3">Aucun client connecté.</td></tr>';
      return;
    }

    var sorted = clients.slice().sort(function(a, b) {
      return (a.hostname || '').localeCompare(b.hostname || '');
    });

    sorted.forEach(function (c) {
      var tr = document.createElement('tr');
      tr.setAttribute('data-client-mac', c.mac || '');
      var typeBadge = c.is_wired
        ? '<span class="badge bg-teal-lt text-teal">Filaire</span>'
        : '<span class="badge bg-azure-lt text-azure">WiFi</span>' + protoBadge(c.radio_proto);
      var signalCell = c.is_wired
        ? '<span class="text-secondary">—</span>'
        : signalBadge(c.signal) + (c.channel ? ' <span class="text-muted small">ch.' + c.channel + '</span>' : '');
      var txCell = c.tx_rate !== null && c.tx_rate !== undefined ? c.tx_rate + ' Mbps' : '—';
      var rxCell = c.rx_rate !== null && c.rx_rate !== undefined ? c.rx_rate + ' Mbps' : '—';

      tr.innerHTML =
        '<td class="fw-semibold small">' + (c.hostname || '—') + '</td>' +
        '<td class="text-secondary small font-monospace">' + (c.ip || '—') + '</td>' +
        '<td>' + typeBadge + '</td>' +
        '<td class="text-center unifi-signal-cell">' + signalCell + '</td>' +
        '<td class="text-end small text-success unifi-tx-cell">' + txCell + '</td>' +
        '<td class="text-end small text-azure unifi-rx-cell">' + rxCell + '</td>' +
        '<td class="text-center unifi-sat-cell">' + satBadge(c.satisfaction) + '</td>' +
        '<td class="text-secondary small unifi-uptime-cell">' + fmtUptime(c.uptime) + '</td>';
      tbody.appendChild(tr);
    });
  }

  /* ── Mise à jour en place si même liste (SSE) ── */
  function updateClientsInPlace(clients) {
    var tbody = document.getElementById('unifi-clients-tbody');
    if (!tbody) return;
    var domRows = tbody.querySelectorAll('[data-client-mac]');
    // Si le nombre de clients a changé ou table vide → re-render complet
    if (domRows.length !== clients.length) { renderClients(clients); return; }
    var domMacs = Array.from(domRows).map(function(r){ return r.dataset.clientMac; });
    var sseMacs = clients.map(function(c){ return c.mac || ''; });
    var structureChanged = sseMacs.some(function(m){ return !domMacs.includes(m); });
    if (structureChanged) { renderClients(clients); return; }
    // Même liste → update cellules dynamiques uniquement
    clients.forEach(function(c) {
      var row = tbody.querySelector('[data-client-mac="' + (c.mac || '') + '"]');
      if (!row) return;
      var signalCell = c.is_wired
        ? '<span class="text-secondary">—</span>'
        : signalBadge(c.signal) + (c.channel ? ' <span class="text-muted small">ch.' + c.channel + '</span>' : '');
      var sig = row.querySelector('.unifi-signal-cell');
      var tx  = row.querySelector('.unifi-tx-cell');
      var rx  = row.querySelector('.unifi-rx-cell');
      var sat = row.querySelector('.unifi-sat-cell');
      var upt = row.querySelector('.unifi-uptime-cell');
      if (sig) sig.innerHTML = signalCell;
      if (tx)  tx.textContent  = c.tx_rate !== null && c.tx_rate !== undefined ? c.tx_rate + ' Mbps' : '—';
      if (rx)  rx.textContent  = c.rx_rate !== null && c.rx_rate !== undefined ? c.rx_rate + ' Mbps' : '—';
      if (sat) sat.innerHTML   = satBadge(c.satisfaction);
      if (upt) upt.textContent = fmtUptime(c.uptime);
    });
  }

  /* ── Rendu AP détaillé ── */
  function renderApDetails(ap) {
    if (!ap) return;
    var spinner = document.getElementById('live-ap-spinner');
    var table   = document.getElementById('live-ap-table');
    if (spinner) spinner.classList.add('d-none');
    if (table)   table.classList.remove('d-none');

    setEl('live-ap-model',   ap.model || '—');
    setEl('live-ap-version', ap.version || '—');

    var ipMacEl = document.getElementById('live-ap-ipmac');
    if (ipMacEl) ipMacEl.textContent = (ap.ip || '—') + ' / ' + (ap.mac || '—');

    var satEl = document.getElementById('live-ap-satisfaction');
    if (satEl) satEl.innerHTML = satBadge(ap.satisfaction);

    // Uptime en texte si SSE fournit la valeur
    if (ap.uptime) {
      var uptimeEl = document.getElementById('live-ap-uptime');
      if (uptimeEl) uptimeEl.textContent = fmtUptimeAp(ap.uptime);
    }

    // Radios
    if (ap.radio_table && ap.radio_table.length > 0) {
      var radiosDiv  = document.getElementById('live-ap-radios');
      var radiosBody = document.getElementById('live-ap-radios-body');
      if (radiosDiv) radiosDiv.classList.remove('d-none');
      if (radiosBody) {
        radiosBody.innerHTML = '';
        ap.radio_table.forEach(function (radio) {
          var el = document.createElement('span');
          el.className = 'badge bg-muted-lt text-muted d-inline-flex align-items-center gap-1 px-2 py-1';
          var protoLabel = radio.radio ? radio.radio.toUpperCase() : '?';
          var ch = radio.channel ? 'ch.' + radio.channel : '';
          var pwr = radio.tx_power ? radio.tx_power + ' dBm' : '';
          var sta = radio.num_sta !== null && radio.num_sta !== undefined ? radio.num_sta + ' sta' : '';
          var parts = [protoLabel, ch, pwr, sta].filter(Boolean);
          el.textContent = parts.join(' · ');
          radiosBody.appendChild(el);
        });
      }
    }
  }

  /* ── Chargement AJAX initial ── */
  function loadUnifiLive() {
    fetch('/infrastructure/unifi/live', { credentials: 'same-origin' })
      .then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); })
      .then(function (d) {
        // Compteurs
        setEl('sse-unifi-total', d.client_count);
        setEl('sse-unifi-wifi',  d.wifi_count);
        setEl('sse-unifi-wired', d.wired_count);
        setEl('unifi-client-count-badge', d.client_count);

        // AP
        renderApDetails(d.ap);

        // Clients
        var spinner = document.getElementById('unifi-clients-spinner');
        var content = document.getElementById('unifi-clients-content');
        if (spinner) spinner.classList.add('d-none');
        if (content) content.classList.remove('d-none');
        renderClients(d.clients);
      })
      .catch(function (err) {
        var spinner = document.getElementById('unifi-clients-spinner');
        if (spinner) spinner.innerHTML = '<span class="text-danger small">Erreur de chargement des clients.</span>';
        var apSpinner = document.getElementById('live-ap-spinner');
        if (apSpinner) apSpinner.innerHTML = '<span class="text-danger small">Erreur de chargement AP.</span>';
      });
  }

  /* ── SSE Mercure ── */
  function init() {
    if (window._argosApSrc) { window._argosApSrc.close(); window._argosApSrc = null; }
    if (!document.getElementById('sse-unifi-total')) return;

    // Chargement AJAX au démarrage
    loadUnifiLive();

    window._argosApSrc = new EventSource(mercureUrl('/argos/metrics/unifi'));
    window._argosApSrc.onmessage = function (e) {
      var d = JSON.parse(e.data);

      // Compteurs
      setEl('sse-unifi-total', d.clients_total);
      setEl('sse-unifi-wifi',  d.clients_wifi);
      setEl('sse-unifi-wired', d.clients_wired);
      setEl('unifi-client-count-badge', d.clients_total);

      // AP
      if (d.ap) {
        renderApDetails(d.ap);
      }

      // Clients : update en place si même structure, re-render sinon
      if (d.clients && d.clients.length >= 0) {
        var spinner = document.getElementById('unifi-clients-spinner');
        var content = document.getElementById('unifi-clients-content');
        if (spinner) spinner.classList.add('d-none');
        if (content) content.classList.remove('d-none');
        updateClientsInPlace(d.clients);
      }

      var sc = document.getElementById('sse-page-sync');
      if (sc && d.last_seen) sc.textContent = d.last_seen;
    };
  }

  if (!window._argosApListeners) {
    window._argosApListeners = true;
    document.addEventListener('turbo:load', init);
    document.addEventListener('DOMContentLoaded', init);
    document.addEventListener('turbo:before-cache', function () {
      if (window._argosApSrc) { window._argosApSrc.close(); window._argosApSrc = null; }
    });
  }
  init();
})();
</script>
{% endblock %}
