{# ===== Modal détail container (Mac Mini) ===== #}
<div class="modal modal-blur fade" id="container-modal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
    <div class="modal-content">
