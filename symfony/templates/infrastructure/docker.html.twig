{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function () {
  function mercureUrl(topic) {
    var u = new URL('/.well-known/mercure', window.location.origin);
    u.searchParams.append('topic', topic);
    return u.toString();
  }
  function barColor(v, warn, danger, ok) {
    return v > danger ? 'bg-danger' : (v > warn ? 'bg-warning' : ok);
  }

  /* ── Switch Mac / NAS ── */
  window.switchDockerTab = function(tab) {
    var panelMac = document.getElementById('panel-mac');
    var panelNas = document.getElementById('panel-nas');
    var btnMac   = document.getElementById('tab-btn-mac');
    var btnNas   = document.getElementById('tab-btn-nas');
    var subtitle = document.getElementById('docker-tab-subtitle');
    var syncLabel = document.getElementById('docker-tab-sync-label');
    if (tab === 'nas') {
      if (panelMac) panelMac.style.display = 'none';
      if (panelNas) panelNas.style.display = '';
      if (btnMac) { btnMac.className = 'btn btn-sm btn-outline-secondary'; }
      if (btnNas) { btnNas.className = 'btn btn-sm btn-primary'; }
      if (subtitle) subtitle.innerHTML = '<a href="{{ path('app_infrastructure_device', {hostname: 'ds-medusa'}) }}" class="text-secondary">Voir la page →</a>';
      if (syncLabel) syncLabel.textContent = 'DS-MEDUSA';
    } else {
      if (panelMac) panelMac.style.display = '';
      if (panelNas) panelNas.style.display = 'none';
      if (btnMac) { btnMac.className = 'btn btn-sm btn-primary'; }
      if (btnNas) { btnNas.className = 'btn btn-sm btn-outline-secondary'; }
      if (subtitle) subtitle.innerHTML = '{% if mac_device %}<a href="{{ path('app_infrastructure_device', {hostname: mac_device.hostname}) }}" class="text-secondary">Voir la page →</a>{% endif %}';
      if (syncLabel) syncLabel.textContent = 'Mac Mini';
    }
  };

  /* ── Mini sparkline modale 24h ── */
  var _spkGradId = 0;
  function miniSparkSvg(data, color) {
    if (!data || data.length < 2) return '';
    var id = 'sg' + (++_spkGradId);
    var W = 300, H = 36, px = 1, py = 3;
    var max = Math.max.apply(null, data.concat([0.001]));
    var coords = data.map(function (v, i) {
      return { x: px + i / (data.length - 1) * (W - 2*px), y: py + (1 - v/max) * (H - 2*py) };
    });
    var pts  = coords.map(function (c) { return c.x.toFixed(1)+','+c.y.toFixed(1); }).join(' ');
    var lc   = coords[coords.length - 1];
    var area = 'M '+coords.map(function(c){return c.x.toFixed(1)+' '+c.y.toFixed(1);}).join(' L ')
             +' L '+lc.x.toFixed(1)+' '+H+' L '+coords[0].x.toFixed(1)+' '+H+' Z';
    return '<svg viewBox="0 0 '+W+' '+H+'" preserveAspectRatio="none" style="width:100%;height:36px;display:block">'
      +'<defs><linearGradient id="'+id+'" x1="0" y1="0" x2="0" y2="1">'
      +'<stop offset="0%" stop-color="'+color+'" stop-opacity="0.3"/>'
      +'<stop offset="100%" stop-color="'+color+'" stop-opacity="0.02"/>'
      +'</linearGradient></defs>'
      +'<path d="'+area+'" fill="url(#'+id+')"/>'
      +'<polyline points="'+pts+'" fill="none" stroke="'+color+'" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>'
      +'<circle cx="'+lc.x.toFixed(1)+'" cy="'+lc.y.toFixed(1)+'" r="2.5" fill="'+color+'"/>'
      +'</svg>';
  }

  /* ── SSE Mac Mini ── */
  function init() {
    if (window._argosDockerSrc) { window._argosDockerSrc.close(); window._argosDockerSrc = null; }
    if (!document.getElementById('sse-running-count')) return;

    window._argosDockerSrc = new EventSource(mercureUrl('/argos/containers'));
    window._argosDockerSrc.onmessage = function (e) {
      var d = JSON.parse(e.data);
      var running = 0, down = 0, degraded = 0;
      d.containers.forEach(function (c) {
        if (c.status === 'up') running++; else if (c.status === 'down') down++; else if (c.status === 'degraded') degraded++;
      });
      var rc = document.getElementById('sse-running-count');
      var dc = document.getElementById('sse-down-count');
      var gc = document.getElementById('sse-degraded-count');
      var sc = document.getElementById('sse-page-sync');
      if (rc) rc.textContent = running;
      if (dc) dc.textContent = down;
      if (gc) gc.textContent = degraded;
      if (sc && d.last_seen) sc.textContent = d.last_seen;

      var statusChanged = false;
      var domCards = document.querySelectorAll('[data-container]');
      var domNames = Array.from(domCards).map(function(el) { return el.dataset.container; });
      var sseNames = d.containers.map(function(c) { return c.name; });
      if (domNames.length !== sseNames.length || sseNames.some(function(n){ return !domNames.includes(n); })) {
        statusChanged = true;
      }
      if (!statusChanged) {
        d.containers.forEach(function(c) {
          var card = document.querySelector('[data-container="'+c.name+'"]');
          if (card && card.dataset.status !== c.status) statusChanged = true;
        });
      }
      if (statusChanged) {
        fetch(window.location.href, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
          .then(function(r) { return r.text(); })
          .then(function(html) {
            var doc = new DOMParser().parseFromString(html, 'text/html');
            var newGrid = doc.getElementById('containers-grid');
            var oldGrid = document.getElementById('containers-grid');
            if (newGrid && oldGrid) { oldGrid.replaceWith(newGrid); }
          });
        return;
      }
      d.containers.forEach(function (c) {
        var card = document.querySelector('[data-container="'+c.name+'"]');
        if (!card) return;
        if (c.cpu !== null) {
          var bar = card.querySelector('[data-cpu-bar]');
          if (bar) { bar.style.width = Math.min(c.cpu,100)+'%'; bar.className = 'progress-bar '+barColor(c.cpu,50,80,'bg-primary'); }
          var val = card.querySelector('[data-cpu-val]');
          if (val) { val.textContent = c.cpu+'%'; val.className = 'fw-semibold small '+(c.cpu>80?'text-danger':c.cpu>50?'text-warning':'text-muted'); }
        }
        if (c.mem !== null) {
          var bar = card.querySelector('[data-mem-bar]');
          if (bar) { bar.style.width = Math.min(c.mem,100)+'%'; bar.className = 'progress-bar '+barColor(c.mem,60,80,'bg-azure'); }
          var val = card.querySelector('[data-mem-val]');
          if (val) { val.textContent = (c.mem_mb?c.mem_mb+' MB · ':'')+c.mem+'%'; val.className = 'fw-semibold small '+(c.mem>80?'text-danger':c.mem>60?'text-warning':'text-muted'); }
        }
        var ts = card.querySelector('[data-checked-at]');
        if (ts && d.last_seen) ts.textContent = d.last_seen;
      });
    };
  }

  /* ── SSE NAS Docker ── */
  function reloadNasGrid() {
    fetch(window.location.href, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.text(); })
      .then(function(html) {
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var newGrid = doc.getElementById('nas-docker-grid');
        var oldGrid = document.getElementById('nas-docker-grid');
        if (newGrid && oldGrid) oldGrid.replaceWith(newGrid);
        var newCount = doc.getElementById('nas-docker-running-count');
        var oldCount = document.getElementById('nas-docker-running-count');
        if (newCount && oldCount) oldCount.textContent = newCount.textContent;
      });
  }

  function initNasSse() {
    if (window._argosNasSrc) { window._argosNasSrc.close(); window._argosNasSrc = null; }
    if (!document.getElementById('nas-docker-grid')) return;
    window._argosNasSrc = new EventSource(mercureUrl('/argos/metrics/nas'));
    window._argosNasSrc.onmessage = function(e) {
      var data = JSON.parse(e.data);
      if (!data.containers || !data.containers.length) return;

      var running = data.containers.filter(function(c){ return c.status === 'up'; }).length;
      var stopped = data.containers.filter(function(c){ return c.status === 'down'; }).length;
      var errors  = data.containers.filter(function(c){ return c.status === 'error'; }).length;
      var countEl = document.getElementById('nas-docker-running-count');
      if (countEl) countEl.textContent = running;
      var downEl = document.getElementById('nas-docker-down-count');
      if (downEl) downEl.textContent = stopped;
      var errorEl = document.getElementById('nas-docker-error-count');
      if (errorEl) errorEl.textContent = errors;
      var syncEl = document.getElementById('nas-docker-sync');
      if (syncEl) { var now = new Date(); syncEl.textContent = now.toTimeString().slice(0,8); }

      // Détecter si la liste a changé (nouveau container ou status différent)
      var domCards = document.querySelectorAll('[data-nas-name][data-nas-status]');
      var domNames = Array.from(domCards).map(function(el){ return el.dataset.nasName; });
      var sseNames = data.containers.map(function(c){ return c.name; });
      var listChanged = domNames.length !== sseNames.length
        || sseNames.some(function(n){ return domNames.indexOf(n) === -1; });

      if (!listChanged) {
        data.containers.forEach(function(c) {
          var card = document.querySelector('[data-nas-name="'+c.name+'"]');
          if (card && card.dataset.nasStatus !== c.status) listChanged = true;
        });
      }

      if (listChanged) { reloadNasGrid(); return; }

      // Mise à jour CPU / RAM sans rechargement
      data.containers.forEach(function(c) {
        var card = document.querySelector('[data-nas-name="'+c.name+'"]');
        if (!card) return;
        if (c.cpu !== null) {
          var bar = card.querySelector('[data-nas-cpu-bar]');
          if (bar) { bar.style.width = Math.min(c.cpu,100)+'%'; bar.className = 'progress-bar '+barColor(c.cpu,50,80,'bg-primary'); }
          var val = card.querySelector('[data-nas-cpu-val]');
          if (val) { val.textContent = c.cpu+'%'; val.className = 'fw-semibold small '+(c.cpu>80?'text-danger':c.cpu>50?'text-warning':'text-muted'); }
        }
        if (c.mem !== null) {
          var bar = card.querySelector('[data-nas-mem-bar]');
          if (bar) { bar.style.width = Math.min(c.mem,100)+'%'; bar.className = 'progress-bar '+barColor(c.mem,60,80,'bg-azure'); }
          var val = card.querySelector('[data-nas-mem-val]');
          if (val) { val.textContent = (c.mem_mb?c.mem_mb+' MB · ':'')+c.mem+'%'; val.className = 'fw-semibold small '+(c.mem>80?'text-danger':c.mem>60?'text-warning':'text-muted'); }
        }
        var ts = card.querySelector('[data-nas-checked-at]');
        if (ts && data.last_seen) ts.textContent = data.last_seen;
      });
    };
  }

  if (!window._argosDockerPageListeners) {
    window._argosDockerPageListeners = true;
    document.addEventListener('turbo:load', function() { init(); initNasSse(); });
    document.addEventListener('DOMContentLoaded', function() { init(); initNasSse(); });
    document.addEventListener('turbo:before-cache', function () {
      if (window._argosDockerSrc) { window._argosDockerSrc.close(); window._argosDockerSrc = null; }
      if (window._argosNasSrc) { window._argosNasSrc.close(); window._argosNasSrc = null; }
      document.querySelectorAll('.modal-backdrop').forEach(function(el){ el.remove(); });
      document.body.classList.remove('modal-open');
      document.body.style.removeProperty('overflow');
      document.body.style.removeProperty('padding-right');
    });
  }
  init();
  initNasSse();
})();
</script>

{# ===== JS Modal Détail Container ===== #}
<script>
(function () {
  var _current = null, _logsInterval = null;
  function show(id)  { var el=document.getElementById(id); if(el) el.classList.remove('d-none'); }
  function hide(id)  { var el=document.getElementById(id); if(el) el.classList.add('d-none'); }
  function text(id,t){ var el=document.getElementById(id); if(el) el.textContent=t; }
  function html(id,h){ var el=document.getElementById(id); if(el) el.innerHTML=h; }
  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  var _sparkId = 0;
  function sparklineSvg(data, labels, color) {
    if (!data || data.length < 2) return '<div class="text-center text-secondary small fst-italic py-3">Données insuffisantes (en attente de collecte)</div>';
    var id = 'spk'+(++_sparkId);
    var W=540,H=160,padL=36,padR=12,padT=10,padB=28;
    var iW=W-padL-padR, iH=H-padT-padB;
    var rawMax=Math.max.apply(null,data.concat([1])), rawMin=Math.min.apply(null,data);
    var gridMax=Math.ceil(rawMax/25)*25; if(gridMax<25) gridMax=25;
    var last=data[data.length-1];
    var coords=data.map(function(v,i){ return {x:padL+(i/(data.length-1))*iW, y:padT+(1-v/gridMax)*iH}; });
    var pts=coords.map(function(c){return c.x.toFixed(1)+','+c.y.toFixed(1);}).join(' ');
    var lc=coords[coords.length-1];
    var area='M '+coords.map(function(c){return c.x.toFixed(1)+' '+c.y.toFixed(1);}).join(' L ')
            +' L '+lc.x.toFixed(1)+' '+(padT+iH)+' L '+padL+' '+(padT+iH)+' Z';
    var grid='',yAxis='';
    [0,25,50,75,100].filter(function(v){return v<=gridMax;}).forEach(function(pct){
      var y=padT+(1-pct/gridMax)*iH;
      grid+='<line x1="'+padL+'" y1="'+y.toFixed(1)+'" x2="'+(W-padR)+'" y2="'+y.toFixed(1)+'" stroke="currentColor" stroke-opacity="0.07" stroke-dasharray="4 3"/>';
      yAxis+='<text x="'+(padL-5)+'" y="'+(y+3.5).toFixed(1)+'" text-anchor="end" font-size="9" fill="currentColor" opacity="0.45">'+pct+'</text>';
    });
    var xAxis='';
    if(labels && labels.length>=2) {
      [0,Math.round(data.length*.25),Math.round(data.length*.5),Math.round(data.length*.75),data.length-1].forEach(function(idx){
        if(idx>=labels.length) return;
        var x=padL+(idx/(data.length-1))*iW;
        xAxis+='<text x="'+x.toFixed(1)+'" y="'+(H-6)+'" text-anchor="middle" font-size="9" fill="currentColor" opacity="0.45">'+labels[idx]+'</text>';
      });
    }
    var yLine='<line x1="'+padL+'" y1="'+padT+'" x2="'+padL+'" y2="'+(padT+iH)+'" stroke="currentColor" stroke-opacity="0.15"/>';
    return '<div class="mb-1">'
      +'<svg viewBox="0 0 '+W+' '+H+'" style="width:100%;height:160px;display:block;overflow:visible">'
      +'<defs><linearGradient id="'+id+'" x1="0" y1="0" x2="0" y2="1">'
      +'<stop offset="0%" stop-color="'+color+'" stop-opacity="0.35"/>'
      +'<stop offset="75%" stop-color="'+color+'" stop-opacity="0.06"/>'
      +'<stop offset="100%" stop-color="'+color+'" stop-opacity="0.0"/>'
      +'</linearGradient></defs>'
      +grid+yAxis+yLine+xAxis
      +'<path d="'+area+'" fill="url(#'+id+')"/>'
      +'<polyline points="'+pts+'" fill="none" stroke="'+color+'" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>'
      +'<circle cx="'+lc.x.toFixed(1)+'" cy="'+lc.y.toFixed(1)+'" r="4" fill="'+color+'" stroke="white" stroke-width="1.5"/>'
      +'</svg>'
      +'<div class="d-flex justify-content-between px-1 mt-1" style="font-size:.72rem">'
      +'<span class="text-muted">min <strong>'+rawMin.toFixed(1)+'%</strong></span>'
      +'<span style="color:'+color+'" class="fw-bold">'+last.toFixed(1)+'% actuellement</span>'
      +'<span class="text-muted">max <strong>'+rawMax.toFixed(1)+'%</strong></span>'
      +'</div></div>';
  }

  function populateInfos(d) {
    var hasError   = !!(d.error && String(d.error).trim() !== '') || (d.state!=='running' && d.exit_code!==null && d.exit_code!==undefined && d.exit_code!==0);
    var stateColor = d.state==='running' ? 'success' : (hasError ? 'danger' : 'secondary');
    var dot=document.getElementById('modal-status-dot');
    if(dot) dot.className='status-dot bg-'+stateColor+' flex-shrink-0'+(d.state==='running'?' status-dot-animated':'');
    var badge=document.getElementById('modal-container-badge');
    if(badge){badge.textContent=d.state;badge.className='badge bg-'+stateColor+'-lt ms-1 flex-shrink-0';}
    text('modal-container-id',d.id?'ID: '+d.id:'');
    if(_current&&!_current.isSystem){
      if(d.state==='running'){show('modal-btn-stop');show('modal-btn-restart');hide('modal-btn-start');}
      else{hide('modal-btn-stop');hide('modal-btn-restart');show('modal-btn-start');}
    }
    var portsHtml=d.ports&&d.ports.length?d.ports.map(function(p){return '<code class="me-2">'+p.host+' → '+p.container+'</code>';}).join(''):'<span class="text-secondary">Aucun port exposé</span>';
    var mountsHtml=d.mounts&&d.mounts.length?'<ul class="list-unstyled mb-0 small">'+d.mounts.map(function(m){var b=m.type==='volume'?'bg-azure-lt':'bg-secondary-lt';return '<li class="mb-1"><span class="badge '+b+' me-1">'+m.type+'</span><span class="text-secondary font-monospace">'+(m.source||m.name||'—')+'</span> <span class="text-muted mx-1">→</span><span class="font-monospace">'+m.destination+'</span>'+(m.mode==='ro'?' <span class="badge bg-warning-lt ms-1">ro</span>':'')+'</li>';}).join('')+'</ul>':'<span class="text-secondary">Aucun volume</span>';
    var startedAt='—';
    if(d.started_at&&d.started_at!=='0001-01-01T00:00:00Z') startedAt=new Date(d.started_at).toLocaleString('fr-FR');
    var finishedAt='';
    if(d.state!=='running'&&d.finished_at&&d.finished_at!=='0001-01-01T00:00:00Z') finishedAt=new Date(d.finished_at).toLocaleString('fr-FR');
    var networksHtml=d.networks&&d.networks.length?d.networks.map(function(n){var al=n.aliases&&n.aliases.length?' <span class="text-muted small">('+n.aliases.join(', ')+')</span>':'';var gw=n.gateway?' <span class="text-muted small">gw '+n.gateway+'</span>':'';return '<div class="mb-1"><span class="badge bg-indigo-lt me-1">'+n.name+'</span>'+(n.ip?'<code class="small">'+n.ip+'</code>':'')+gw+al+'</div>';}).join(''):'<span class="text-secondary">—</span>';
    var rpColor={'always':'success','unless-stopped':'azure','on-failure':'warning','no':'secondary'};
    var rpBadge='<span class="badge bg-'+(rpColor[d.restart_policy]||'secondary')+'-lt">'+(d.restart_policy||'no')+'</span>';
    var exitRow='';
    if(d.state!=='running'&&d.exit_code!==null&&d.exit_code!==undefined){var ec=d.exit_code===0?'success':'danger';exitRow='<tr><td class="text-secondary">Exit code</td><td><span class="badge bg-'+ec+'-lt font-monospace">'+d.exit_code+'</span>'+(finishedAt?' <span class="text-muted small ms-2">arrêté le '+finishedAt+'</span>':'')+'</td></tr>';}
    var errorRow='';
    if(d.error&&String(d.error).trim()!==''){errorRow='<tr><td class="text-secondary align-top">Erreur</td><td><div class="alert alert-danger mb-0 py-2 px-2" style="font-size:.78rem;word-break:break-word"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1" style="vertical-align:-2px"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.24 3.957l-8.422 14.06a1.989 1.989 0 0 0 1.7 2.983h16.845a1.989 1.989 0 0 0 1.7 -2.983l-8.423 -14.06a1.989 1.989 0 0 0 -3.4 0z"/></svg>'+esc(d.error)+'</div></td></tr>';}
    html('modal-infos-content','<table class="table table-sm mb-0">'
      +'<tr><td class="text-secondary" style="width:130px">Image</td><td><code class="text-truncate d-inline-block" style="max-width:400px">'+(d.image||'—')+'</code></td></tr>'
      +'<tr><td class="text-secondary">Hostname</td><td><code>'+(d.hostname||'—')+'</code></td></tr>'
      +'<tr><td class="text-secondary">Démarré le</td><td>'+startedAt+'</td></tr>'
      +exitRow
      +errorRow
      +'<tr><td class="text-secondary">Restart</td><td>'+rpBadge+'</td></tr>'
      +'<tr><td class="text-secondary align-top">Réseaux</td><td>'+networksHtml+'</td></tr>'
      +'<tr><td class="text-secondary">Ports</td><td>'+portsHtml+'</td></tr>'
      +'<tr><td class="text-secondary align-top">Volumes</td><td>'+mountsHtml+'</td></tr>'
      +'</table>'
      +(d.env&&d.env.length?('<div class="mt-3"><div class="d-flex align-items-center justify-content-between mb-2"><span class="text-secondary small text-uppercase fw-medium" style="letter-spacing:.05em">Variables d\'environnement</span><span class="badge bg-secondary-lt">'+d.env.length+'</span></div><div style="max-height:320px;overflow-y:auto;border:1px solid var(--tblr-border-color);border-radius:6px"><table class="table table-sm mb-0" style="font-size:.73rem">'+d.env.map(function(e){var m=e.value==='***';return '<tr><td class="font-monospace text-secondary pe-3" style="width:38%;word-break:break-all;white-space:normal">'+esc(e.key)+'</td><td class="font-monospace'+(m?' text-muted':'')+'" style="word-break:break-all;white-space:normal">'+(m?'<span class="badge bg-warning-lt">masked</span>':esc(e.value))+'</td></tr>';}).join('')+'</table></div></div>'):'<div class="mt-3 text-secondary small fst-italic">Aucune variable d\'environnement</div>')
    );
    hide('modal-infos-spinner'); show('modal-infos-content');
  }

  function populateStats(d) {
    var sp=d.sparkline||{labels:[],cpu:[],mem:[]};
    var period=sp.labels&&sp.labels.length>=2?'<span class="text-muted small">'+sp.labels[0]+' → '+sp.labels[sp.labels.length-1]+'</span>':'<span class="text-muted small fst-italic">pas encore de données 24h</span>';
    html('modal-stats-content',
      '<div class="mb-4"><div class="d-flex justify-content-between align-items-center mb-2"><span class="text-secondary small text-uppercase fw-medium" style="letter-spacing:.05em">CPU — 24h</span>'+period+'</div>'+sparklineSvg(sp.cpu,sp.labels,'var(--tblr-primary)')+'</div>'
      +'<div><div class="d-flex justify-content-between align-items-center mb-2"><span class="text-secondary small text-uppercase fw-medium" style="letter-spacing:.05em">RAM — 24h</span></div>'+sparklineSvg(sp.mem,sp.labels,'var(--tblr-azure)')+'</div>'
    );
    hide('modal-stats-spinner'); show('modal-stats-content');
  }

  function _resetModal(displayName) {
    if(_logsInterval){clearInterval(_logsInterval);_logsInterval=null;}
    text('modal-container-name',displayName); text('modal-container-id','');
    var dot=document.getElementById('modal-status-dot');
    if(dot) dot.className='status-dot bg-secondary flex-shrink-0';
    var badge=document.getElementById('modal-container-badge');
    if(badge){badge.textContent='';badge.className='badge bg-secondary-lt ms-1 flex-shrink-0';}
    ['infos','stats','logs'].forEach(function(t){show('modal-'+t+'-spinner');hide('modal-'+t+'-content');});
    if(document.getElementById('modal-logs-spinner'))
      document.getElementById('modal-logs-spinner').innerHTML='<div class="spinner-border spinner-border-sm text-secondary"></div><div class="text-secondary small mt-2">Chargement des logs…</div>';
    ['modal-btn-restart','modal-btn-stop','modal-btn-start'].forEach(function(bid){var b=document.getElementById(bid);if(b)b.classList.add('d-none');});
    var firstTab=document.getElementById('modal-tab-infos'); if(firstTab) firstTab.click();
    var trigger=document.getElementById('container-modal-trigger'); if(trigger) trigger.click();
  }

  function openNasModal(name, status) {
    _current={source:'nas',name:name};
    _resetModal(name);
    // Boutons selon le statut connu ; populateInfos corrigera après l'inspect
    if(status==='up'){show('modal-btn-restart');show('modal-btn-stop');}
    else{show('modal-btn-start');}
    fetch('/infrastructure/nas/docker/'+encodeURIComponent(name)+'/details')
      .then(function(r){return r.json().then(function(d){return {ok:r.ok,data:d};});})
      .then(function(res){
        if(!res.ok||res.data.error){
          var msg=res.data&&res.data.error?res.data.error:'Erreur de chargement';
          html('modal-infos-spinner','<div class="text-warning small py-3 text-center">'+esc(msg)+'<br><span class="text-muted" style="font-size:.78rem">Vérifiez NAS_DOCKER_PROXY_URL dans .env.local</span></div>');
          html('modal-stats-spinner','<div class="text-muted small text-center py-3">Données indisponibles</div>');
          hide('modal-logs-spinner');
          return;
        }
        populateInfos(res.data);populateStats(res.data);
      })
      .catch(function(){html('modal-infos-spinner','<div class="text-danger small">Erreur réseau</div>');html('modal-stats-spinner','<div class="text-danger small">Erreur réseau</div>');});
  }

  function openModal(name, csrfToken, isSystem) {
    _current={name:name,csrfToken:csrfToken,isSystem:isSystem==='1'};
    _resetModal(name);
    if(!_current.isSystem){show('modal-btn-restart');show('modal-btn-stop');}
    fetch('/container/'+encodeURIComponent(name)+'/details')
      .then(function(r){return r.json();})
      .then(function(d){populateInfos(d);populateStats(d);})
      .catch(function(){html('modal-infos-spinner','<div class="text-danger small">Erreur de chargement</div>');html('modal-stats-spinner','<div class="text-danger small">Erreur de chargement</div>');});
  }

  function doAction(action) {
    if(!_current) return;
    var url, body;
    if(_current.source==='nas') {
      var nasGrid=document.getElementById('nas-docker-grid');
      var csrfToken=nasGrid?nasGrid.dataset.nasCsrf:'';
      url='/infrastructure/nas/docker/'+encodeURIComponent(_current.name)+'/action';
      body=new URLSearchParams({_token:csrfToken,action:action});
    } else {
      if(_current.isSystem) return;
      url='/container/'+encodeURIComponent(_current.name)+'/action';
      body=new URLSearchParams({_token:_current.csrfToken,action:action});
    }

    // Feedback visuel immédiat : désactive tous les boutons, remplace l'icône du bouton actif par un spinner
    var btnIds=['modal-btn-restart','modal-btn-stop','modal-btn-start'];
    var btnActiveId='modal-btn-'+action;
    var saved={};
    btnIds.forEach(function(id){var b=document.getElementById(id);if(!b)return;saved[id]=b.innerHTML;b.disabled=true;});
    var active=document.getElementById(btnActiveId);
    if(active){
      var label={restart:'Restart…',stop:'Arrêt…',start:'Démarrage…'}[action]||'…';
      active.innerHTML='<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>'+label;
    }

    function restoreButtons(){
      btnIds.forEach(function(id){var b=document.getElementById(id);if(!b)return;if(saved[id]!==undefined)b.innerHTML=saved[id];b.disabled=false;});
    }

    fetch(url,{method:'POST',credentials:'same-origin',body:body})
      .then(function(r){return r.json();})
      .then(function(d){
        if(d.success){
          // Optimistic update de la card d'origine
          var card=_current.source==='nas'
            ?document.querySelector('[data-nas-name="'+_current.name+'"]')
            :document.querySelector('[data-container="'+_current.name+'"]');
          if(card) optimisticUpdate(card,action);
          if(window._argosToast) window._argosToast('Container '+action+' : OK','success');
          var cb=document.querySelector('#container-modal [data-bs-dismiss="modal"]');
          if(cb)cb.click();
          if(_current&&_current.source==='nas') setTimeout(reloadNasGrid, 1500);
        } else {
          if(window._argosToast) window._argosToast('Échec de l\'action '+action,'danger');
          restoreButtons();
        }
      })
      .catch(function(){
        if(window._argosToast) window._argosToast('Erreur réseau pendant l\'action '+action,'danger');
        restoreButtons();
      });
  }

  // Feedback visuel immédiat après stop/start sans attendre le SSE
  function optimisticUpdate(card, action) {
    if (action === 'restart') return; // pas de feedback optimiste pour restart
    var stopped = (action === 'stop');
    var color   = stopped ? 'danger' : 'success';
    var label   = stopped ? 'exited' : 'running';
    var topBar  = card.querySelector('.card-status-top');
    if (topBar) topBar.className = 'card-status-top bg-'+color;
    var dot = card.querySelector('.status-dot');
    if (dot) {
      dot.classList.remove('bg-success','bg-danger','bg-warning','bg-secondary','status-dot-animated');
      dot.classList.add('bg-'+color);
      if (!stopped) dot.classList.add('status-dot-animated');
    }
    var badge = card.querySelector('.badge');
    if (badge) { badge.className = 'badge bg-'+color+'-lt'; badge.textContent = label; }
    // Met à jour l'attribut pour que le SSE ne déclenchent pas de rechargement inutile
    if ('status' in card.dataset)    card.dataset.status    = stopped ? 'down' : 'up';
    if ('nasStatus' in card.dataset) card.dataset.nasStatus = stopped ? 'down' : 'up';
  }

  if(!window._argosDockerModalListeners) {
    window._argosDockerModalListeners = true;

    document.addEventListener('click', function(e) {
      var intercepted=e.target.closest('button, a, form');
      var card=e.target.closest('[data-container][data-csrf-token]');
      if(intercepted) return;
      if(!card) return;
      e.preventDefault();
      openModal(card.dataset.container, card.dataset.csrfToken, card.dataset.system||'0');
    });

    document.addEventListener('click', function(e) {
      var intercepted=e.target.closest('button, a, form');
      var nasCard=e.target.closest('[data-nas-name][data-nas-status]');
      if(intercepted) return;
      if(!nasCard) return;
      e.preventDefault();
      openNasModal(nasCard.dataset.nasName, nasCard.dataset.nasStatus);
    });

    document.addEventListener('click', function(e) {
      var btn=e.target.closest('[data-nas-action]');
      if(!btn) return;
      var card=btn.closest('[data-nas-name]');
      if(!card) return;
      e.stopPropagation();
      btn.disabled=true;
      var nasGrid=document.getElementById('nas-docker-grid');
      var csrfToken=nasGrid?nasGrid.dataset.nasCsrf:'';
      fetch('/infrastructure/nas/docker/'+encodeURIComponent(card.dataset.nasName)+'/action',{
        method:'POST',credentials:'same-origin',
        body:new URLSearchParams({_token:csrfToken,action:btn.dataset.nasAction})
      })
      .then(function(r){return r.json().then(function(d){if(d.success)optimisticUpdate(card,btn.dataset.nasAction);});})
      .catch(function(){})
      .finally(function(){btn.disabled=false;});
    });

    document.addEventListener('click', function(e) {
      if(!e.target.closest('#modal-tab-logs')) return;
      if(_logsInterval||!_current) return;
      function fetchLogs() {
        if(!_current) return;
        var logsUrl=_current.source==='nas'
          ?'/infrastructure/nas/docker/'+encodeURIComponent(_current.name)+'/logs'
          :'/container/'+encodeURIComponent(_current.name)+'/logs';
        fetch(logsUrl)
          .then(function(r){return r.json();})
          .then(function(d){
            var pre=document.getElementById('modal-logs-pre');
            if(!pre) return;
            var atBottom=pre.scrollHeight-pre.scrollTop-pre.clientHeight<60;
            pre.textContent=d.logs||'(aucun log disponible)';
            if(atBottom) pre.scrollTop=pre.scrollHeight;
            hide('modal-logs-spinner'); show('modal-logs-content');
          })
          .catch(function(){html('modal-logs-spinner','<div class="text-danger small">Erreur de chargement des logs</div>');});
      }
      fetchLogs();
      _logsInterval=setInterval(fetchLogs,3000);
    });

    document.addEventListener('click', function(e) {
      var btn=e.target.closest('#modal-btn-restart, #modal-btn-stop, #modal-btn-start');
      if(!btn) return;
      if(btn.id==='modal-btn-restart') doAction('restart');
      else if(btn.id==='modal-btn-stop') doAction('stop');
      else if(btn.id==='modal-btn-start') doAction('start');
    });

    document.addEventListener('click', function(e) {
      var btn=e.target.closest('[data-card-action]');
      if(!btn) return;
      var card=btn.closest('[data-container][data-csrf-token]');
      if(!card) return;
      btn.disabled=true;
      fetch('/container/'+encodeURIComponent(card.dataset.container)+'/action',{method:'POST',body:new URLSearchParams({_token:card.dataset.csrfToken,action:btn.dataset.cardAction})})
        .then(function(r){return r.json().then(function(d){if(d.success)optimisticUpdate(card,btn.dataset.cardAction);});})
        .catch(function(){}).finally(function(){btn.disabled=false;});
    });

    document.addEventListener('hidden.bs.modal', function(e) {
      if(e.target&&e.target.id==='container-modal'){_current=null;if(_logsInterval){clearInterval(_logsInterval);_logsInterval=null;}}
    });
  }
})();
</script>
{% endblock %}
