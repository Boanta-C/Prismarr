        <div class="d-flex align-items-center gap-2 overflow-hidden">
          <span id="modal-status-dot" class="status-dot bg-secondary flex-shrink-0"></span>
          <h5 class="modal-title mb-0 text-truncate" id="modal-container-name">—</h5>
          <span id="modal-container-badge" class="badge bg-secondary-lt ms-1 flex-shrink-0"></span>
