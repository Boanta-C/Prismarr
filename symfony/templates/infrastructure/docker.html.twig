        <div class="tab-content">
          <div class="tab-pane show active" id="modal-pane-infos">
            <div id="modal-infos-spinner" class="text-center py-4"><div class="spinner-border spinner-border-sm text-secondary"></div></div>
            <div id="modal-infos-content" class="d-none"></div>
