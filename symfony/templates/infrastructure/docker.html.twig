          <div class="tab-pane" id="modal-pane-stats">
            <div id="modal-stats-spinner" class="text-center py-4"><div class="spinner-border spinner-border-sm text-secondary"></div></div>
            <div id="modal-stats-content" class="d-none"></div>
          </div>
          <div class="tab-pane" id="modal-pane-logs">
            <div id="modal-logs-spinner" class="text-center py-4">
              <div class="spinner-border spinner-border-sm text-secondary"></div>
              <div class="text-secondary small mt-2">Chargement des logs…</div>
            </div>
            <div id="modal-logs-content" class="d-none">
              <pre id="modal-logs-pre" class="rounded p-3 small mb-0"
                   style="background:#1a1a2e;color:#e2e8f0;max-height:50vh;overflow-y:auto;white-space:pre-wrap;word-break:break-all;font-size:.70rem;line-height:1.5"></pre>
            </div>
