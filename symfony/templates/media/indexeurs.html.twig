{% extends 'base.html.twig' %}
{% block title %}{{ 'media.indexeurs.page_title'|trans }}{% endblock %}

{% block body %}
<div class="page-header mb-3">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title">{{ 'media.indexeurs.page_title'|trans }} <span class="badge bg-secondary ms-1">{{ stats.total ?? 0 }}</span></h2>
    </div>
  </div>
</div>

{% if error %}
  <div class="alert alert-warning">{{ 'media.indexeurs.error_unreachable'|trans }}</div>
{% endif %}

{# ── Stats ── #}
<div class="row g-3 mb-3">
  <div class="col-6 col-lg-3">
    <div class="card card-sm">
      <div class="card-body">
        <div class="d-flex align-items-center gap-2">
          <span class="text-body fs-2 fw-bold">{{ stats.total ?? 0 }}</span>
          <div class="text-muted small">{{ 'media.indexeurs.stats.total'|trans }}</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card card-sm">
      <div class="card-body">
        <div class="d-flex align-items-center gap-2">
          <span class="text-success fs-2 fw-bold">{{ stats.enabled ?? 0 }}</span>
          <div class="text-muted small">{{ 'media.indexeurs.stats.enabled'|trans }}</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card card-sm">
      <div class="card-body">
        <div class="d-flex align-items-center gap-2">
          <span class="text-primary fs-2 fw-bold">{{ stats.torrent ?? 0 }}</span>
          <div class="text-muted small">{{ 'media.indexeurs.stats.torrent'|trans }}</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card card-sm">
      <div class="card-body">
        <div class="d-flex align-items-center gap-2">
          <span class="text-info fs-2 fw-bold">{{ stats.usenet ?? 0 }}</span>
          <div class="text-muted small">{{ 'media.indexeurs.stats.usenet'|trans }}</div>
        </div>
      </div>
    </div>
  </div>
</div>

{# ── Indexer list ── #}
<div class="card mb-3">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.indexeurs.configured'|trans }}</h3>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table table-hover">
      <thead>
        <tr>
          <th>{{ 'media.indexeurs.table.name'|trans }}</th>
          <th>{{ 'media.indexeurs.table.type'|trans }}</th>
          <th>{{ 'media.indexeurs.table.priority'|trans }}</th>
          <th>{{ 'media.indexeurs.table.status'|trans }}</th>
          <th>{{ 'media.indexeurs.table.health'|trans }}</th>
        </tr>
      </thead>
      <tbody>
        {% if indexers is empty %}
          <tr><td colspan="5" class="text-center text-muted py-3">{{ 'media.indexeurs.empty'|trans }}</td></tr>
        {% else %}
          {% for idx in indexers %}
            {% set hasError = status[idx.id] is defined %}
            <tr>
              <td class="fw-medium">{{ idx.name }}</td>
              <td>
                {% if idx.type == 'torrent' %}
                  <span class="badge bg-primary-lt">{{ 'media.indexeurs.badge.torrent'|trans }}</span>
                {% elseif idx.type == 'usenet' %}
                  <span class="badge bg-info-lt">{{ 'media.indexeurs.badge.usenet'|trans }}</span>
                {% else %}
                  <span class="badge bg-secondary-lt">{{ idx.type }}</span>
                {% endif %}
              </td>
              <td class="text-muted">{{ idx.priority }}</td>
              <td>
                {% if idx.enabled %}
                  <span class="badge bg-success-lt">{{ 'media.indexeurs.badge.enabled'|trans }}</span>
                {% else %}
                  <span class="badge bg-secondary-lt">{{ 'media.indexeurs.badge.disabled'|trans }}</span>
                {% endif %}
              </td>
              <td>
                {% if not idx.enabled %}
                  <span class="text-muted small">—</span>
                {% elseif hasError %}
                  <span class="text-danger small d-flex align-items-center gap-1">
                    <span class="status-dot bg-danger"></span> {{ 'media.indexeurs.health.error'|trans }}
                  </span>
                {% else %}
                  <span class="text-success small d-flex align-items-center gap-1">
                    <span class="status-dot status-dot-animated bg-success"></span> {{ 'media.indexeurs.health.ok'|trans }}
                  </span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        {% endif %}
      </tbody>
    </table>
  </div>
</div>

{# ── Search history ── #}
{% if searches is not empty %}
<div class="card">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.indexeurs.searches.title'|trans }}</h3>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead>
        <tr>
          <th>{{ 'media.indexeurs.searches.date'|trans }}</th>
          <th>{{ 'media.indexeurs.searches.indexer'|trans }}</th>
          <th>{{ 'media.indexeurs.searches.query'|trans }}</th>
          <th>{{ 'media.indexeurs.searches.result'|trans }}</th>
        </tr>
      </thead>
      <tbody>
        {% for s in searches %}
          <tr>
            <td class="text-muted small text-nowrap">
              {{ s.date ? s.date|date('d/m H:i') : '—' }}
            </td>
            <td class="small">{{ s.indexer }}</td>
            <td class="small text-truncate" style="max-width:300px;" title="{{ s.query }}">{{ s.query }}</td>
            <td>
              {% if s.successful %}
                <span class="badge bg-success-lt">{{ 'media.indexeurs.searches.results_tpl'|trans({count: s.grabCount}) }}</span>
              {% else %}
                <span class="badge bg-danger-lt">{{ 'media.indexeurs.searches.failed'|trans }}</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}

{% endblock %}
