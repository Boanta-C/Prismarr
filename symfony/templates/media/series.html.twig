    if (!card) return;
    e.preventDefault(); e.stopPropagation();
    var cards = visibleCards();
    var idx = cards.indexOf(card);
    if (e.shiftKey && lastSelectedIdx >= 0 && idx >= 0) {
      var from = Math.min(lastSelectedIdx, idx), to = Math.max(lastSelectedIdx, idx);
      for (var i = from; i <= to; i++) toggleSelect(cards[i], true);
    } else {
      toggleSelect(card); lastSelectedIdx = idx;
    }
