  function toggleSelect(card, force) {
    var id = card.dataset.id;
    var cb = card.querySelector('.select-cb');
    var selected = force !== undefined ? force : !selectedSeriesIds.has(id);
    if (selected) { selectedSeriesIds.add(id); card.classList.add('selected'); cb.classList.add('checked'); }
    else { selectedSeriesIds.delete(id); card.classList.remove('selected'); cb.classList.remove('checked'); }
