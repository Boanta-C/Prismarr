  document.getElementById('series-table-tbody').addEventListener('click', function(e) {
    var row = e.target.closest('.series-table-row');
    if (!row) return;
    var id = row.dataset.id;
    if (selectMode) {
      var card = grid.querySelector('.media-card[data-id="' + id + '"]');
      if (card) toggleSelect(card);
      syncSeriesTableSelection();
      return;
