    grid.querySelectorAll('.media-card').forEach(function(c) { c.classList.remove('selected'); c.querySelector('.select-cb').classList.remove('checked'); });
    // Clear tableau
    document.querySelectorAll('.select-cb-table-s').forEach(function(cb) { cb.style.background = 'rgba(0,0,0,.3)'; cb.style.borderColor = 'rgba(255,255,255,.4)'; cb.closest('tr').style.background = ''; });
