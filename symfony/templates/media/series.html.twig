  // Bulk Delete
  document.getElementById('bulk-btn-delete-series').addEventListener('click', function() {
    if (!selectedSeriesIds.size) return;
    document.getElementById('bulk-s-delete-count').textContent = selectedSeriesIds.size;
    document.getElementById('bulk-s-delete-files').checked = false;
    document.getElementById('bulk-s-delete-exclude').checked = false;
