{% block javascripts %}
<script>
(function () {
  var grid    = document.getElementById('series-grid');
  var visibleCards = function() { return Array.from(grid.querySelectorAll('.media-card')).filter(function(c) { return getComputedStyle(c).display !== 'none'; }); };
  var search  = document.getElementById('search-input');
  var btnAll  = document.querySelectorAll('.filter-btn');
  // counter removed
  var currentFilter = 'all';
  var currentSort = 'title-asc';

  // Populate genre & network dropdowns
  var genres = {}, networks = {};
  grid.querySelectorAll('.media-card').forEach(function(c) {
    (c.dataset.genres || '').split(', ').forEach(function(g) { if (g) genres[g] = true; });
    var net = c.dataset.network || '';
    if (net) networks[net] = true;
  });
  var genreSel = document.getElementById('filter-genre');
  Object.keys(genres).sort().forEach(function(g) {
    var o = document.createElement('option'); o.value = g; o.textContent = g; genreSel.appendChild(o);
  });
  var netSel = document.getElementById('filter-network');
  Object.keys(networks).sort().forEach(function(n) {
    var o = document.createElement('option'); o.value = n; o.textContent = n; netSel.appendChild(o);
  });

  function applyFilters() {
    var q = search.value.toLowerCase().trim();
    var genre = genreSel.value;
    var network = netSel.value;
    var cards = Array.from(grid.querySelectorAll('.media-card'));
    var visible = 0;

    // Sort
    var sorted = cards.slice();
    sorted.sort(function(a, b) {
      switch (currentSort) {
        case 'title-asc': return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        case 'title-desc': return (b.dataset.title || '').localeCompare(a.dataset.title || '');
        case 'year-desc': return (parseInt(b.dataset.year) || 0) - (parseInt(a.dataset.year) || 0);
        case 'year-asc': return (parseInt(a.dataset.year) || 0) - (parseInt(b.dataset.year) || 0);
        case 'size-desc': return (parseFloat(b.dataset.size) || 0) - (parseFloat(a.dataset.size) || 0);
        case 'percent-desc': return (parseInt(b.dataset.percent) || 0) - (parseInt(a.dataset.percent) || 0);
        case 'percent-asc': return (parseInt(a.dataset.percent) || 0) - (parseInt(b.dataset.percent) || 0);
        default: return 0;
      }
    });
    sorted.forEach(function(c) { grid.appendChild(c); });

    // Filter
    sorted.forEach(function (c) {
      var title  = c.dataset.title || '';
      var status = c.dataset.status || '';
      var type   = c.dataset.type || '';
      var mon    = c.dataset.monitored;

      var matchSearch = !q || title.includes(q);
      var percent = parseInt(c.dataset.percent) || 0;
      var epCount = parseInt(c.dataset.episodeCount) || 0;
      var matchFilter = currentFilter === 'all'
        || (currentFilter === 'continuing' && status === 'continuing')
        || (currentFilter === 'ended'      && status === 'ended')
        || (currentFilter === 'anime'      && type === 'anime')
        || (currentFilter === 'unmonitored' && mon === '0')
        || (currentFilter === 'missing'    && mon === '1' && percent < 100 && epCount > 0);
      var matchGenre = !genre || (c.dataset.genres || '').indexOf(genre) !== -1;
      var matchNetwork = !network || (c.dataset.network || '') === network;

      var show = matchSearch && matchFilter && matchGenre && matchNetwork;
      if (show) {
        c.style.display = '';
        c.style.removeProperty('display');
        visible++;
      } else {
        c.style.setProperty('display', 'none', 'important');
      }
    });

    // Filtrer aussi les lignes du tableau
    document.querySelectorAll('.series-table-row').forEach(function(row) {
      var rTitle = row.dataset.title || '';
      var rStatus = row.dataset.status || '';
      var rType = row.dataset.type || '';
      var rMon = row.dataset.monitored;
      var rPercent = parseInt(row.dataset.percent) || 0;
      var rEpCount = parseInt(row.dataset.episodeCount) || 0;
      var rGenres = row.dataset.genres || '';
      var rNetwork = row.dataset.network || '';

      var rMatchSearch = !q || rTitle.includes(q);
      var rMatchFilter = currentFilter === 'all'
        || (currentFilter === 'continuing' && rStatus === 'continuing')
        || (currentFilter === 'ended' && rStatus === 'ended')
        || (currentFilter === 'anime' && rType === 'anime')
        || (currentFilter === 'unmonitored' && rMon === '0')
        || (currentFilter === 'missing' && rMon === '1' && rPercent < 100 && rEpCount > 0);
      var rMatchGenre = !genre || rGenres.indexOf(genre) !== -1;
      var rMatchNetwork = !network || rNetwork === network;
      row.style.display = (rMatchSearch && rMatchFilter && rMatchGenre && rMatchNetwork) ? '' : 'none';
    });

    // Afficher les boutons filtrés si un filtre est actif
    var hasFilter = currentFilter !== 'all' || q || genre || network;
    document.getElementById('btn-update-filtered-series').style.display = hasFilter ? '' : 'none';
    document.getElementById('btn-search-filtered-series').style.display = hasFilter ? '' : 'none';

    // Rebuild étagères si visible
    if (shelfView.style.display === 'block') { shelfBuilt = false; buildShelfView(); }
  }

  search.addEventListener('input', applyFilters);
  genreSel.addEventListener('change', applyFilters);
  netSel.addEventListener('change', applyFilters);
  document.getElementById('sort-select').addEventListener('change', function() {
    currentSort = this.value;
    applyFilters();
  });

  btnAll.forEach(function (btn) {
    btn.addEventListener('click', function () {
      btnAll.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentFilter = btn.dataset.filter;
      applyFilters();
    });
  });

  // View mode switch + persist
  var tableView = document.getElementById('series-table-view');
  var shelfView = document.getElementById('series-shelf-view');
  var shelfBuilt = false;

  function buildShelfView() {
    if (shelfBuilt) return;
    shelfBuilt = true;
    var q = search.value.toLowerCase().trim();
    var genre = genreSel.value;
    var network = netSel.value;
    var cards = Array.from(grid.querySelectorAll('.media-card')).filter(function(c) {
      var title = c.dataset.title || '';
      var status = c.dataset.status || '';
      var type = c.dataset.type || '';
      var mon = c.dataset.monitored;
      var percent = parseInt(c.dataset.percent) || 0;
      var epCount = parseInt(c.dataset.episodeCount) || 0;
      var matchSearch = !q || title.includes(q);
      var matchFilter = currentFilter === 'all'
        || (currentFilter === 'continuing' && status === 'continuing')
        || (currentFilter === 'ended' && status === 'ended')
        || (currentFilter === 'anime' && type === 'anime')
        || (currentFilter === 'unmonitored' && mon === '0')
        || (currentFilter === 'missing' && mon === '1' && percent < 100 && epCount > 0);
      var matchGenre = !genre || (c.dataset.genres || '').indexOf(genre) !== -1;
      var matchNetwork = !network || (c.dataset.network || '') === network;
      return matchSearch && matchFilter && matchGenre && matchNetwork;
    });
    var groups = {
      'continuing': { label: '📺 En cours', items: [] },
      'ended': { label: '✅ Terminées', items: [] },
      'upcoming': { label: '🔮 À venir', items: [] },
      'anime': { label: '🌸 Animés', items: [] },
      'unmonitored': { label: '👁 Non suivies', items: [] }
    };
    cards.forEach(function(c) {
      var s = c.dataset;
      var item = { id: s.id, title: s.displayTitle || '', poster: s.poster || '', percent: parseInt(s.percent) || 0, status: s.status, type: s.type, monitored: s.monitored };
      if (s.type === 'anime') groups.anime.items.push(item);
      if (s.monitored === '0') { groups.unmonitored.items.push(item); return; }
      if (s.status === 'continuing') groups.continuing.items.push(item);
      else if (s.status === 'ended') groups.ended.items.push(item);
      else if (s.status === 'upcoming') groups.upcoming.items.push(item);
    });
    var html = '';
    ['continuing','anime','ended','upcoming','unmonitored'].forEach(function(key) {
      var g = groups[key];
      if (!g.items.length) return;
      html += '<div class="shelf-section"><h4>' + g.label + ' <span class="text-muted fw-normal" style="font-size:.75rem;">(' + g.items.length + ')</span></h4>';
      html += '<div class="shelf-scroll">';
      g.items.forEach(function(item) {
        var barColor = item.percent === 100 ? '#22c55e' : (item.percent > 0 ? '#ef4444' : '#6b7280');
        if (item.status === 'continuing' && item.percent === 100) barColor = '#38bdf8';
        html += '<div class="shelf-card" data-id="' + item.id + '">';
        html += item.poster ? '<img src="' + item.poster + '" alt="" loading="lazy">' : '<div style="width:100%;aspect-ratio:2/3;background:var(--tblr-bg-surface-secondary);"></div>';
        html += '<div class="shelf-title">' + item.title + '</div>';
        html += '<div class="shelf-bar" style="background:' + barColor + ';"></div>';
        html += '</div>';
      });
      html += '</div></div>';
    });
    shelfView.innerHTML = html;
    // Click handler
    shelfView.addEventListener('click', function(e) {
      var sc = e.target.closest('.shelf-card');
      if (!sc) return;
      var id = sc.dataset.id;
      if (selectMode) {
        var card = grid.querySelector('.media-card[data-id="' + id + '"]');
        if (card) toggleSelect(card);
        sc.style.outline = selectedSeriesIds.has(id) ? '2px solid var(--tblr-primary)' : 'none';
        return;
      }
      var card = grid.querySelector('.media-card[data-id="' + id + '"]');
      if (card) card.click();
    });
  }

  function setViewMode(mode) {
    grid.classList.remove('view-table', 'view-extended', 'view-compact', 'view-wall');
    grid.style.display = '';
    tableView.classList.remove('active');
    shelfView.style.display = 'none';
    if (mode === 'table') {
      grid.style.display = 'none';
      tableView.classList.add('active');
    } else if (mode === 'shelf') {
      grid.style.display = 'none';
      buildShelfView();
      shelfView.style.display = 'block';
    } else if (mode !== 'grid') {
      grid.classList.add('view-' + mode);
    }
    document.querySelectorAll('.view-btn').forEach(function(b) {
      b.classList.remove('active', 'btn-secondary');
      b.classList.add('btn-ghost-secondary');
      if (b.dataset.view === mode) { b.classList.add('active', 'btn-secondary'); b.classList.remove('btn-ghost-secondary'); }
    });
    try { localStorage.setItem('prismarr_series_view', mode); } catch(e) {}
    applyFilters();
  }
  // Restore saved view
  var savedView = 'grid';
  try { savedView = localStorage.getItem('prismarr_series_view') || 'grid'; } catch(e) {}
  if (savedView !== 'grid') setViewMode(savedView);

  document.querySelectorAll('.view-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { setViewMode(btn.dataset.view); });
