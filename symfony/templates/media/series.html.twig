  // ── Calendrier déroulant ──────────────────────────────────────────────────
  var calToggle = document.getElementById('calendar-toggle');
  var calBody = document.getElementById('calendar-body');
  var calChev = document.getElementById('cal-chevron');
  if (calToggle) {
    calToggle.addEventListener('click', function() {
      var open = calBody.style.display !== 'none';
      calBody.style.display = open ? 'none' : '';
      calChev.style.transform = open ? '' : 'rotate(90deg)';
    });
