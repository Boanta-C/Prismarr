  // ── Helpers modals bulk ──
  var bulkConfigLoaded = false;
  function openBulkModal(id) {
    var m = document.getElementById(id);
    m.classList.add('show'); m.style.display = 'block';
    document.body.classList.add('modal-open');
    var bd = document.createElement('div'); bd.className = 'modal-backdrop fade show'; bd.id = 'bulk-backdrop';
    document.body.appendChild(bd);
  }
  function closeBulkModal(id) {
    var m = document.getElementById(id);
    m.classList.remove('show'); m.style.display = 'none';
    document.body.classList.remove('modal-open');
    var bd = document.getElementById('bulk-backdrop'); if (bd) bd.remove();
  }
  document.querySelectorAll('#modal-bulk-edit-series [data-bs-dismiss="modal"], #modal-bulk-tags-series [data-bs-dismiss="modal"], #modal-bulk-delete-series [data-bs-dismiss="modal"], #modal-bulk-rename-series [data-bs-dismiss="modal"]').forEach(function(btn) {
    btn.addEventListener('click', function() { closeBulkModal(btn.closest('.modal').id); });
  });
  function ensureBulkConfig(cb) {
    if (bulkConfigLoaded) { cb(); return; }
    Promise.all([ajaxGet('/medias/sonarr/quality-profiles'), ajaxGet('/medias/sonarr/root-folders'), ajaxGet('/medias/sonarr/tags')]).then(function(r) {
      bulkConfigLoaded = true;
      var qSel = document.getElementById('bulk-s-quality');
      if (qSel.options.length <= 1) (r[0]||[]).forEach(function(p) { var o = document.createElement('option'); o.value = p.id; o.textContent = p.name; qSel.appendChild(o); });
      var rSel = document.getElementById('bulk-s-root');
      if (rSel.options.length <= 1) (r[1]||[]).forEach(function(f) { var o = document.createElement('option'); o.value = f.path; o.textContent = f.path; rSel.appendChild(o); });
      var tList = document.getElementById('bulk-s-tags-list');
      if (!tList.children.length) (r[2]||[]).forEach(function(t) {
        var d = document.createElement('div'); d.className = 'form-check';
        d.innerHTML = '<input class="form-check-input bulk-s-tag-cb" type="checkbox" value="' + t.id + '" id="bulk-s-tag-' + t.id + '"><label class="form-check-label small" for="bulk-s-tag-' + t.id + '">' + esc(t.label) + '</label>';
        tList.appendChild(d);
      });
      cb();
    });
  }
  function getSelectedNames() {
    var names = [];
    selectedSeriesIds.forEach(function(id) { var c = grid.querySelector('[data-id="' + id + '"]'); if (c) names.push(c.getAttribute('title') || '?'); });
    return names;
  }

  // Bulk Edit
  document.getElementById('bulk-btn-edit-series').addEventListener('click', function() {
    if (!selectedSeriesIds.size) return;
    ensureBulkConfig(function() {
      document.getElementById('bulk-s-monitored').value = '';
      document.getElementById('bulk-s-quality').value = '';
      document.getElementById('bulk-s-type').value = '';
      document.getElementById('bulk-s-root').value = '';
      document.getElementById('bulk-s-season-folder').value = '';
      document.getElementById('bulk-s-edit-info').textContent = selectedSeriesIds.size + ' série(s) sélectionnée(s)';
      openBulkModal('modal-bulk-edit-series');
    });
  });
  document.getElementById('bulk-s-edit-save').addEventListener('click', function() {
    var ids = Array.from(selectedSeriesIds).map(Number);
    var payload = { seriesIds: ids };
    var v;
    v = document.getElementById('bulk-s-monitored').value; if (v) payload.monitored = v === 'true';
    v = document.getElementById('bulk-s-quality').value; if (v) payload.qualityProfileId = parseInt(v);
    v = document.getElementById('bulk-s-type').value; if (v) payload.seriesType = v;
    v = document.getElementById('bulk-s-root').value; if (v) payload.rootFolderPath = v;
    v = document.getElementById('bulk-s-season-folder').value; if (v) payload.seasonFolder = v === 'true';
    var btn = this; btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    ajaxPost('/medias/series/bulk/edit', payload).then(function(d) {
      btn.disabled = false; btn.innerHTML = 'Sauvegarder';
      closeBulkModal('modal-bulk-edit-series');
      if (d.ok) { showPageBanner('✅ ' + ids.length + ' série(s) modifiée(s).', 'success'); setTimeout(function() { location.reload(); }, 1500); }
      else showPageBanner('❌ Erreur.', 'danger');
