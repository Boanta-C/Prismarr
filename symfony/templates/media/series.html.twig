            }
            var eventLabels = {1:'Téléchargé',2:'Importé',3:'Renommé',4:'Supprimé',6:'Ignoré',7:'Échoué',8:'Téléchargé',9:'Ignoré'};
            var eventColors = {1:'success',2:'primary',3:'secondary',4:'danger',6:'warning',7:'danger',8:'success',9:'warning'};
            var html = '<div class="table-responsive" style="max-height:calc(100% - 1rem);overflow-y:auto"><table class="table table-sm table-vcenter table-hover mb-0" style="font-size:.78rem"><thead class="sticky-top" style="background:var(--tblr-bg-surface)"><tr><th>Épisode</th><th>Action</th><th>Source</th><th>Qualité</th><th>Date</th></tr></thead><tbody>';
            seasonHist.slice(0, 50).forEach(function(h) {
              var epNum = h.episode ? 'E' + String(h.episode.episodeNumber || 0).padStart(2,'0') : '?';
              var action = eventLabels[h.eventType] || h.eventType || '?';
              var color = eventColors[h.eventType] || 'secondary';
              var quality = (h.quality && h.quality.quality) ? h.quality.quality.name : '—';
              var date = h.date ? h.date.substring(0, 10) : '—';
              html += '<tr><td class="fw-medium">' + epNum + '</td><td><span class="badge bg-' + color + '-lt">' + action + '</span></td><td class="text-muted text-truncate" style="max-width:250px;" title="' + esc(h.sourceTitle || '') + '">' + esc(h.sourceTitle || '—') + '</td><td><span class="badge bg-blue-lt">' + quality + '</span></td><td class="text-muted">' + date + '</td></tr>';
            });
            html += '</tbody></table></div>';
            content.innerHTML = html;
