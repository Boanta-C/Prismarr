  /* ══════════════════════════════════════════════════════════════════════════
     Mode sélection + actions bulk séries
     ══════════════════════════════════════════════════════════════════════════ */
  var selectMode = false;
  var selectedSeriesIds = new Set();
  var lastSelectedIdx = -1;
  var bulkBar = document.getElementById('bulk-bar-series');
