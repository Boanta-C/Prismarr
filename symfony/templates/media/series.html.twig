  // Bulk Rename
  var renameSeriesIds = [];
  document.getElementById('bulk-btn-rename-series').addEventListener('click', function() {
    if (!selectedSeriesIds.size) return;
    openBulkModal('modal-bulk-rename-series');
    var loading = document.getElementById('bulk-s-rename-loading');
    var okDiv = document.getElementById('bulk-s-rename-ok');
    var changes = document.getElementById('bulk-s-rename-changes');
    var goBtn = document.getElementById('bulk-s-rename-go');
    loading.style.display = '';
    okDiv.style.display = 'none';
    changes.innerHTML = '';
    goBtn.disabled = true;
    goBtn.textContent = 'Organiser';
    renameSeriesIds = [];

    var ids = Array.from(selectedSeriesIds).map(Number);
    var loaded = 0;
    var totalChanges = 0;
    var totalOk = 0;
    var html = '';

    ids.forEach(function(sid) {
      var card = grid.querySelector('[data-id="' + sid + '"]');
      var title = card ? (card.getAttribute('title') || '?') : '?';
      ajaxGet('/medias/series/' + sid + '/rename').then(function(proposals) {
        loaded++;
        if (proposals && proposals.length) {
          renameSeriesIds.push(sid);
          totalChanges += proposals.length;
          proposals.forEach(function(p) {
            var oldName = (p.existingPath || '').split('/').pop();
            var newName = (p.newPath || '').split('/').pop();
            html += '<div class="mb-2 p-2 rounded" style="background:rgba(0,0,0,.15);font-size:.78rem;">';
            html += '<div class="fw-medium mb-1">' + esc(title.split('—')[0].trim()) + '</div>';
            html += '<div class="text-danger small">✗ ' + esc(oldName) + '</div>';
            html += '<div class="text-success small">✓ ' + esc(newName) + '</div>';
            html += '</div>';
          });
        } else {
          totalOk++;
        }
        if (loaded >= ids.length) {
          loading.style.display = 'none';
          if (totalOk > 0) {
            okDiv.style.display = '';
            okDiv.textContent = '✅ ' + totalOk + ' série(s) déjà correctement nommée(s).';
          }
          if (html) changes.innerHTML = html;
          if (totalChanges > 0) {
            goBtn.disabled = false;
            goBtn.textContent = 'Organiser ' + totalChanges + ' fichier(s)';
          } else {
            goBtn.textContent = 'Tout est déjà correct';
          }
        }
      }).catch(function() { loaded++; });
    });
  });
  document.getElementById('bulk-s-rename-go').addEventListener('click', function() {
