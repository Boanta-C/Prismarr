      // Bind season rename
      epContainer.querySelectorAll('.btn-season-rename').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          var sn = parseInt(btn.dataset.season);
          var seriesId = btn.dataset.seriesId;
          btn.disabled = true;
          btn.innerHTML = SVG_SPIN_SM;

          openFileOverlay();
          var loading = document.getElementById('ep-filemanager-loading');
          var content = document.getElementById('ep-filemanager-content');
          loading.style.display = '';
          content.style.display = 'none';
          content.innerHTML = '';
          document.getElementById('ep-filemanager-feedback').style.display = 'none';

          ajaxGet('/medias/series/' + seriesId + '/rename').then(function(proposals) {
            btn.disabled = false;
            btn.innerHTML = RENAME_ICON;
            loading.style.display = 'none';

            // Filter proposals for this season
            var seasonProposals = proposals.filter(function(p) { return p.seasonNumber === sn; });

            if (!seasonProposals.length) {
              content.innerHTML = '<div class="p-3 text-success small"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M20 6 9 17l-5-5"/></svg> Tous les fichiers de la saison ' + sn + ' sont déjà correctement nommés.</div>';
              content.style.display = '';
              return;
            }

            var html = '<div class="p-3">';
            html += '<h5 class="mb-3" style="font-size:.9rem;">Renommage — Saison ' + sn + ' (' + seasonProposals.length + ' fichier(s))</h5>';
            html += '<div class="mb-3" style="max-height:300px;overflow-y:auto;">';
            seasonProposals.forEach(function(p) {
              var oldName = (p.existingPath || '').split('/').pop();
              var newName = (p.newPath || '').split('/').pop();
              html += '<div class="mb-2 p-2 rounded" style="background:rgba(0,0,0,.15);font-size:.78rem;">';
              html += '<div class="d-flex align-items-center gap-1 mb-1">';
              html += '<span class="badge bg-secondary-lt">E' + String(p.episodeNumbers ? p.episodeNumbers[0] : '?').padStart(2,'0') + '</span>';
              html += '</div>';
              html += '<div class="text-danger small" style="word-break:break-all;">✗ ' + esc(oldName) + '</div>';
              html += '<div class="text-success small" style="word-break:break-all;">✓ ' + esc(newName) + '</div>';
              html += '</div>';
            });
            html += '</div>';
            var fileIds = seasonProposals.map(function(p) { return p.episodeFileId; }).filter(Boolean);
            html += '<button class="btn btn-primary btn-sm" id="season-rename-go">Renommer ' + seasonProposals.length + ' fichier(s)</button>';
            html += '</div>';
            content.innerHTML = html;
            content.style.display = '';

            document.getElementById('season-rename-go').addEventListener('click', function() {
              var goBtn = this;
              goBtn.disabled = true;
              goBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Renommage...';
              ajaxPost('/medias/series/' + seriesId + '/rename', { fileIds: fileIds }).then(function(data) {
                if (data.ok && data.cmdId) {
                  var pollRename = setInterval(function() {
                    ajaxGet('/medias/series/command/' + data.cmdId).then(function(cmd) {
                      var st = (cmd.status || '').toLowerCase();
                      if (st === 'completed') {
                        clearInterval(pollRename);
                        goBtn.innerHTML = '✅ Renommé';
                        setTimeout(function() { closeFileOverlay(); loadEpisodes(); }, 1500);
                      } else if (st === 'failed') {
                        clearInterval(pollRename);
                        goBtn.disabled = false;
                        goBtn.innerHTML = 'Renommer';
                        showBanner('Échec du renommage.', 'danger');
                      }
                    });
                  }, 1500);
                } else {
                  goBtn.disabled = false;
                  goBtn.innerHTML = 'Renommer';
                }
              });
            });
          }).catch(function() {
            btn.disabled = false;
            btn.innerHTML = RENAME_ICON;
            loading.innerHTML = '<span class="text-danger">Erreur chargement propositions.</span>';
          });
        });
      });

      // Bind episode file delete
      epContainer.querySelectorAll('.btn-ep-file-del').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          if (!confirm('Supprimer ce fichier du disque ?\n\nCette action est irréversible.')) return;
          btn.disabled = true;
          btn.innerHTML = SVG_SPIN_SM;
          postAction('/medias/series/file/' + btn.dataset.fileId + '/delete', {}, function() {
            showBanner('Fichier supprimé.', 'success');
            setTimeout(function() { hideBanner(); loadEpisodes(); }, 1500);
          }, function() {
            btn.disabled = false;
            btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
          });
        });
      });
    });
  }

  function postAction(url, body, successCb, errorCb) {
    fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify(body),
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.ok) { if (successCb) successCb(data); }
      else { if (errorCb) errorCb(data); else showBanner(data.error || 'Erreur.', 'danger'); }
    })
    .catch(function () { showBanner('Erreur réseau.', 'danger'); });
  }

  var bannerEl = document.getElementById('modal-serie-banner');
  function showBanner(html, type) {
    bannerEl.className = 'alert alert-' + (type || 'info') + ' mb-2 py-2';
    bannerEl.style.fontSize = '.82rem';
    bannerEl.innerHTML = html;
    bannerEl.classList.remove('d-none');
  }
  function hideBanner() { bannerEl.classList.add('d-none'); }

  var bannerLocked = false;
  var pageBannerSeriesId = null;

  function showPageBanner(msg, type, seriesId) {
    bannerLocked = true;
    if (seriesId) pageBannerSeriesId = seriesId;
    var el = document.getElementById('sonarr-warnings-banner');
    var openBtn = pageBannerSeriesId ? ' <button class="btn btn-sm py-0 px-1 ms-auto page-banner-open" style="opacity:.7" title="Ouvrir la série"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></button>' : '';
    var existing = el.querySelector('.alert');
    if (existing && existing.classList.contains('alert-' + type)) {
      existing.innerHTML = msg + openBtn;
    } else {
      el.innerHTML = '<div class="alert alert-' + (type || 'info') + ' mb-3 d-flex align-items-center" style="font-size:.82rem;">' + msg + openBtn + '</div>';
    }
    var openEl = el.querySelector('.page-banner-open');
    if (openEl) {
      openEl.onclick = function() {
        if (!pageBannerSeriesId) return;
        var card = grid.querySelector('[data-id="' + pageBannerSeriesId + '"]');
        if (card) card.click();
      };
    }
    if (type === 'success' || type === 'warning' || type === 'danger') {
      setTimeout(function() { bannerLocked = false; el.innerHTML = ''; pageBannerSeriesId = null; }, 6000);
    }
  }
  function hidePageBanner() {
    bannerLocked = false;
    document.getElementById('sonarr-warnings-banner').innerHTML = '';
    pageBannerSeriesId = null;
  }

  // Tout analyser + RSS Sync
  document.getElementById('btn-refresh-all-series').addEventListener('click', function() {
    var btn = this; btn.disabled = true;
    ajaxPost('/medias/series/command/refresh-all', {}).then(function(d) {
      btn.disabled = false;
      if (d.ok && d.cmdId) {
        pollCmd(d.cmdId, 'Actualisation bibliothèque', function() {});
      } else {
        showPageBanner('❌ Erreur.', 'danger');
      }
    }).catch(function() { btn.disabled = false; });
  });

  document.getElementById('btn-rss-sync-series').addEventListener('click', function() {
    var btn = this; btn.disabled = true;
    ajaxPost('/medias/series/command/rss-sync', {}).then(function(d) {
      btn.disabled = false;
      if (d.ok && d.cmdId) {
        pollCmd(d.cmdId, 'Sync. RSS', function() {});
      } else {
        showPageBanner('❌ Erreur.', 'danger');
      }
    }).catch(function() { btn.disabled = false; });
  });

  // Warnings auto-refresh (10s)
  function refreshSeriesWarnings() {
    if (bannerLocked) return;
    var el = document.getElementById('sonarr-warnings-banner');
    if (!el) return;
    ajaxGet('/medias/series/warnings').then(function(warnings) {
      if (!warnings || !warnings.length) { el.innerHTML = ''; return; }
      el.innerHTML = '<div class="alert alert-warning mb-3"><div class="d-flex align-items-center"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2 flex-shrink-0"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg><div>' + warnings.map(function(w) { return '<div>' + w + '</div>'; }).join('') + '</div></div></div>';
    }).catch(function(){});
  }
  refreshSeriesWarnings();
  setInterval(refreshSeriesWarnings, 10000);

  // Check for active commands on page load (only user-initiated ones)
  var POLL_COMMANDS = {'SeriesSearch':1,'SeasonSearch':1,'EpisodeSearch':1,'RenameFiles':1,'MissingEpisodeSearch':1};
  ajaxGet('/medias/series/commands/active').then(function(cmds) {
    if (!cmds || !cmds.length) return;
    cmds.forEach(function(cmd) {
      var name = cmd.name || '';
      if (!POLL_COMMANDS[name]) return;
      var cmdId = cmd.id;
      if (!cmdId) return;
      var seriesId = (cmd.body && cmd.body.seriesId) ? String(cmd.body.seriesId) : null;
      var label = name;
      if (name === 'SeriesSearch') label = 'Recherche série';
      else if (name === 'SeasonSearch') label = 'Recherche saison';
      else if (name === 'EpisodeSearch') label = 'Recherche épisode';
      else if (name === 'RenameFiles') label = 'Renommage';
      else if (name === 'MissingEpisodeSearch') label = 'Recherche manquants';
      pollCmd(cmdId, label, function() {}, seriesId);
    });
  });

  function pollCmd(cmdId, label, onDone, seriesId) {
    var pollSeriesId = seriesId || currentId;
    var pollCount = 0;
    showPageBanner('<span class="spinner-border spinner-border-sm me-2"></span> 🔍 ' + label + ' — en cours...', 'info', pollSeriesId);
    if (pollSeriesId && pollSeriesId == currentId) {
      showBanner('<span class="spinner-border spinner-border-sm me-2"></span> ' + label + ' — en cours...', 'info');
    }
    var timer = setInterval(function() {
      pollCount++;
      var elapsed = pollCount * 2;
      fetch('/medias/series/command/' + cmdId, { headers: {'X-Requested-With':'XMLHttpRequest'} })
      .then(function(r) { return r.json(); })
      .then(function(cmd) {
        var st = (cmd.status || '').toLowerCase();
        var msg = cmd.message || '';
        var isCurrentModal = pollSeriesId && pollSeriesId == currentId;
        if (st === 'completed') {
          clearInterval(timer);
          var dl = msg.match(/(\d+) reports downloaded/);
          var dlCount = dl ? parseInt(dl[1]) : 0;
          var isSearch = label.toLowerCase().indexOf('recherche') !== -1;
          if (dlCount > 0) {
            if (isCurrentModal) showBanner('✅ ' + label + ' — ' + dlCount + ' téléchargement(s) lancé(s).', 'success');
            showPageBanner('✅ ' + label + ' — ' + dlCount + ' téléchargement(s) lancé(s). Vérifiez la queue.', 'success', pollSeriesId);
          } else if (isSearch) {
            if (isCurrentModal) showBanner('⚠️ ' + label + ' — terminé, aucun résultat trouvé.', 'warning');
            showPageBanner('⚠️ ' + label + ' — terminé, aucun résultat trouvé.', 'warning', pollSeriesId);
          } else {
            if (isCurrentModal) showBanner('✅ ' + label + ' — terminé.', 'success');
            showPageBanner('✅ ' + label + ' — terminé.', 'success', pollSeriesId);
          }
          if (isCurrentModal) setTimeout(hideBanner, 5000);
          if (onDone) onDone(true, msg);
        } else if (st === 'failed') {
          clearInterval(timer);
          if (isCurrentModal) showBanner('❌ ' + label + ' — échoué : ' + (msg || 'erreur inconnue'), 'danger');
          showPageBanner('❌ ' + label + ' — échoué : ' + (msg || 'erreur inconnue'), 'danger', pollSeriesId);
          if (onDone) onDone(false, msg);
        } else {
          var display = msg || ('Recherche en cours... (' + elapsed + 's)');
          if (isCurrentModal) showBanner('<span class="spinner-border spinner-border-sm me-2"></span> ' + label + ' — ' + display, 'info');
          showPageBanner('<span class="spinner-border spinner-border-sm me-2"></span> 🔍 ' + label + ' — ' + display, 'info', pollSeriesId);
        }
      });
    }, 2000);
    return timer;
  }

  var SEARCH_ICON = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>';
  var HISTORY_ICON = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>';
  var EDIT_ICON = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>';
  var FILES_ICON = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';

  // Actualiser & scanner série
