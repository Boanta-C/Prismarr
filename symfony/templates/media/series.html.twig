  }, true);
  grid.addEventListener('click', function(e) {
    var btn = e.target.closest('.hover-monitor-btn');
    if (!btn) return;
    e.preventDefault();
    e.stopImmediatePropagation();
    blockModal = true;
    var id = btn.dataset.id;
    var mon = btn.dataset.monitored === '1';
    var newMon = !mon;
    ajaxPost('/medias/series/' + id + '/monitor', { monitored: newMon }).then(function(data) {
      if (data.ok) {
        btn.dataset.monitored = newMon ? '1' : '0';
        var svg = btn.querySelector('svg');
        svg.setAttribute('fill', newMon ? '#6366f1' : 'none');
        svg.setAttribute('stroke', newMon ? '#6366f1' : 'rgba(255,255,255,.5)');
        btn.title = newMon ? 'Ne plus suivre' : 'Suivre';
        var card = grid.querySelector('.media-card[data-id="' + id + '"]');
        if (card) card.dataset.monitored = newMon ? '1' : '0';
        refreshSeriesCard(id);
      }
    });
  }, true);

