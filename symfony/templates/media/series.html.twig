    document.querySelectorAll('.select-cb-table-s').forEach(function(cb) {
      var id = cb.dataset.id;
      var isSelected = selectedSeriesIds.has(id);
      cb.style.background = isSelected ? '#6366f1' : 'rgba(0,0,0,.3)';
      cb.style.borderColor = isSelected ? '#6366f1' : 'rgba(255,255,255,.4)';
