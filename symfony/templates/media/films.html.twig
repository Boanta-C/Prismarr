      <div class="modal-body">
        {# Recherche #}
        <div class="d-flex gap-2 mb-4 mt-2">
          <input type="text" id="add-search-input" class="form-control form-control-lg" placeholder="Rechercher un film…" autocomplete="off" autofocus>
          <button id="add-search-btn" class="btn btn-primary flex-shrink-0">Chercher</button>
