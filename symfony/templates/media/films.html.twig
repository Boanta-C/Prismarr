          <input type="checkbox" class="form-check-input" id="bulk-delete-files">
          <label class="form-check-label" for="bulk-delete-files">Supprimer les fichiers du disque</label>
        </div>
        <div class="form-check mb-3">
          <input type="checkbox" class="form-check-input" id="bulk-delete-exclude">
          <label class="form-check-label" for="bulk-delete-exclude">Ajouter à la liste d'exclusion d'import</label>
        </div>
        <div class="small text-muted" style="max-height:150px;overflow-y:auto;" id="bulk-delete-list"></div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <button class="btn btn-danger" id="bulk-delete-confirm">Supprimer</button>
      </div>
    </div>
  </div>
</div>

{# ── Modal bulk renommer ── #}
<div class="modal modal-blur fade" id="modal-bulk-rename" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Organiser & Renommer</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="bulk-rename-loading" class="text-center text-muted py-3">
          <span class="spinner-border spinner-border-sm me-2"></span> Chargement des prévisualisations...
        </div>
        <div id="bulk-rename-content" style="display:none">
          <div id="bulk-rename-ok" class="alert alert-success py-2 small" style="display:none">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M20 6 9 17l-5-5"/></svg>
            <span id="bulk-rename-ok-text"></span>
          </div>
          <div id="bulk-rename-changes" style="max-height:350px;overflow-y:auto;"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <button class="btn btn-primary" id="bulk-rename-go">Organiser</button>
      </div>
    </div>
  </div>
</div>

{# ── Grille ── #}
<div class="media-grid" id="movies-grid">
{% for movie in movies %}
  {% set movieJson = {
    id: movie.id,
    title: movie.title,
    originalTitle: movie.originalTitle,
    year: movie.year,
    runtime: movie.runtime,
    overview: movie.overview,
    genres: movie.genres,
    studio: movie.studio,
    certification: movie.certification,
    poster: movie.poster,
    fanart: movie.fanart,
    hasFile: movie.hasFile,
    monitored: movie.monitored,
    status: movie.status,
    quality: movie.quality,
    sizeOnDisk: movie.sizeOnDisk,
    sizeGb: movie.sizeGb,
    path: movie.path,
    imdbId: movie.imdbId,
    tmdbId: movie.tmdbId,
    ratingsImdb: movie.ratingsImdb,
    ratingsImdbVotes: movie.ratingsImdbVotes,
    ratingsTmdb: movie.ratingsTmdb,
    ratingsTmdbVotes: movie.ratingsTmdbVotes,
    movieFile: movie.movieFile,
    added: movie.added,
    tags: movie.tags ?? [],
    qualityProfileId: movie.qualityProfileId,
    minimumAvailability: movie.minimumAvailability ?? 'released',
    alternateTitles: movie.alternateTitles ?? []
  } %}
  <div class="media-card"
       data-bs-toggle="modal"
       data-bs-target="#modal-film"
       data-title="{{ movie.title|lower }}"
       data-has-file="{{ movie.hasFile ? '1' : '0' }}"
       data-monitored="{{ movie.monitored ? '1' : '0' }}"
       data-status="{{ movie.status ?? 'released' }}"
       data-id="{{ movie.id }}"
       data-year="{{ movie.year ?? 0 }}"
       data-size="{{ movie.sizeOnDisk ?? 0 }}"
       data-added="{{ movie.added ?? '' }}"
       data-quality="{{ movie.quality ?? '' }}"
       data-genres="{{ movie.genres|join(',') }}"
       data-language="{{ movie.languages is defined ? movie.languages|join(', ') : (movie.language ?? '') }}"
       data-movie="{{ movieJson|json_encode|e('html_attr') }}"
       title="{{ movie.title }}{% if movie.year %} ({{ movie.year }}){% endif %}">

    {% if movie.poster %}
      <img src="{{ movie.poster }}" alt="{{ movie.title }}" loading="lazy">
    {% else %}
      <div class="no-poster">{{ movie.title }}</div>
    {% endif %}

    {# Checkbox sélection #}
    <div class="select-cb"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>

    {# Pastille statut #}
    {% if movie.hasFile %}
      <div class="status-dot" style="background:#22c55e;box-shadow:0 0 4px #22c55e;" title="Téléchargé"></div>
    {% elseif movie.monitored and movie.status in ['announced', 'inCinemas'] %}
      <div class="status-dot" style="background:#6366f1;box-shadow:0 0 4px #6366f1;" title="Suivi — indisponible ({{ movie.status == 'inCinemas' ? 'en salles' : 'annoncé' }})"></div>
    {% elseif movie.monitored %}
      <div class="status-dot" style="background:#f59e0b;box-shadow:0 0 4px #f59e0b;" title="Suivi — manquant"></div>
    {% else %}
      <div class="status-dot" style="background:#6b7280;" title="Non suivi"></div>
    {% endif %}

    {# Badge qualité #}
    {% if movie.quality %}
      <div class="quality-badge">{{ movie.quality }}</div>
    {% endif %}

    <div class="card-overlay">
      <div class="card-title-text">{{ movie.title }}</div>
      <div class="card-year">{{ movie.year }}</div>
    </div>

    {# Hover Jellyseerr #}
    <div class="hover-info">
      <div style="position:absolute;top:.3rem;left:.4rem;right:.4rem;display:flex;align-items:center;justify-content:space-between;">
        <div class="d-flex align-items-center gap-2">
          <span class="hover-monitor-btn-film" data-id="{{ movie.id }}" data-monitored="{{ movie.monitored ? '1' : '0' }}" style="line-height:1;pointer-events:auto;cursor:pointer;display:inline-flex;padding:.35rem;margin:-.35rem;border-radius:.25rem;" title="{{ movie.monitored ? 'Ne plus suivre' : 'Suivre' }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="{{ movie.monitored ? '#6366f1' : 'none' }}" stroke="{{ movie.monitored ? '#6366f1' : 'rgba(255,255,255,.5)' }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
          </span>
          {% if movie.quality %}<span class="badge bg-blue-lt" style="font-size:.6rem;">{{ movie.quality }}</span>{% endif %}
        </div>
        <div>
          {% if movie.hasFile %}
            <div style="width:10px;height:10px;border-radius:50%;background:#22c55e;box-shadow:0 0 4px #22c55e;border:2px solid rgba(0,0,0,.4);"></div>
          {% elseif movie.monitored and movie.status in ['announced', 'inCinemas'] %}
            <div style="width:10px;height:10px;border-radius:50%;background:#6366f1;box-shadow:0 0 4px #6366f1;border:2px solid rgba(0,0,0,.4);"></div>
          {% elseif movie.monitored %}
            <div style="width:10px;height:10px;border-radius:50%;background:#f59e0b;box-shadow:0 0 4px #f59e0b;border:2px solid rgba(0,0,0,.4);"></div>
          {% else %}
            <div style="width:10px;height:10px;border-radius:50%;background:#6b7280;border:2px solid rgba(0,0,0,.4);"></div>
          {% endif %}
        </div>
      </div>
      <div class="h-badges">
        {% if movie.hasFile %}<span class="badge bg-success-lt">Téléchargé</span>
        {% elseif movie.monitored %}<span class="badge bg-warning-lt">Manquant</span>
        {% else %}<span class="badge bg-secondary-lt">Non suivi</span>{% endif %}
      </div>
      <div class="h-title">{{ movie.title }}</div>
      <div class="h-year">{{ movie.year }}{% if movie.runtime %} · {{ movie.runtime }} min{% endif %}{% if movie.sizeGb %} · {{ movie.sizeGb }} Go{% endif %}</div>
      {% if movie.overview %}<div class="h-overview">{{ movie.overview }}</div>{% endif %}
    </div>

    {# Info étendue #}
    <div class="extended-info">
      <div class="fw-bold mb-1">{{ movie.title }}{% if movie.year %} <span class="text-muted fw-normal">({{ movie.year }})</span>{% endif %}</div>
      <div class="d-flex align-items-center gap-2 mb-1 flex-wrap" style="font-size:.78rem;">
        {% if movie.hasFile %}<span class="badge bg-success-lt">Téléchargé</span>
        {% elseif movie.monitored %}<span class="badge bg-warning-lt">Manquant</span>
        {% else %}<span class="badge bg-secondary-lt">Non suivi</span>{% endif %}
        {% if movie.quality %}<span class="badge bg-blue-lt">{{ movie.quality }}</span>{% endif %}
        {% if movie.runtime %}<span class="text-muted">{{ movie.runtime }} min</span>{% endif %}
        {% if movie.sizeGb %}<span class="text-muted">{{ movie.sizeGb }} Go</span>{% endif %}
      </div>
      {% if movie.genres %}<div class="d-flex gap-1 flex-wrap mb-1">{% for g in movie.genres %}<span class="badge bg-secondary-lt" style="font-size:.6rem;">{{ g }}</span>{% endfor %}</div>{% endif %}
      {% if movie.overview %}<div class="text-muted small" style="overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">{{ movie.overview }}</div>{% endif %}
    </div>
  </div>
{% endfor %}
</div>

{# ══════════════════════════════════════════════════════════════════════════════
   MODAL DETAIL FILM — Redesign Jellyfin/Radarr style
   ══════════════════════════════════════════════════════════════════════════════ #}
<div class="modal modal-blur fade" id="modal-film" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen-lg-down modal-xl" role="document" style="margin-top:1rem">
    <div class="modal-content" style="background:var(--tblr-bg-surface)">

      {# ── Header avec fanart backdrop ── #}
      <div class="film-header-backdrop" id="film-header-backdrop">
        <div class="film-header-content">
          <div class="d-flex justify-content-between align-items-start">
            <div style="max-width:85%">
              <div class="d-flex align-items-center gap-3 mb-1">
                <button id="btn-monitor" class="btn btn-sm d-flex align-items-center gap-1" style="filter:drop-shadow(0 1px 4px rgba(0,0,0,.5));font-size:.8rem;">
                  <svg id="monitor-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                  <span id="btn-monitor-label">Suivre</span>
                </button>
                <h2 class="text-white mb-0" id="film-title" style="text-shadow:0 2px 8px rgba(0,0,0,.6)"></h2>
              </div>
              <div id="film-original-title" class="text-white-50 small mb-2" style="display:none"></div>
              <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                <span id="film-year" class="text-white-50 fw-medium"></span>
                <span id="film-runtime" class="text-white-50"></span>
                <span id="film-cert" class="badge bg-dark text-white-50" style="display:none"></span>
                <span id="film-rating-imdb" class="film-rating-badge" style="display:none">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#f5c518" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
                  <span id="film-rating-imdb-val"></span>
                </span>
                <span id="film-rating-tmdb" class="film-rating-badge" style="display:none">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#01d277" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
                  <span id="film-rating-tmdb-val"></span>
                </span>
              </div>
              <div id="film-genres" class="d-flex flex-wrap gap-1 mt-2"></div>
            </div>
            <button type="button" class="btn-close btn-close-white ms-2 mt-1" data-bs-dismiss="modal" aria-label="Fermer" style="filter:drop-shadow(0 0 2px rgba(0,0,0,.8))"></button>
          </div>
        </div>
      </div>

      {# ── Body — two columns ── #}
      <div class="modal-body pt-0">
        <div class="row g-4" style="margin-top:-1rem">

          {# ── Left column: poster + status + actions ── #}
          <div class="col-md-4 col-lg-3">
            <div class="film-poster-col mb-3">
              <img id="film-poster" src="" alt="" loading="lazy" style="display:none">
            </div>

            {# Status badges #}
            <div class="d-flex flex-wrap gap-2 mb-3" id="film-status-badges"></div>

            {# Action buttons #}
            <div class="d-grid gap-2">
              <button id="btn-search" class="btn btn-primary film-action-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                Rechercher
              </button>
              <button id="btn-interactive" class="btn btn-outline-primary film-action-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                Recherche interactive
              </button>
              <button id="btn-refresh" class="btn btn-outline-secondary film-action-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg>
                Actualiser &amp; scanner
              </button>
              <div id="delete-choices" class="d-grid gap-1">
                <button id="btn-delete-radarr-only" class="btn btn-sm btn-warning">
                  Retirer de Radarr
                </button>
                <button id="btn-delete-file-only" class="btn btn-sm btn-danger">
                  Supprimer le fichier
                </button>
                <button id="btn-delete-from-radarr" class="btn btn-sm btn-danger">
                  Supprimer tout (Radarr + fichier)
                </button>
              </div>
            </div>

            {# External links #}
            <div class="d-flex gap-2 mt-3" id="film-external-links"></div>
          </div>

          {# ── Right column: synopsis + tech info + cast + history ── #}
          <div class="col-md-8 col-lg-9">

            {# Search feedback area #}
            <div id="search-feedback" class="alert mb-3" style="display:none">
              <div class="d-flex align-items-center gap-2">
                <div class="spinner-border spinner-border-sm" id="search-spinner" style="display:none"></div>
                <span id="search-feedback-text"></span>
              </div>
            </div>

            {# Interactive releases area #}
            <div id="releases-area" class="card mb-2" style="display:none">
              <div class="card-header">
                <h3 class="card-title">Releases disponibles</h3>
                <div class="card-actions">
                  <button type="button" class="btn btn-sm btn-ghost-secondary" id="releases-close">Fermer</button>
                </div>
              </div>
              <div id="releases-loading" class="card-body text-center text-muted py-4">
                <div class="spinner-border spinner-border-sm me-2"></div>
                Interrogation des indexeurs (30-60s)...
              </div>
              <div id="releases-table-wrap" style="display:none">
                <div class="table-responsive" style="max-height:350px;overflow-y:auto">
                  <table class="table table-sm table-vcenter table-hover card-table" style="font-size:.78rem" id="releases-table">
                    <thead class="sticky-top" style="background:var(--tblr-bg-surface)">
                      <tr>
                        <th class="rel-sort" data-col="title" style="cursor:pointer">Release <span class="rel-arrow"></span></th>
                        <th class="rel-sort" data-col="indexer" style="cursor:pointer">Indexeur <span class="rel-arrow"></span></th>
                        <th class="rel-sort" data-col="quality" style="cursor:pointer">Qualité <span class="rel-arrow"></span></th>
                        <th class="rel-sort text-end" data-col="score" style="cursor:pointer">Score <span class="rel-arrow"></span></th>
                        <th class="text-muted small">Formats</th>
                        <th class="rel-sort text-end" data-col="size" style="cursor:pointer">Taille <span class="rel-arrow"></span></th>
                        <th class="rel-sort text-end" data-col="seeders" style="cursor:pointer">Seeds <span class="rel-arrow"></span></th>
                        <th class="text-end">Langs</th>
                        <th class="rel-sort text-end" data-col="age" style="cursor:pointer">Âge <span class="rel-arrow"></span></th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody id="releases-tbody"></tbody>
                  </table>
                </div>
              </div>
              <div id="releases-empty" class="card-body text-center text-muted py-4" style="display:none">
                Aucune release trouvée.
              </div>
            </div>

            {# Synopsis #}
            <div class="mb-2">
              <h4 class="mb-2">Synopsis</h4>
              <p id="film-overview" class="text-muted" style="line-height:1.7"></p>
              <div id="film-studio" class="text-muted small" style="display:none"></div>
            </div>

            {# Technical info (only if hasFile) — compact table #}
            <div id="film-techinfo" class="card mb-2" style="display:none">
              <div class="card-header py-2"><h3 class="card-title mb-0">Informations du fichier</h3></div>
              <div class="table-responsive">
                <table class="table table-sm table-vcenter mb-0" style="font-size:.8rem" id="film-techinfo-table">
                  <tbody></tbody>
                </table>
              </div>
            </div>

            {# Extra files #}
            <div id="film-extras" class="text-muted small mb-3 px-1" style="display:none"></div>

            {# Rename info (only if hasFile) #}
            <div id="film-rename-info" class="card mb-2" style="display:none">
              <div class="card-header">
                <h3 class="card-title">Nommage du fichier</h3>
                <div class="card-actions">
                  <button id="btn-rename-file" class="btn btn-outline-secondary btn-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
                    Renommer
                  </button>
                </div>
              </div>
              <div class="card-body">
                <div id="rename-loading" class="text-muted small">Chargement des propositions...</div>
                <div id="rename-details" style="display:none">
                  <div class="mb-2">
                    <span class="text-muted small">Nom actuel :</span>
                    <div class="fw-medium small font-monospace text-truncate" id="rename-current" title=""></div>
                  </div>
                  <div>
                    <span class="text-muted small">Nom attendu :</span>
                    <div class="fw-medium small font-monospace text-truncate" id="rename-expected" title=""></div>
                  </div>
                  <div id="rename-match" class="mt-2 small text-success" style="display:none">Le fichier est déjà correctement nommé.</div>
                </div>
                <div id="rename-empty" class="text-muted small" style="display:none">Aucune proposition de renommage.</div>
              </div>
            </div>

            {# Rename feedback #}
            <div id="rename-feedback" class="alert mb-3" style="display:none">
              <div class="d-flex align-items-center gap-2">
                <div class="spinner-border spinner-border-sm" id="rename-spinner" style="display:none"></div>
                <span id="rename-feedback-text"></span>
              </div>
            </div>

            {# Modifier le film (collapsible) #}
            <div id="film-edit-card" class="card mb-2" style="display:none">
              <div class="card-header" style="cursor:pointer" id="edit-card-toggle">
                <h3 class="card-title">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  Modifier
                </h3>
                <div class="card-actions">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="edit-card-chevron" style="transition:transform .2s"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
              <div id="edit-card-body" class="card-body p-0" style="display:none">
                <div id="edit-card-loading" class="p-3 text-muted small text-center">
                  <span class="spinner-border spinner-border-sm me-1"></span> Chargement...
                </div>
                <div id="edit-card-content" style="display:none"></div>
                <div id="edit-card-feedback" class="alert m-3" style="display:none"></div>
              </div>
            </div>

            {# Gérer les fichiers (only if hasFile, lazy-loaded via AJAX) #}
            <div id="film-filemanager" class="card mb-2" style="display:none">
              <div class="card-header" style="cursor:pointer" id="filemanager-toggle">
                <h3 class="card-title">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                  Gérer les fichiers
                </h3>
                <div class="card-actions">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="filemanager-chevron" style="transition:transform .2s"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
              <div id="filemanager-body" class="card-body p-0" style="display:none">
                <div id="filemanager-loading" class="p-3 text-muted small text-center">
                  <span class="spinner-border spinner-border-sm me-1"></span> Chargement des fichiers...
                </div>
                <div id="filemanager-content" style="display:none"></div>
                <div id="filemanager-feedback" class="alert m-3" style="display:none">
                  <span id="filemanager-feedback-text"></span>
                </div>
              </div>
            </div>


            {# Casting (AJAX) #}
            <div class="card mb-2">
              <div class="card-header py-2"><h3 class="card-title mb-0">Casting</h3></div>
              <div class="card-body py-2">
                <div id="cast-loading" class="text-muted small">Chargement...</div>
                <div id="cast-scroll" class="cast-scroll" style="display:none"></div>
                <div id="cast-empty" class="text-muted small" style="display:none">Aucune information de casting disponible.</div>
              </div>
            </div>

            {# Équipe (AJAX) #}
            <div class="card mb-2" id="crew-section" style="display:none">
              <div class="card-header py-2"><h3 class="card-title mb-0">Équipe</h3></div>
              <div class="card-body py-2">
                <div id="crew-scroll" class="cast-scroll"></div>
              </div>
            </div>

            {# Titres alternatifs (déroulant) #}
            <div class="card mb-2" id="titles-section" style="display:none">
              <div class="card-header py-2" style="cursor:pointer" id="titles-toggle">
                <h3 class="card-title mb-0">Titres</h3>
                <div class="card-actions">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="titles-chevron" style="transition:transform .2s"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
              <div id="titles-body" class="card-body p-0" style="display:none">
                <div class="table-responsive">
                  <table class="table table-sm table-vcenter mb-0" style="font-size:.78rem" id="titles-table">
                    <thead><tr><th>Titre alternatif</th><th>Source</th></tr></thead>
                    <tbody id="titles-tbody"></tbody>
                  </table>
                </div>
              </div>
            </div>

            {# History (AJAX, collapsible) #}
            <div class="card mb-2">
              <div class="card-header py-2" style="cursor:pointer" id="hist-toggle">
                <h3 class="card-title d-flex align-items-center gap-2 mb-0">
                  Historique
                  <svg id="hist-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="transition:transform .2s"><path d="m6 9 6 6 6-6"/></svg>
                </h3>
              </div>
              <div id="hist-content" style="display:none">
                <div class="card-body py-2">
                  <div id="hist-loading" class="text-muted small">Chargement...</div>
                  <div id="hist-timeline"></div>
                  <div id="hist-empty" class="text-muted small" style="display:none">Aucun historique.</div>
                </div>
              </div>
            </div>

          </div>{# /col right #}
        </div>{# /row #}
      </div>{# /modal-body #}

    </div>
  </div>
</div>

{# ── Modal ajout film ── #}
<div class="modal modal-blur fade" id="modal-add-film" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document" style="margin-top:2rem">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title">Ajouter un film</h4>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Fermer"></button>
