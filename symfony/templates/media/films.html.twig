      </div>
    </div>
  </div>
</div>

</div>
</div>
{% endif %}


{% endblock %}

{% block javascripts %}
<script>
(function () {
  /* ══════════════════════════════════════════════════════════════════════════
     Grille + filtres
     ══════════════════════════════════════════════════════════════════════════ */
  var grid    = document.getElementById('movies-grid');
  var search  = document.getElementById('search-input');
  var btnAll  = document.querySelectorAll('.filter-btn');
  var counter = document.getElementById('count-label'); // peut être null
  var currentFilter = 'all';

  function applyFilters() {
    var q       = search.value.toLowerCase().trim();
    var fQual   = filterQuality.value;
    var fGenre  = filterGenre.value;
    var fLang   = filterLanguage.value;
    var cards   = grid.querySelectorAll('.media-card');
    var visible = 0;

    cards.forEach(function (c) {
      var title     = c.dataset.title || '';
      var hasFile   = c.dataset.hasFile === '1';
      var monitored = c.dataset.monitored === '1';

      var status    = c.dataset.status || 'released';
      var isUnavail = !hasFile && monitored && (status === 'announced' || status === 'inCinemas');

      var matchSearch = !q || title.includes(q);
      var matchStatus = currentFilter === 'all'
        || (currentFilter === 'downloaded'   && hasFile)
        || (currentFilter === 'missing'      && !hasFile && monitored)
        || (currentFilter === 'unmonitored'  && !monitored);
      var matchQuality  = !fQual || (c.dataset.quality || '') === fQual;
      var matchGenre    = !fGenre || (c.dataset.genres || '').split(',').indexOf(fGenre) !== -1;
      var matchLanguage = !fLang || (c.dataset.language || '').indexOf(fLang) !== -1;

      var show = matchSearch && matchStatus && matchQuality && matchGenre && matchLanguage;
      if (show) {
        c.style.removeProperty('display');
        visible++;
      } else {
        c.style.setProperty('display', 'none', 'important');
      }
    });

    if (counter) counter.textContent = visible + ' film' + (visible > 1 ? 's' : '');

    // Sync filtre sur le tableau
    document.querySelectorAll('.films-table-row').forEach(function(row) {
      var card = grid.querySelector('.media-card[data-id="' + row.dataset.id + '"]');
      row.style.display = (card && getComputedStyle(card).display !== 'none') ? '' : 'none';
    });

    // Afficher les boutons bulk seulement si un filtre de statut/qualité/genre/langue est appliqué (pas le tri ni la recherche texte)
    var hasFilter = currentFilter !== 'all' || fQual || fGenre || fLang;
    document.getElementById('btn-update-filtered').style.display = hasFilter ? '' : 'none';
    document.getElementById('btn-search-filtered').style.display = hasFilter ? '' : 'none';

    // Rebuild étagères si visible
    if (filmsShelfView.style.display === 'block') { filmsShelfBuilt = false; buildFilmsShelf(); }
  }

  // Peupler les filtres dynamiquement depuis les données des cards
  var qualitySet = new Set();
  var genreSet = new Set();
  var languageSet = new Set();
  grid.querySelectorAll('.media-card').forEach(function(c) {
    if (c.dataset.quality) qualitySet.add(c.dataset.quality);
    (c.dataset.language || '').split(', ').forEach(function(l) { if (l.trim()) languageSet.add(l.trim()); });
    (c.dataset.genres || '').split(',').forEach(function(g) { if (g.trim()) genreSet.add(g.trim()); });
  });

  function populateSelect(id, values) {
    var sel = document.getElementById(id);
    var label = sel.options[0].text;
    Array.from(values).sort().forEach(function(v) {
      var opt = document.createElement('option'); opt.value = v; opt.textContent = v;
      sel.appendChild(opt);
    });
  }
  populateSelect('filter-quality', qualitySet);
  populateSelect('filter-genre', genreSet);
  populateSelect('filter-language', languageSet);

  var filterQuality = document.getElementById('filter-quality');
  var filterGenre = document.getElementById('filter-genre');
  var filterLanguage = document.getElementById('filter-language');
  filterQuality.addEventListener('change', applyFilters);
  filterGenre.addEventListener('change', applyFilters);
  filterLanguage.addEventListener('change', applyFilters);

  search.addEventListener('input', applyFilters);

  /* ── Bulk actions on filtered films ── */
  function getFilteredMovieIds() {
    var ids = [];
    grid.querySelectorAll('.media-card').forEach(function(c) {
      if (c.style.display !== 'none') ids.push(parseInt(c.dataset.id));
    });
    return ids;
  }

  var ICON_REFRESH = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>';
  var ICON_SEARCH = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>';

  var bannerLocked = false; // Empêcher refreshWarnings d'écraser le bandeau pendant une action
  function showPageBanner(msg, type) {
    var el = document.getElementById('warnings-banner');
    if (!el) return;
    bannerLocked = true;
    var existing = el.querySelector('.alert');
    if (existing && existing.classList.contains('alert-' + type)) {
      existing.innerHTML = msg;
    } else {
      el.innerHTML = '<div class="alert alert-' + type + ' mb-3">' + msg + '</div>';
    }
    if (type === 'success' || type === 'warning' || type === 'danger') {
      setTimeout(function() { bannerLocked = false; refreshWarnings(); }, 6000);
    }
  }

  document.getElementById('btn-update-filtered').addEventListener('click', function() {
    var ids = getFilteredMovieIds();
    if (!ids.length) return;
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> ' + ids.length + ' films...';
    showPageBanner('<span class="spinner-border spinner-border-sm me-2"></span> Actualisation de ' + ids.length + ' film(s) en cours...', 'info');

    ajaxPost('/medias/films/bulk/refresh', { movieIds: ids })
    .then(function(data) {
      btn.disabled = false;
      btn.innerHTML = ICON_REFRESH + ' Actualiser les filtrés';
      if (data.ok) {
        showPageBanner('✅ Actualisation lancée pour ' + ids.length + ' film(s) — Radarr met à jour les métadonnées et scanne les fichiers.', 'success');
      } else {
        showPageBanner('❌ Erreur actualisation : ' + (data.error || 'erreur inconnue'), 'danger');
      }
    }).catch(function() {
      btn.disabled = false;
      btn.innerHTML = ICON_REFRESH + ' Actualiser les filtrés';
      showPageBanner('❌ Erreur réseau.', 'danger');
    });
  });

  document.getElementById('btn-search-filtered').addEventListener('click', function() {
    var ids = [];
    grid.querySelectorAll('.media-card').forEach(function(c) {
      if (c.style.display !== 'none' && c.dataset.hasFile === '0' && c.dataset.monitored === '1') ids.push(parseInt(c.dataset.id));
    });
    if (!ids.length) {
      showPageBanner('⚠️ Aucun film manquant dans la sélection filtrée.', 'warning');
      return;
    }
    if (!confirm('Lancer la recherche pour ' + ids.length + ' film(s) manquant(s) ?')) return;
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> ' + ids.length + ' films...';
    showPageBanner('<span class="spinner-border spinner-border-sm me-2"></span> 🔍 Recherche en cours pour ' + ids.length + ' film(s) manquant(s) sur ' + INDEXER_COUNT + ' indexeur(s)...', 'info');

    var filmNames = [];
    grid.querySelectorAll('.media-card').forEach(function(c) {
      if (c.style.display !== 'none' && c.dataset.hasFile === '0' && c.dataset.monitored === '1') {
        filmNames.push(c.getAttribute('title') || '?');
      }
    });

    ajaxPost('/medias/films/bulk/search', { movieIds: ids })
    .then(function(data) {
      if (data.ok && data.cmdId) {
        // Poll le statut de la commande
        var bulkPollCount = 0;
        var lastFilmSeen = '';
        var filmsDone = 0;
        var bulkPoll = setInterval(function() {
          bulkPollCount++;
          var elapsed = bulkPollCount * 2;
          ajaxGet('/medias/films/command/' + data.cmdId)
          .then(function(cmd) {
            var st = (cmd.status || '').toLowerCase();
            var msg = cmd.message || '';

            if (st === 'completed') {
              clearInterval(bulkPoll);
              btn.disabled = false;
              btn.innerHTML = ICON_SEARCH + ' Rechercher les filtrés';
              var downloaded = msg.match(/(\d+) reports downloaded/);
              var dlCount = downloaded ? parseInt(downloaded[1]) : 0;
              if (dlCount > 0) {
                showPageBanner('✅ Recherche terminée — ' + dlCount + ' téléchargement(s) lancé(s) pour ' + ids.length + ' film(s). Vérifiez la queue ci-dessus.', 'success');
              } else {
                showPageBanner('⚠️ Recherche terminée pour ' + ids.length + ' film(s) — aucun torrent trouvé correspondant aux critères.', 'warning');
              }
            } else if (st === 'failed') {
              clearInterval(bulkPoll);
              btn.disabled = false;
              btn.innerHTML = ICON_SEARCH + ' Rechercher les filtrés';
              showPageBanner('❌ Recherche échouée : ' + (msg || 'erreur inconnue'), 'danger');
            } else {
              // En cours — compter les films traités
              var filmMatch = msg.match(/for\s+\[(.+?)\]/i);
              if (filmMatch && filmMatch[1] !== lastFilmSeen) {
                lastFilmSeen = filmMatch[1];
                filmsDone++;
              }
              var progress = filmsDone > 0 ? ' — Film ' + filmsDone + '/' + ids.length : '';
              var display = msg || ('Recherche en cours... (' + elapsed + 's)');
              showPageBanner('<span class="spinner-border spinner-border-sm me-2"></span> 🔍 ' + display + progress, 'info');
            }
          });
        }, 2000);
      } else {
        btn.disabled = false;
        btn.innerHTML = ICON_SEARCH + ' Rechercher les filtrés';
        showPageBanner('❌ Erreur recherche : ' + (data.error || 'erreur inconnue'), 'danger');
      }
    }).catch(function() {
      btn.disabled = false;
      btn.innerHTML = ICON_SEARCH + ' Rechercher les filtrés';
      showPageBanner('❌ Erreur réseau.', 'danger');
    });
  });

  var sortSelect = document.getElementById('sort-select');
  sortSelect.addEventListener('change', function() {
    var val = this.value;
    var cards = Array.from(grid.querySelectorAll('.media-card'));
    cards.sort(function(a, b) {
      switch(val) {
        case 'title-asc':  return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        case 'title-desc': return (b.dataset.title || '').localeCompare(a.dataset.title || '');
        case 'year-desc':  return (parseInt(b.dataset.year) || 0) - (parseInt(a.dataset.year) || 0);
        case 'year-asc':   return (parseInt(a.dataset.year) || 0) - (parseInt(b.dataset.year) || 0);
        case 'added-desc': return (b.dataset.added || '').localeCompare(a.dataset.added || '');
        case 'size-desc':  return (parseInt(b.dataset.size) || 0) - (parseInt(a.dataset.size) || 0);
        case 'size-asc':   return (parseInt(a.dataset.size) || 0) - (parseInt(b.dataset.size) || 0);
        default: return 0;
      }
    });
    cards.forEach(function(c) { grid.appendChild(c); });
    applyFilters();
  });

  btnAll.forEach(function (btn) {
    btn.addEventListener('click', function () {
      btnAll.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentFilter = btn.dataset.filter;
      applyFilters();
    });
  });

  /* ══════════════════════════════════════════════════════════════════════════
     Utilitaires
     ══════════════════════════════════════════════════════════════════════════ */
  function esc(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function formatSize(bytes) {
    if (!bytes || bytes <= 0) return '—';
    if (bytes >= 1073741824) return (bytes / 1073741824).toFixed(2) + ' Go';
    return Math.round(bytes / 1048576) + ' Mo';
  }

  function formatRuntime(min) {
    if (!min || min <= 0) return '';
    var h = Math.floor(min / 60);
    var m = min % 60;
    if (h === 0) return m + 'min';
    return h + 'h ' + (m < 10 ? '0' : '') + m + 'min';
  }

  function ajaxGet(url) {
    return fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    });
  }

  function ajaxPost(url, body) {
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify(body || {}),
    }).then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    });
  }

  /* ══════════════════════════════════════════════════════════════════════════
     Modal detail film
     ══════════════════════════════════════════════════════════════════════════ */
  var modalEl          = document.getElementById('modal-film');
  var currentMovie     = null;
  var currentId        = null;
  var currentMonitored = false;
  var pollTimer        = null;

  modalEl.addEventListener('show.bs.modal', function (event) {
    var card = event.relatedTarget;
    if (!card || !card.dataset.movie) return;

    currentMovie     = JSON.parse(card.dataset.movie);
    currentId        = currentMovie.id;
    currentMonitored = currentMovie.monitored;

    populateHeader(currentMovie);
    populateLeftCol(currentMovie);
    populateRightCol(currentMovie);
    showFileActions(currentMovie);
    loadCredits(currentId);
    loadRenameProposals(currentId);
    // Reset historique (lazy load au clic)
    document.getElementById('hist-content').style.display = 'none';
    document.getElementById('hist-chevron').style.transform = '';
    histLoaded = false;

    // Reset dynamic areas
    hideSearchFeedback();
    hideRenameFeedback();
    document.getElementById('releases-area').style.display = 'none';
  });

  modalEl.addEventListener('hidden.bs.modal', function () {
    stopPoll();
    currentMovie = null;
    currentId    = null;
  });

  /* ── Header ── */
  function populateHeader(m) {
    var backdrop = document.getElementById('film-header-backdrop');
    if (m.fanart) {
      backdrop.style.backgroundImage = 'url(' + m.fanart + ')';
      backdrop.classList.add('has-fanart');
    } else {
      backdrop.style.backgroundImage = 'none';
      backdrop.style.background = 'var(--tblr-bg-surface)';
      backdrop.classList.remove('has-fanart');
    }

    document.getElementById('film-title').textContent = m.title + (m.year ? ' (' + m.year + ')' : '');

    var origEl = document.getElementById('film-original-title');
    if (m.originalTitle && m.originalTitle !== m.title) {
      origEl.textContent = 'Titre original : ' + m.originalTitle;
      origEl.style.display = '';
    } else {
      origEl.style.display = 'none';
    }

    document.getElementById('film-year').textContent = m.year || '';
    document.getElementById('film-runtime').textContent = formatRuntime(m.runtime);

    var certEl = document.getElementById('film-cert');
    if (m.certification) {
      certEl.textContent = m.certification;
      certEl.style.display = '';
    } else {
      certEl.style.display = 'none';
    }

    // Ratings
    var imdbEl = document.getElementById('film-rating-imdb');
    if (m.ratingsImdb && m.ratingsImdb > 0) {
      document.getElementById('film-rating-imdb-val').textContent = parseFloat(m.ratingsImdb).toFixed(1) + (m.ratingsImdbVotes ? ' (' + formatVotes(m.ratingsImdbVotes) + ')' : '');
      imdbEl.style.display = '';
    } else {
      imdbEl.style.display = 'none';
    }

    var tmdbEl = document.getElementById('film-rating-tmdb');
    if (m.ratingsTmdb && m.ratingsTmdb > 0) {
      document.getElementById('film-rating-tmdb-val').textContent = (parseFloat(m.ratingsTmdb) * 10).toFixed(0) + '%';
      tmdbEl.style.display = '';
    } else {
      tmdbEl.style.display = 'none';
    }

    // Genres
    var genresEl = document.getElementById('film-genres');
    genresEl.innerHTML = '';
    (m.genres || []).forEach(function (g) {
      var span = document.createElement('span');
      span.className = 'film-genre-badge';
      span.textContent = g;
      genresEl.appendChild(span);
    });
  }

  function formatVotes(n) {
    if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
    return n;
  }

  /* ── Left column ── */
  function populateLeftCol(m) {
    var posterImg = document.getElementById('film-poster');
    if (m.poster) {
      posterImg.src = m.poster;
      posterImg.alt = m.title;
      posterImg.style.display = '';
    } else {
      posterImg.style.display = 'none';
    }

    // Status badges
    var badgesEl = document.getElementById('film-status-badges');
    badgesEl.innerHTML = '';
    if (m.monitored) {
      badgesEl.innerHTML += '<span class="badge bg-primary-lt" title="Radarr surveille ce film et cherchera automatiquement une release">Suivi</span>';
    } else {
      badgesEl.innerHTML += '<span class="badge bg-secondary-lt" title="Ce film n\'est pas surveillé, Radarr ne cherchera pas de release">Non suivi</span>';
    }
    if (m.hasFile) {
      badgesEl.innerHTML += '<span class="badge bg-success-lt" title="Le fichier est présent sur le disque">Téléchargé</span>';
    } else if (m.monitored && (m.status === 'announced' || m.status === 'inCinemas')) {
      var statusLabel = m.status === 'inCinemas' ? 'En salles' : 'Annoncé';
      var statusTip = m.status === 'inCinemas' ? 'Ce film est actuellement en salles, pas encore disponible en téléchargement' : 'Ce film est annoncé mais pas encore sorti';
      badgesEl.innerHTML += '<span class="badge" style="background:rgba(99,102,241,.15);color:#6366f1;" title="' + statusTip + '">Indisponible — ' + statusLabel + '</span>';
    } else {
      badgesEl.innerHTML += '<span class="badge bg-warning-lt" title="Le film est sorti mais aucun fichier n\'a été trouvé ou téléchargé">Manquant</span>';
    }
    if (m.quality) {
      badgesEl.innerHTML += '<span class="badge bg-blue-lt" title="Qualité du fichier téléchargé">' + esc(m.quality) + '</span>';
    }
    if (m.sizeOnDisk > 0) {
      badgesEl.innerHTML += '<span class="badge bg-secondary-lt" title="Taille du fichier sur le disque">' + formatSize(m.sizeOnDisk) + '</span>';
    }

    // Monitor button label
    refreshMonitorBtn();

    // External links
    var linksEl = document.getElementById('film-external-links');
    linksEl.innerHTML = '';
    if (m.imdbId) {
      linksEl.innerHTML += '<a href="https://www.imdb.com/title/' + esc(m.imdbId) + '/" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary">IMDb</a>';
    }
    if (m.tmdbId) {
      linksEl.innerHTML += '<a href="https://www.themoviedb.org/movie/' + m.tmdbId + '" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary">TMDB</a>';
    }
  }

  /* ── Right column ── */
  function populateRightCol(m) {
    // Synopsis
    document.getElementById('film-overview').textContent = m.overview || 'Aucun synopsis disponible.';

    var studioEl = document.getElementById('film-studio');
    if (m.studio) {
      studioEl.textContent = 'Studio : ' + m.studio;
      studioEl.style.display = '';
    } else {
      studioEl.style.display = 'none';
    }

    // Technical info
    var techCard = document.getElementById('film-techinfo');
    var techBody = document.querySelector('#film-techinfo-table tbody');
    techBody.innerHTML = '';

    if (m.hasFile && m.movieFile) {
      techCard.style.display = '';
      var mf = m.movieFile;
      var mi = mf.mediaInfo || {};
      var items = [];

      if (mf.relativePath) items.push(['Chemin', '<span class="font-monospace small">' + esc(mf.relativePath) + '</span>']);
      if (mf.quality) items.push(['Qualité', '<span class="badge bg-blue-lt">' + esc(mf.quality) + '</span>']);
      if (mi.videoCodec) items.push(['Vidéo', esc(mi.videoCodec) + (mi.resolution ? ' · ' + esc(mi.resolution) : '') + (mi.videoFps ? ' · ' + parseFloat(mi.videoFps).toFixed(0) + 'fps' : '')]);
      if (mi.videoDynamicRange) items.push(['HDR', esc(mi.videoDynamicRange) + (mi.videoBitDepth ? ' · ' + mi.videoBitDepth + 'bits' : '')]);
      if (mi.audioCodec) items.push(['Audio', esc(mi.audioCodec) + (mi.audioChannels ? ' · ' + mi.audioChannels + 'ch' : '')]);
      if (mf.languages && mf.languages.length) items.push(['Langues', mf.languages.map(function(l) { return '<span class="badge bg-cyan-lt me-1">' + esc(l) + '</span>'; }).join('')]);
      if (mi.subtitles) items.push(['Sous-titres', '<span class="text-muted">' + esc(mi.subtitles) + '</span>']);
      if (mf.size) items.push(['Taille', formatSize(mf.size)]);
      if (mf.releaseGroup) items.push(['Groupe', esc(mf.releaseGroup)]);
      // Custom formats
      if (mf.customFormats && mf.customFormats.length) {
        var cfHtml = mf.customFormats.map(function(cf) { return '<span class="badge bg-purple-lt me-1">' + esc(cf) + '</span>'; }).join('');
        if (mf.customFormatScore) cfHtml += ' <span class="text-muted small">+' + mf.customFormatScore + '</span>';
        items.push(['Formats', cfHtml]);
      }

      // 2 paires par ligne
      for (var i = 0; i < items.length; i += 2) {
        var tr = document.createElement('tr');
        tr.innerHTML = '<td class="text-muted" style="width:15%;white-space:nowrap">' + items[i][0] + '</td>' +
          '<td style="width:35%">' + items[i][1] + '</td>' +
          (items[i+1] ? '<td class="text-muted" style="width:15%;white-space:nowrap">' + items[i+1][0] + '</td><td style="width:35%">' + items[i+1][1] + '</td>' : '<td></td><td></td>');
        techBody.appendChild(tr);
      }
    } else {
      techCard.style.display = 'none';
    }

    // Extra files
    var extrasEl = document.getElementById('film-extras');
    extrasEl.style.display = 'none';
    if (m.hasFile && m.id) {
      ajaxGet('/medias/films/' + m.id + '/extras').then(function(extras) {
        if (!extras || !extras.length) {
          extrasEl.textContent = 'Pas de fichiers supplémentaires à gérer.';
        } else {
          extrasEl.textContent = extras.length + ' fichier(s) supplémentaire(s) : ' + extras.map(function(e) { return e.relativePath || e.extension || '?'; }).join(', ');
        }
        extrasEl.style.display = '';
      }).catch(function() {
        extrasEl.textContent = 'Pas de fichiers supplémentaires à gérer.';
        extrasEl.style.display = '';
      });
    }
  }

  /* ── Credits (AJAX) ── */
  var BOOKMARK_SVG = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>';

  function buildCreditCard(person, role) {
    var card = document.createElement('div');
    card.className = 'cast-card';
    var imgUrl = '';
    if (person.images && person.images.length) {
      for (var i = 0; i < person.images.length; i++) {
        if (person.images[i].remoteUrl) { imgUrl = person.images[i].remoteUrl; break; }
        if (person.images[i].url) { imgUrl = person.images[i].url; break; }
      }
    }
    var html = '<button class="cast-bookmark" data-person="' + esc(person.personName || '') + '" data-tmdb="' + (person.personTmdbId || person.tmdbId || '') + '" data-person-type="' + (person.type || 'cast') + '" data-person-job="' + esc(person.job || '') + '" title="Suivre cet artiste">' + BOOKMARK_SVG + '</button>';
    html += imgUrl
      ? '<img src="' + esc(imgUrl) + '" alt="' + esc(person.personName) + '" loading="lazy">'
      : '<div style="width:64px;height:64px;border-radius:50%;background:var(--tblr-bg-surface-secondary);margin:0 auto;display:flex;align-items:center;justify-content:center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--tblr-muted)" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>';
    html += '<div class="cast-name">' + esc(person.personName || '—') + '</div>';
    html += '<div class="cast-role">' + esc(role) + '</div>';
    card.innerHTML = html;

    var bm = card.querySelector('.cast-bookmark');
    bm.querySelector('svg').setAttribute('fill', 'none');
    bm.querySelector('svg').setAttribute('stroke', 'rgba(255,255,255,.4)');
    return card;
  }

  function loadCredits(movieId) {
    var loading  = document.getElementById('cast-loading');
    var scroll   = document.getElementById('cast-scroll');
    var empty    = document.getElementById('cast-empty');
    var crewScroll = document.getElementById('crew-scroll');
    var crewSection = document.getElementById('crew-section');
    var titlesSection = document.getElementById('titles-section');
    var titlesTbody = document.getElementById('titles-tbody');

    loading.style.display = '';
    scroll.style.display  = 'none';
    scroll.innerHTML      = '';
    empty.style.display   = 'none';
    crewScroll.innerHTML  = '';
    crewSection.style.display = 'none';
    titlesSection.style.display = 'none';
    titlesTbody.innerHTML = '';

    Promise.all([
      ajaxGet('/medias/films/' + movieId + '/credits'),
      ajaxGet('/medias/films/person/following')
    ])
    .then(function (results) {
      var credits = results[0] || [];
      var following = results[1] || {}; // {personTmdbId: listId}
      loading.style.display = 'none';

      function activateBookmarks(container) {
        container.querySelectorAll('.cast-bookmark').forEach(function(bm) {
          var tmdbId = parseInt(bm.dataset.tmdb) || 0;
          var personType = bm.dataset.personType || 'cast';
          var personJob = bm.dataset.personJob || '';
          var personName = bm.dataset.person || '';
          var listId = following[tmdbId] || null;
          // Set initial state
          if (listId) {
            bm.classList.add('active');
            bm.querySelector('svg').setAttribute('fill', '#6366f1');
            bm.querySelector('svg').setAttribute('stroke', '#6366f1');
            bm.dataset.listId = listId;
          }
          bm.addEventListener('click', function() {
            var isActive = bm.classList.contains('active');
            if (isActive) {
              // Unfollow
              var lid = bm.dataset.listId;
              if (!lid) return;
              bm.querySelector('svg').setAttribute('fill', 'none');
              bm.querySelector('svg').setAttribute('stroke', 'rgba(255,255,255,.4)');
              bm.classList.remove('active');
              ajaxPost('/medias/films/person/unfollow', { listId: parseInt(lid) });
              delete following[tmdbId];
            } else {
              // Follow
              bm.querySelector('svg').setAttribute('fill', '#6366f1');
              bm.querySelector('svg').setAttribute('stroke', '#6366f1');
              bm.classList.add('active');
              ajaxPost('/medias/films/person/follow', {
                personTmdbId: tmdbId,
                personName: personName,
                type: personType,
                job: personJob
              }).then(function(data) {
                if (data.ok && data.listId) {
                  bm.dataset.listId = data.listId;
                  following[tmdbId] = data.listId;
                }
              });
            }
          });
        });
      }

      // Cast
      var actors = credits.filter(function (c) { return c.type === 'cast'; }).slice(0, 15);
      if (!actors.length) { empty.style.display = ''; }
      else {
        actors.forEach(function (a) {
          scroll.appendChild(buildCreditCard(a, a.character || ''));
        });
        activateBookmarks(scroll);
        scroll.style.display = '';
      }

      // Crew — dédupliquer par personne (une carte par personne, tous les rôles)
      var crew = credits.filter(function (c) { return c.type === 'crew'; });
      var jobOrder = {'Director':0,'Screenplay':1,'Writer':2,'Producer':3,'Executive Producer':4,'Director of Photography':5};
      crew.sort(function(a, b) {
        var oa = jobOrder[a.job] !== undefined ? jobOrder[a.job] : 99;
        var ob = jobOrder[b.job] !== undefined ? jobOrder[b.job] : 99;
        return oa - ob;
      });
      // Regrouper par personTmdbId
      var seenCrew = {};
      var uniqueCrew = [];
      crew.forEach(function(c) {
        var pid = c.personTmdbId || c.personName;
        if (seenCrew[pid]) {
          seenCrew[pid].jobs.push(c.job || c.department || '');
        } else {
          seenCrew[pid] = { person: c, jobs: [c.job || c.department || ''] };
          uniqueCrew.push(seenCrew[pid]);
        }
      });
      if (uniqueCrew.length) {
        uniqueCrew.slice(0, 15).forEach(function (entry) {
          var roleLabel = entry.jobs.join(', ');
          crewScroll.appendChild(buildCreditCard(entry.person, roleLabel));
        });
        activateBookmarks(crewScroll);
        crewSection.style.display = '';
      }
    })
    .catch(function () {
      loading.style.display = 'none';
      empty.style.display = '';
    });

    // Titres alternatifs (depuis les données du film déjà chargées)
    if (currentMovie && currentMovie.alternateTitles && currentMovie.alternateTitles.length) {
      currentMovie.alternateTitles.forEach(function(t) {
        var tr = document.createElement('tr');
        tr.innerHTML = '<td>' + esc(t.title || '—') + '</td><td><span class="badge bg-secondary-lt" style="font-size:.65rem">' + esc(t.sourceType || '—') + '</span></td>';
        titlesTbody.appendChild(tr);
      });
      titlesSection.style.display = '';
    }
  }

  // Titles toggle
  document.getElementById('titles-toggle').addEventListener('click', function() {
    var body = document.getElementById('titles-body');
    var chev = document.getElementById('titles-chevron');
    if (body.style.display === 'none') {
      body.style.display = '';
      chev.style.transform = 'rotate(180deg)';
    } else {
      body.style.display = 'none';
      chev.style.transform = '';
    }
  });

  /* ── History (AJAX, collapsible) ── */
  var histLoaded = false;
  document.getElementById('hist-toggle').addEventListener('click', function() {
    var content = document.getElementById('hist-content');
    var chevron = document.getElementById('hist-chevron');
    var visible = content.style.display !== 'none';
    content.style.display = visible ? 'none' : '';
    chevron.style.transform = visible ? '' : 'rotate(180deg)';
    if (!visible && !histLoaded && currentId) {
      histLoaded = true;
      loadHistory(currentId);
    }
  });

  function loadHistory(movieId) {
    var loading  = document.getElementById('hist-loading');
    var timeline = document.getElementById('hist-timeline');
    var empty    = document.getElementById('hist-empty');
    loading.style.display  = '';
    timeline.style.display = 'none';
    timeline.innerHTML     = '';
    empty.style.display    = 'none';

    ajaxGet('/medias/films/' + movieId + '/history')
    .then(function (items) {
      loading.style.display = 'none';
      if (!items.length) { empty.style.display = ''; return; }

      var evLabel = {
        grabbed: 'Capturé',
        downloadFolderImported: 'Importé',
        downloadFailed: 'Échec téléchargement',
        movieFileDeleted: 'Fichier supprimé',
        movieImported: 'Importé',
        movieFileRenamed: 'Renommé',
      };

      items.slice(0, 15).forEach(function (item) {
        var evType  = item.eventType || '';
        var date    = item.date ? new Date(item.date).toLocaleDateString('fr-FR') + ' ' + new Date(item.date).toLocaleTimeString('fr-FR', {hour:'2-digit',minute:'2-digit'}) : '—';
        var quality = (item.quality && item.quality.quality) ? item.quality.quality.name : '';
        var source  = (item.data && item.data.releaseTitle) ? item.data.releaseTitle : ((item.data && item.data.importedPath) ? item.data.importedPath : '');
        var lbl     = evLabel[evType] || evType;

        var div = document.createElement('div');
        div.className = 'timeline-event ev-' + evType;
        div.innerHTML =
          '<div class="d-flex justify-content-between align-items-start">' +
            '<div>' +
              '<span class="fw-medium small">' + esc(lbl) + '</span>' +
              (quality ? ' <span class="badge bg-blue-lt ms-1" style="font-size:.65rem">' + esc(quality) + '</span>' : '') +
              (source ? '<div class="text-muted small text-truncate" style="max-width:400px;font-size:.7rem" title="' + esc(source) + '">' + esc(source) + '</div>' : '') +
            '</div>' +
            '<span class="text-muted small text-nowrap ms-2" style="font-size:.7rem">' + date + '</span>' +
          '</div>';
        timeline.appendChild(div);
      });
      timeline.style.display = '';
    })
    .catch(function () {
      loading.style.display = 'none';
      empty.style.display = '';
    });
  }

  /* ══════════════════════════════════════════════════════════════════════════
     Search with step feedback
     ══════════════════════════════════════════════════════════════════════════ */
  function showSearchFeedback(text, type, showSpinner) {
    var el   = document.getElementById('search-feedback');
    var spin = document.getElementById('search-spinner');
    var txt  = document.getElementById('search-feedback-text');
    el.style.display = '';
    el.className = 'alert alert-' + (type || 'info') + ' mb-3';
    txt.textContent = text;
    spin.style.display = showSpinner ? '' : 'none';
  }

  function hideSearchFeedback() {
    document.getElementById('search-feedback').style.display = 'none';
  }

  function stopPoll() {
    if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
  }

  function refreshMonitorBtn() {
    var icon = document.getElementById('monitor-icon');
    var btn = document.getElementById('btn-monitor');
    var label = document.getElementById('btn-monitor-label');
    if (currentMonitored) {
      icon.setAttribute('fill', 'currentColor');
      icon.setAttribute('stroke', 'currentColor');
      btn.className = 'btn btn-sm btn-warning d-flex align-items-center gap-1';
      label.textContent = 'Ne plus suivre';
    } else {
      icon.setAttribute('fill', 'none');
      icon.setAttribute('stroke', 'currentColor');
      btn.className = 'btn btn-sm btn-success d-flex align-items-center gap-1';
      label.textContent = 'Suivre';
    }
    btn.style.filter = 'drop-shadow(0 1px 4px rgba(0,0,0,.5))';
    btn.style.fontSize = '.8rem';
  }

  /* ── Search button ── */
  var INDEXER_COUNT = {{ indexerCount }};
  var SEARCH_ICON = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg> Rechercher';

  document.getElementById('btn-search').addEventListener('click', function () {
    if (!currentId) return;
    document.getElementById('search-feedback').style.display = 'none';
    var btn = this;
    var movieTitle = currentMovie ? currentMovie.title : 'Film';
    stopPoll();

    // Étape 1 : lancement
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Lancement...';
    showSearchFeedback('🔍 Lancement de la recherche pour "' + movieTitle + '"...', 'info', true);

    ajaxPost('/medias/films/' + currentId + '/search')
    .then(function (data) {
      if (!data.ok || !data.cmdId) {
        btn.disabled = false;
        btn.innerHTML = SEARCH_ICON;
        showSearchFeedback('❌ Impossible de lancer la recherche — vérifiez que le film est bien dans Radarr', 'danger', false);
        return;
      }

      // Étape 2 : interrogation des indexeurs
      var idxMsg = INDEXER_COUNT > 0
        ? '📡 Interrogation de ' + INDEXER_COUNT + ' indexeur' + (INDEXER_COUNT > 1 ? 's' : '') + '...'
        : '📡 Interrogation des indexeurs...';
      showSearchFeedback(idxMsg, 'info', true);
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Indexeurs...';
      var pollCount = 0;

      pollTimer = setInterval(function () {
        pollCount++;
        ajaxGet('/medias/films/command/' + data.cmdId)
        .then(function (cmd) {
          var st = (cmd.status || '').toLowerCase();

          if (st === 'completed') {
            stopPoll();
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Vérification...';
            showSearchFeedback('📋 Recherche terminée — vérification des résultats...', 'info', true);

            // Étape 3 : vérifier la queue et l'historique pour le résultat
            Promise.all([
              ajaxGet('/medias/films/' + currentId + '/history'),
              ajaxGet('/medias/films/queue')
            ]).then(function (results) {
              var history = results[0] || [];
              var queue = results[1] || {};
              var queueRecords = (queue.records || queue || []);

              // Chercher si un grab récent (< 2 min) existe dans l'historique
              var now = new Date();
              var recentGrabs = (Array.isArray(history) ? history : []).filter(function(h) {
                if (h.eventType !== 'grabbed') return false;
                var d = new Date(h.date);
                return (now - d) < 120000;
              });

              // Chercher dans la queue
              var inQueue = (Array.isArray(queueRecords) ? queueRecords : []).filter(function(q) {
                return q.movieId === currentId;
              });

              btn.disabled = false;
              btn.innerHTML = SEARCH_ICON;

              if (inQueue.length > 0) {
                var q = inQueue[0];
                var dlStatus = q.status || 'downloading';
                var dlTitle = q.title || '';
                showSearchFeedback('✅ Téléchargement en cours : "' + dlTitle + '" — statut : ' + dlStatus, 'success', false);
              } else if (recentGrabs.length > 0) {
                var g = recentGrabs[0];
                var src = (g.data || {}).indexer || 'indexeur inconnu';
                showSearchFeedback('✅ Torrent capturé via ' + src + ' — en attente de téléchargement', 'success', false);
              } else {
                // Recherche normale n'a rien trouvé — tenter via recherche interactive
                showSearchFeedback('🔍 Recherche auto sans résultat — interrogation directe des indexeurs...', 'info', true);
                var releaseTimer = 0;
                var releaseCountdown = setInterval(function() {
                  releaseTimer++;
                  var msgs = [
                    '📡 Connexion aux indexeurs...',
                    '📡 Interrogation de ' + INDEXER_COUNT + ' indexeur' + (INDEXER_COUNT > 1 ? 's' : '') + '...',
                    '🔍 Recherche de torrents en cours...',
                    '🔍 Analyse des résultats...',
                  ];
                  var msgIdx = Math.min(Math.floor(releaseTimer / 8), msgs.length - 1);
                  showSearchFeedback(msgs[msgIdx] + ' (' + releaseTimer + 's)', 'info', true);
                }, 1000);

                ajaxGet('/medias/films/' + currentId + '/releases')
                .then(function(releases) {
                  clearInterval(releaseCountdown);
                  var approved = (releases || []).filter(function(r) { return r.approved; });
                  var total = (releases || []).length;

                  if (approved.length > 0) {
                    showSearchFeedback('📥 ' + total + ' résultat(s) trouvé(s), ' + approved.length + ' valide(s) — grab du meilleur...', 'info', true);
                    var best = approved[0];
                    ajaxPost('/medias/films/' + currentId + '/grab', { guid: best.guid, indexerId: best.indexerId })
                    .then(function(gd) {
                      if (gd.ok) {
                        showSearchFeedback('✅ Téléchargement lancé via ' + best.indexer + ' : ' + best.title.substring(0, 50), 'success', false);
                      } else {
                        showSearchFeedback('⚠️ ' + approved.length + ' torrent(s) trouvé(s) mais grab échoué : ' + (gd.error || '?') + '. Utilisez la recherche interactive pour choisir manuellement.', 'warning', false);
                      }
                      setTimeout(hideSearchFeedback, 10000);
                    }).catch(function() {
                      showSearchFeedback('⚠️ Erreur réseau lors du grab. Utilisez la recherche interactive.', 'warning', false);
                      setTimeout(hideSearchFeedback, 8000);
                    });
                  } else if (total > 0) {
                    showSearchFeedback('⚠️ ' + total + ' résultat(s) trouvé(s) mais aucun ne correspond au profil qualité. Utilisez la recherche interactive pour voir les détails.', 'warning', false);
                    setTimeout(hideSearchFeedback, 10000);
                  } else {
                    showSearchFeedback('⚠️ Aucun torrent trouvé sur les indexeurs pour ce film.', 'warning', false);
                    setTimeout(hideSearchFeedback, 8000);
                  }
                }).catch(function() {
                  clearInterval(releaseCountdown);
                  showSearchFeedback('⚠️ Timeout des indexeurs. Réessayez ou utilisez la recherche interactive.', 'warning', false);
                  setTimeout(hideSearchFeedback, 8000);
                });
              }
            }).catch(function() {
              btn.disabled = false;
              btn.innerHTML = SEARCH_ICON;
              showSearchFeedback('✅ Recherche terminée', 'success', false);
              setTimeout(hideSearchFeedback, 5000);
            });

          } else if (st === 'failed') {
            stopPoll();
            btn.disabled = false;
            btn.innerHTML = SEARCH_ICON;
            var errMsg = cmd.message || 'Erreur inconnue';
            showSearchFeedback('❌ Recherche échouée : ' + errMsg, 'danger', false);
            setTimeout(hideSearchFeedback, 8000);
          } else {
            // En cours — messages progressifs
            var dots = '.'.repeat((pollCount % 3) + 1);
            var elapsed = pollCount * 3;
            var msg = '📡 Interrogation de ' + INDEXER_COUNT + ' indexeur' + (INDEXER_COUNT > 1 ? 's' : '') + dots;
            if (elapsed >= 10) msg += ' (' + elapsed + 's)';
            showSearchFeedback(msg, 'info', true);
          }
        });
      }, 3000);
    })
    .catch(function () {
      btn.disabled = false;
      btn.innerHTML = SEARCH_ICON;
      showSearchFeedback('❌ Erreur réseau — impossible de contacter Radarr', 'danger', false);
    });
  });

  /* ── Interactive search ── */
  document.getElementById('btn-interactive').addEventListener('click', function () {
    if (!currentId) return;
    document.getElementById('search-feedback').style.display = 'none';
    var area      = document.getElementById('releases-area');
    var loading   = document.getElementById('releases-loading');
    var tableWrap = document.getElementById('releases-table-wrap');
    var empty     = document.getElementById('releases-empty');
    var tbody     = document.getElementById('releases-tbody');

    area.style.display      = '';
    loading.style.display   = '';
    tableWrap.style.display = 'none';
    empty.style.display     = 'none';
    tbody.innerHTML         = '';

    ajaxGet('/medias/films/' + currentId + '/releases')
    .then(function (releases) {
      loading.style.display = 'none';
      if (!releases.length) { empty.style.display = ''; return; }

      currentReleases = releases;
      renderReleases(releases, tbody);
      tableWrap.style.display = '';
    })
    .catch(function () {
      loading.innerHTML = '<span class="text-danger">Erreur lors du chargement (timeout ou indexeurs indisponibles).</span>';
    });
