        {# Formulaire d'ajout (visible après sélection) — AU-DESSUS des résultats #}
        <div id="add-film-form" style="display:none" class="mb-3 p-3 border border-primary rounded" style="background:var(--tblr-bg-surface-secondary)">
          <h5 id="add-film-form-title" class="mb-3"></h5>
          <div class="row g-2">
