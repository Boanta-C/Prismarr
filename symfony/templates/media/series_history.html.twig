{% extends 'base.html.twig' %}

{% block title %}Historique séries — IH-ARGOS{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Historique séries</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        {% include 'media/_sonarr_nav.html.twig' ignore missing %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% set records = history.records ?? [] %}

<div class="card">
  <div class="table-responsive">
    <table class="table table-vcenter table-hover card-table mb-0" style="font-size:.82rem;">
      <thead>
        <tr>
          <th>Série</th>
          <th>Épisode</th>
          <th>Action</th>
          <th>Source</th>
          <th>Qualité</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        {% set eventLabels = {grabbed: 'Téléchargé', downloadFolderImported: 'Importé', episodeFileDeleted: 'Supprimé', episodeFileRenamed: 'Renommé', downloadFailed: 'Échoué', seriesFolderImported: 'Importé (dossier)'} %}
        {% set eventColors = {grabbed: 'success', downloadFolderImported: 'primary', episodeFileDeleted: 'danger', episodeFileRenamed: 'secondary', downloadFailed: 'danger', seriesFolderImported: 'primary'} %}
        {% for h in records %}
        <tr>
          <td class="fw-medium">{{ h.series.title ?? '—' }}</td>
          <td>
            {% if h.episode %}
              <span class="badge bg-secondary-lt">S{{ '%02d'|format(h.episode.seasonNumber ?? 0) }}E{{ '%02d'|format(h.episode.episodeNumber ?? 0) }}</span>
            {% else %}—{% endif %}
          </td>
          <td><span class="badge bg-{{ eventColors[h.eventType] ?? 'secondary' }}-lt">{{ eventLabels[h.eventType] ?? h.eventType }}</span></td>
          <td class="text-muted text-truncate" style="max-width:250px;" title="{{ h.sourceTitle ?? '' }}">{{ h.sourceTitle ?? '—' }}</td>
          <td>
            {% if h.quality and h.quality.quality %}
              <span class="badge bg-blue-lt">{{ h.quality.quality.name }}</span>
            {% else %}—{% endif %}
          </td>
          <td class="text-muted">{{ h.date ? h.date|date('d/m/Y H:i', 'Europe/Paris') : '—' }}</td>
        </tr>
        {% else %}
        <tr><td colspan="6" class="text-center text-muted py-4">Aucun historique.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{% if history.totalRecords is defined and history.totalRecords > 50 %}
<div class="d-flex justify-content-center gap-2 mt-3">
  {% if page > 1 %}<a href="?page={{ page - 1 }}" class="btn btn-sm btn-outline-secondary">← Précédent</a>{% endif %}
  <span class="text-muted small align-self-center">Page {{ page }} / {{ (history.totalRecords / 50)|round(0, 'ceil') }}</span>
  {% if page * 50 < history.totalRecords %}<a href="?page={{ page + 1 }}" class="btn btn-sm btn-outline-secondary">Suivant →</a>{% endif %}
</div>
{% endif %}

</div>
</div>
{% endblock %}
