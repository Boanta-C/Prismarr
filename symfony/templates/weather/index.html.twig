{% extends 'base.html.twig' %}

{% block title %}Météo {{ location }} — IH-ARGOS{% endblock %}
{% block page_title %}Météo — {{ location }}{% endblock %}
{% block head_meta %}<meta name="turbo-visit-control" content="reload">{% endblock %}

{% block stylesheets %}
<style>
/* ── Transparent UNIQUEMENT quand .wp-bg est dans le DOM ── */
body:has(.wp-bg),
body:has(.wp-bg) .page,
body:has(.wp-bg) .page-wrapper,
body:has(.wp-bg) .page-body { background-color: transparent !important; }

/* ── Page-wrapper au-dessus de la vidéo ── */
body:has(.wp-bg) .page-wrapper { position: relative; z-index: 2; }

/* ── Le header respecte le thème utilisateur — pas de forçage ── */

/* toggle thème visible sur météo (le header est générique maintenant) */

/* ── Sidebar mobile doit rester au-dessus de la vidéo ── */
body:has(.wp-bg) .navbar-vertical { z-index: 1060 !important; }
body:has(.wp-bg) .navbar-vertical.collapse:not(.show) { display: none; }
@media (max-width: 991px) {
  body:has(.wp-bg) .navbar-vertical.show { position: fixed; top: 0; left: 0; bottom: 0; z-index: 1060; background: var(--tblr-bg-surface) !important; }
}

/* ── Météo : garder le page-header avec un fond adapté à la vidéo ── */
body:has(.wp-bg) .page-header { margin-bottom: 1rem !important; }

/* ══════════════════════════════════════════════════════════════
   FOND PLEINE PAGE — vidéo MP4 en boucle
══════════════════════════════════════════════════════════════ */
.wp-bg {
    position: fixed;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
}
.wp-bg video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: blur(3px);
    transform: scale(1.08);
}
/* Fallback gradient si la vidéo n'est pas encore disponible */
.wp-bg-fallback {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #050e1c 100%);
}

/* ══════════════════════════════════════════════════════════════
   GLASS CARDS
══════════════════════════════════════════════════════════════ */
.wx-content { position: relative; z-index: 2; }

body:has(.wp-bg) .wx-content .card,
body:has(.wp-bg) .wx-content .card-body {
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
}
body:has(.wp-bg) .wx-content .card {
    border-color: rgba(255,255,255,.09) !important;
    box-shadow: 0 4px 24px rgba(0,0,0,.5) !important;
}
body:has(.wp-bg) .wx-content .card-header {
    border-color: rgba(255,255,255,.09) !important;
}

/* ── Mode clair sur fond vidéo ── */
:root[data-bs-theme="light"] .wx-content .card {
    background: rgba(255,255,255,.92) !important;
    border-color: rgba(0,0,0,.12) !important;
    box-shadow: 0 2px 12px rgba(0,0,0,.12) !important;
}
:root[data-bs-theme="light"] .wx-content .card-header { border-color: rgba(0,0,0,.1) !important; background: rgba(0,0,0,.02) !important; }
:root[data-bs-theme="light"] .wx-content .card-title,
:root[data-bs-theme="light"] .wx-content .card h3,
:root[data-bs-theme="light"] .wx-content .card h4 { color: #1a1a2e !important; }
:root[data-bs-theme="light"] .wx-content .card .text-secondary,
:root[data-bs-theme="light"] .wx-content .card .text-muted { color: #5a5a6e !important; }
:root[data-bs-theme="light"] .wx-content .card .small,
:root[data-bs-theme="light"] .wx-content .card .fw-bold,
:root[data-bs-theme="light"] .wx-content .card .fw-medium,
:root[data-bs-theme="light"] .wx-content .card td,
:root[data-bs-theme="light"] .wx-content .card th,
:root[data-bs-theme="light"] .wx-content .card span,
:root[data-bs-theme="light"] .wx-content .card div { color: #2a2a3e !important; }
:root[data-bs-theme="light"] .wx-content .card .badge { color: inherit !important; }
:root[data-bs-theme="light"] .wx-content .dlist-row { color: #2a2a3e !important; border-color: rgba(0,0,0,.06) !important; }
:root[data-bs-theme="light"] .wx-content .dlist-row:hover { background: rgba(99,102,241,.06) !important; }
:root[data-bs-theme="light"] .wx-content .dlist-row.active { background: rgba(99,102,241,.12) !important; border-left-color: #6366f1 !important; }
:root[data-bs-theme="light"] .wx-content .days-list { background: rgba(248,248,252,.96) !important; border-color: rgba(0,0,0,.1) !important; }
:root[data-bs-theme="light"] .wx-content .wx-forecast-wrap { background: rgba(255,255,255,.92) !important; }
:root[data-bs-theme="light"] .wx-content .hourly-col { background: rgba(255,255,255,.95) !important; }
:root[data-bs-theme="light"] .wx-content .alert { background: rgba(255,255,255,.9) !important; color: #333 !important; }
:root[data-bs-theme="light"] .wx-content .progress { background: rgba(0,0,0,.08) !important; }
/* Éléments hors cards (sur la vidéo) — garder en blanc */
:root[data-bs-theme="light"] .wx-content > .mb-3,
:root[data-bs-theme="light"] .wx-content > .d-flex { color: #fff !important; }

/* ══════════════════════════════════════════════════════════════
   HERO
══════════════════════════════════════════════════════════════ */
.weather-hero {
    border-radius: .75rem;
    border: 1px solid rgba(255,255,255,.1);
    background: rgba(8,14,28,.65);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    padding: 1rem 1.25rem;
    position: relative;
    z-index: 2;
}
.hero-topbar {
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    padding-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,.09); margin-bottom: 1rem;
}
@media (max-width: 575px) {
  .hero-topbar { gap: .5rem; justify-content: center; text-align: center; }
  .hero-topbar > .flex-grow-1 { text-align: center; }
  .weather-hero { padding: .75rem !important; text-align: center; }
  .hero-badges { gap: .2rem; justify-content: center; }
  .hero-badge { font-size: .6rem; padding: .15rem .4rem; }
  .hero-temp { text-align: center; }
}
@media (max-width: 767px) {
  .moon-canvas-wrap { flex-direction: column; text-align: center; align-items: center; }
  #moon-canvas { width: 80px !important; height: 80px !important; }
  #sun-arc-canvas { height: 100px !important; }
  .metric-grid { grid-template-columns: repeat(2, 1fr) !important; }
  .metric-tile { justify-content: center; text-align: center; flex-direction: column; gap: .3rem; }
  .wx-content .card-body { padding: .5rem !important; }
  #hero-next-rows { justify-content: center !important; }
  .sunrise-row { flex-wrap: wrap; gap: .5rem; }
}
.hero-topbar > .flex-grow-1 { min-width: 0; }
.hero-temp   { font-size: clamp(2.5rem, 8vw, 5rem); font-weight: 800; line-height: 1; letter-spacing: -.05em; color: #fff; }
.hero-icon   { font-size: clamp(2.5rem, 7vw, 4.5rem); line-height: 1; filter: drop-shadow(0 0 20px rgba(255,255,255,.25)); }
.hero-label  { font-size: 1.2rem; font-weight: 500; color: rgba(255,255,255,.9); }
.hero-feels  { font-size: .9rem; color: rgba(255,255,255,.5); margin-top: .2rem; }
.hero-badges { display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.7rem; }
.hero-badge  { font-size:.72rem;padding:.22rem .6rem;border-radius:.35rem;background:rgba(255,255,255,.09);color:rgba(255,255,255,.8);border:1px solid rgba(255,255,255,.12);white-space:nowrap; }

/* ══════════════════════════════════════════════════════════════
   METRIC GRID
══════════════════════════════════════════════════════════════ */
.metric-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border: 1px solid rgba(255,255,255,.09); border-radius: .5rem; overflow: hidden;
}
@media (max-width: 767px) { .metric-grid { grid-template-columns: repeat(2, 1fr); } }
.metric-tile {
    padding: .85rem 1rem; display:flex; align-items:center; gap:.7rem;
    border-right: 1px solid rgba(255,255,255,.07);
    border-bottom: 1px solid rgba(255,255,255,.07);
    transition: background .12s;
}
.metric-tile:hover { background: rgba(255,255,255,.04); }
.metric-tile:nth-child(4n)        { border-right: none; }
.metric-tile:nth-last-child(-n+4) { border-bottom: none; }
@media (max-width: 767px) {
    .metric-tile:nth-child(4n)    { border-right: 1px solid rgba(255,255,255,.07); }
    .metric-tile:nth-child(2n)    { border-right: none; }
    .metric-tile:nth-last-child(-n+4) { border-bottom: 1px solid rgba(255,255,255,.07); }
    .metric-tile:nth-last-child(-n+2) { border-bottom: none; }
}
.mt-icon { width:34px;height:34px;border-radius:.45rem;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
.mt-icon svg { width:18px;height:18px;stroke-width:1.7; }
.mt-lbl { font-size:.6rem;color:var(--tblr-muted);text-transform:uppercase;letter-spacing:.07em;line-height:1.1; }
.mt-val { font-size:.95rem;font-weight:700;line-height:1.3; }
.mt-sub { font-size:.68rem;color:var(--tblr-muted);line-height:1.2; }

/* ══════════════════════════════════════════════════════════════
   LUNE (Canvas)
══════════════════════════════════════════════════════════════ */
.moon-canvas-wrap { display:flex;align-items:center;gap:1.25rem;padding-bottom:1.1rem;margin-bottom:1.1rem;border-bottom:1px solid rgba(255,255,255,.09); }
#moon-canvas { filter: drop-shadow(0 0 18px rgba(200,165,70,.3)); border-radius:50%; }
.moon-bar  { height:5px;border-radius:3px;background:rgba(255,255,255,.1);overflow:hidden;margin-top:.4rem; }
.moon-fill { height:100%;background:linear-gradient(90deg,#d4a843,#fde047);border-radius:3px; }
.moon-row  { display:flex;align-items:center;gap:.7rem;padding:.45rem 0;border-bottom:1px solid rgba(255,255,255,.07); }
.moon-row:last-child { border-bottom:none; }
.moon-em   { font-size:1.3rem;min-width:2rem;text-align:center; }
.sunrise-row { display:flex;justify-content:space-around;text-align:center;padding-top:.8rem;margin-top:.8rem;border-top:1px solid rgba(255,255,255,.07); }

/* ══════════════════════════════════════════════════════════════
   FORECAST SPLIT CARD — jours (gauche) + horaires (droite)
══════════════════════════════════════════════════════════════ */
.wx-forecast-wrap { display:flex; min-height:400px; max-height:520px; overflow:hidden; }
@media (max-width:767px) {
  .wx-forecast-wrap { flex-direction:column; min-height:auto; max-height:none; overflow:visible; }
  .wx-forecast-wrap .days-list { max-height:160px; overflow-y:auto; }
  .wx-forecast-wrap .wx-hourly-col { height:350px; min-height:350px; }
}

/* Colonne gauche — liste des 14 jours */
.days-list {
    width:220px; flex-shrink:0;
    border-right:1px solid rgba(255,255,255,.08);
    overflow-y:auto; scrollbar-width:thin;
}
@media (max-width:767px) { .days-list { width:100%; border-right:none; border-bottom:1px solid rgba(255,255,255,.08); max-height:180px; } }
.dlist-row {
    display:flex; align-items:center; gap:.4rem;
    padding:.48rem .6rem;
    cursor:pointer;
    border-bottom:1px solid rgba(255,255,255,.05);
    border-left:3px solid transparent;
    transition:background .1s;
    user-select:none;
}
.dlist-row:hover  { background:rgba(255,255,255,.05); }
.dlist-row.active { background:rgba(255,255,255,.08); }
.dlist-row.type-storm        { border-left-color:#f59e0b; }
.dlist-row.type-heavy_rain   { border-left-color:#3b82f6; }
.dlist-row.type-rain         { border-left-color:#60a5fa; }
.dlist-row.type-snow         { border-left-color:#a5f3fc; }
.dlist-row.type-fog          { border-left-color:#64748b; }
.dlist-row.type-cloudy       { border-left-color:#475569; }
.dlist-row.type-partly_cloudy{ border-left-color:#fbbf24; }
.dlist-row.type-clear        { border-left-color:#fde047; }
.dlist-meta  { flex:1; min-width:0; }
.dlist-name  { font-size:.74rem; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.dlist-date  { font-size:.58rem; color:var(--tblr-muted); }
.dlist-emoji { font-size:1.1rem; flex-shrink:0; line-height:1; }
.dlist-temps { font-size:.72rem; white-space:nowrap; flex-shrink:0; }
.dlist-temps .mx { font-weight:700; }
.dlist-temps .mn { color:var(--tblr-muted); font-size:.63rem; }
.dlist-rain  { font-size:.6rem; color:#60a5fa; white-space:nowrap; flex-shrink:0; }

/* Colonne droite — prévisions horaires */
.wx-hourly-col {
    flex:1; display:flex; flex-direction:column; min-width:0; overflow:hidden;
}
@media (max-width:767px) { .wx-hourly-col { height:360px; } }
.wx-hourly-header {
    padding:.55rem .9rem;
    border-bottom:1px solid rgba(255,255,255,.08);
    display:flex; align-items:baseline; gap:.45rem;
    flex-shrink:0;
}
.wx-hourly-strip { flex:1; overflow-y:auto; scrollbar-width:thin; }

/* ══════════════════════════════════════════════════════════════
   GRAPHIQUES
══════════════════════════════════════════════════════════════ */
.chart-header {
    display:flex;align-items:center;justify-content:space-between;
    padding-bottom:.75rem;border-bottom:1px solid rgba(255,255,255,.07);margin-bottom:1rem;
}
.chart-day-label { font-size:1rem;font-weight:600; }
.chart-day-sub   { font-size:.78rem;color:var(--tblr-muted); }

.charts-row { display:grid;grid-template-columns:1fr 1fr;gap:1rem; }
@media (max-width:767px) { .charts-row { grid-template-columns:1fr; } }
.chart-panel {
    background: rgba(255,255,255,.025);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: .5rem;
    padding: .85rem 1rem 1rem;
}
.chart-panel-label {
    font-size:.65rem;font-weight:700;text-transform:uppercase;
    letter-spacing:.08em;color:var(--tblr-muted);margin-bottom:.6rem;
    display:flex;align-items:center;gap:.4rem;
}
.chart-wrap { position:relative;height:210px; }

/* ══════════════════════════════════════════════════════════════
   BOUSSOLE VENT
══════════════════════════════════════════════════════════════ */
.wind-section {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255,255,255,.09);
    display: flex;
    align-items: center;
    gap: 1.75rem;
    flex-wrap: wrap;
}
@media (max-width: 575px) {
  .wind-section { justify-content: center; text-align: center; flex-direction: column; gap: 1rem; }
  .wind-stats { min-width: auto; }
}
#compass-canvas { flex-shrink: 0; filter: drop-shadow(0 0 12px rgba(96,165,250,.15)); }
.wind-stats { flex: 1; min-width: 160px; }
.wind-speed-big { font-size: 3rem; font-weight: 800; line-height: 1; color: #fff; }
.wind-speed-unit { font-size: .9rem; color: var(--tblr-muted); margin-left: .25rem; }
.wind-dir-badge {
    display: inline-flex; align-items: center; gap: .35rem;
    font-size: .75rem; font-weight: 600;
    padding: .2rem .55rem; border-radius: .3rem;
    background: rgba(96,165,250,.12); color: #60a5fa;
    border: 1px solid rgba(96,165,250,.2); margin-top: .35rem;
}
.wind-bars { margin-top: .85rem; display: flex; flex-direction: column; gap: .38rem; }
.wb-row    { display: flex; align-items: center; gap: .5rem; }
.wb-lbl    { font-size: .6rem; color: var(--tblr-muted); text-transform: uppercase; letter-spacing: .05em; min-width: 42px; }
.wb-track  { flex: 1; height: 5px; border-radius: 3px; background: rgba(255,255,255,.07); overflow: hidden; }
.wb-fill   { height: 100%; border-radius: 3px; transition: width .4s ease; }
.wb-blue   { background: linear-gradient(90deg, #38bdf8, #60a5fa); }
.wb-amber  { background: linear-gradient(90deg, #fbbf24, #f59e0b); }
.wb-red    { background: linear-gradient(90deg, #f97316, #ef4444); }
.wb-val    { font-size: .7rem; font-weight: 700; min-width: 28px; text-align: right; color: rgba(255,255,255,.7); }

/* ══════════════════════════════════════════════════════════════
   STORM / EVENTS / STATS
══════════════════════════════════════════════════════════════ */
.storm-row { display:flex;align-items:center;gap:.75rem;padding:.6rem 0;border-bottom:1px solid rgba(255,255,255,.06); }
.storm-row:last-child { border-bottom:none; }
.storm-time { font-weight:600;font-size:.85rem;min-width:95px; }
.storm-date-sub { font-size:.68rem;color:var(--tblr-muted);margin-top:.1rem; }
.storm-metrics { font-size:.8rem; }
.storm-sub { font-size:.72rem;color:var(--tblr-muted);margin-top:.1rem; }
.ev-row { display:flex;align-items:center;gap:.75rem;padding:.5rem 0;border-bottom:1px solid rgba(255,255,255,.06); }
.ev-row:last-child { border-bottom:none; }
.ev-name { min-width:110px;font-weight:500;font-size:.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }

.stat-grid { display:grid;grid-template-columns:repeat(4,1fr);border:1px solid rgba(255,255,255,.07);border-radius:.5rem;overflow:hidden; }
@media (max-width:767px) { .stat-grid { grid-template-columns:repeat(2,1fr); } }
.stat-cell { padding:1rem .75rem;text-align:center;border-right:1px solid rgba(255,255,255,.07);border-bottom:1px solid rgba(255,255,255,.07); }
.stat-cell:nth-child(4n)        { border-right:none; }
.stat-cell:nth-last-child(-n+4) { border-bottom:none; }
@media (max-width:767px) {
    .stat-cell:nth-child(4n)    { border-right:1px solid rgba(255,255,255,.07); }
    .stat-cell:nth-child(2n)    { border-right:none; }
    .stat-cell:nth-last-child(-n+4) { border-bottom:1px solid rgba(255,255,255,.07); }
    .stat-cell:nth-last-child(-n+2) { border-bottom:none; }
}
.sc-icon { font-size:1.5rem;display:block;margin-bottom:.3rem; }
.sc-val  { font-size:1.3rem;font-weight:800;line-height:1; }
.sc-lbl  { font-size:.62rem;color:var(--tblr-muted);margin-top:.25rem;text-transform:uppercase;letter-spacing:.05em; }

/* ══════════════════════════════════════════════════════════════
   ÉVÉNEMENTS DANS WIND-SECTION
══════════════════════════════════════════════════════════════ */
.wx-events-side {
    flex: 1; min-width: 0;
    border-left: 1px solid rgba(255,255,255,.08);
    padding-left: 1rem;
    overflow-y: auto; max-height: 175px;
    scrollbar-width: thin;
}
.wx-events-side .ev-row { padding: .3rem 0; }

/* ══════════════════════════════════════════════════════════════
   CARDS COLLÉES — pas d'espace entre sections
══════════════════════════════════════════════════════════════ */
.wx-content > .card { margin-bottom: .5rem !important; }
.wx-content > .row { margin-bottom: .5rem; }

.storm-banner {
    background:linear-gradient(135deg,rgba(124,45,18,.75),rgba(87,32,12,.75));
    backdrop-filter:blur(12px);border:1px solid rgba(245,158,11,.4);
    border-radius:.5rem;padding:.9rem 1.25rem;display:flex;align-items:center;gap:1rem;
    animation:pulse-warn 2s infinite;margin-bottom:1rem;
}
@keyframes pulse-warn { 0%,100%{box-shadow:0 0 0 0 rgba(245,158,11,.25)} 50%{box-shadow:0 0 0 8px rgba(245,158,11,0)} }
</style>
{% endblock %}

{% block body %}

{# ══ Fond pleine page — vidéo MP4 en boucle ══ #}
{# Debug : ?wx=rain&night=1 pour forcer une condition #}
{% set debugWx   = app.request.query.get('wx') %}
{% set debugNight = app.request.query.get('night') == '1' %}
{% set wxType    = debugWx ?: (current ? current.type : 'clear') %}
{% set isDay     = debugWx ? not debugNight : (current and current.is_day) %}

{% set wpVideo = 'clear-night' %}
{% if wxType == 'clear' %}        {% set wpVideo = isDay ? 'clear-day'    : 'clear-night' %}
{% elseif wxType == 'partly_cloudy' %} {% set wpVideo = 'partly-cloudy' %}
{% elseif wxType == 'cloudy' %}   {% set wpVideo = 'cloudy' %}
{% elseif wxType == 'rain' %}     {% set wpVideo = 'rain' %}
{% elseif wxType == 'heavy_rain' %}{% set wpVideo = 'heavy-rain' %}
{% elseif wxType == 'storm' %}    {% set wpVideo = 'storm' %}
{% elseif wxType in ['snow','sleet'] %}{% set wpVideo = 'snow' %}
{% elseif wxType == 'fog' %}      {% set wpVideo = 'fog' %}
{% endif %}
<div class="wp-bg" aria-hidden="true">
  <div class="wp-bg-fallback"></div>
  <video autoplay muted loop playsinline disablepictureinpicture controlslist="nodownload nofullscreen noremoteplayback" preload="auto">
    <source src="{{ asset('img/weather/' ~ wpVideo ~ '.mp4') }}" type="video/mp4">
  </video>
</div>

{% if debugWx %}
<div style="position:fixed;bottom:1rem;left:50%;transform:translateX(-50%);z-index:9999;
            background:rgba(0,0,0,.85);border:1px solid rgba(255,255,255,.2);border-radius:.75rem;
            padding:.5rem .75rem;display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;backdrop-filter:blur(12px);">
  <span style="font-size:.7rem;color:rgba(255,255,255,.5);margin-right:.25rem">🎬 debug wx:</span>
  {% for cond in ['clear','partly_cloudy','cloudy','rain','heavy_rain','storm','snow','fog'] %}
    <a href="?wx={{ cond }}{{ debugNight ? '&night=1' : '' }}"
       style="font-size:.7rem;padding:.2rem .5rem;border-radius:.35rem;text-decoration:none;
              background:{{ wxType == cond ? 'rgba(99,102,241,.8)' : 'rgba(255,255,255,.08)' }};
              color:{{ wxType == cond ? '#fff' : 'rgba(255,255,255,.6)' }};border:1px solid rgba(255,255,255,.1);">
      {{ cond }}
    </a>
  {% endfor %}
  <span style="color:rgba(255,255,255,.2)">|</span>
  <a href="?wx={{ wxType }}" style="font-size:.7rem;padding:.2rem .5rem;border-radius:.35rem;text-decoration:none;
     background:{{ not debugNight ? 'rgba(251,191,36,.8)' : 'rgba(255,255,255,.08)' }};color:#fff;border:1px solid rgba(255,255,255,.1);">☀ jour</a>
  <a href="?wx={{ wxType }}&night=1" style="font-size:.7rem;padding:.2rem .5rem;border-radius:.35rem;text-decoration:none;
     background:{{ debugNight ? 'rgba(99,102,241,.8)' : 'rgba(255,255,255,.08)' }};color:#fff;border:1px solid rgba(255,255,255,.1);">🌙 nuit</a>
  <a href="{{ path('app_weather') }}" style="font-size:.7rem;padding:.2rem .5rem;border-radius:.35rem;text-decoration:none;
     background:rgba(239,68,68,.6);color:#fff;border:1px solid rgba(255,255,255,.1);">✕ quitter</a>
</div>
{% endif %}

<div class="wx-content py-3">

  {# ── Sous-titre infos ── #}
  <div class="mb-3">
    <div class="small" style="display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;color:rgba(255,255,255,.6)">
      <span>Open-Meteo · 14 jours</span>
      {% if fetched_ago is not null %}
      <span>· Dernière MAJ <strong id="last-maj-time" style="color:rgba(255,255,255,.65)">--:--</strong></span>
      {% endif %}
      <span>· Prochain <strong id="next-refresh-time" style="color:rgba(255,255,255,.65)">--:--</strong></span>
    </div>
  </div>

  {% if error %}
    <div class="alert alert-danger d-flex align-items-start gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0" style="margin-top:2px;"><path d="M12 9v4"/><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z"/><path d="M12 16h.01"/></svg>
      <div>
        <strong>API météo indisponible</strong>
        {% if error_reason is defined and error_reason %}
          <div class="small mt-1" style="opacity:.8;">{{ error_reason }}</div>
        {% endif %}
        <div class="small mt-1 text-secondary">Les données seront rechargées automatiquement dès que l'API sera de nouveau accessible.</div>
      </div>
    </div>
  {% else %}

  {# ── Bannière orage ── #}
  {% if storm_next_24h %}
    <div class="storm-banner">
      <span style="font-size:2.5rem">⛈️</span>
      <div>
        <div class="fw-bold text-warning fs-5">Orage dans les prochaines 24h !</div>
        {% if storm_hours|first %}<div class="text-muted small">{{ storm_hours|first.datetime|date('H\\h', 'Europe/Paris') }} — {{ storm_hours|first.label }} · Rafales {{ storm_hours|first.gusts }} km/h · {{ storm_hours|first.wind_dir }}</div>{% endif %}
      </div>
    </div>
  {% elseif storm_next_48h %}
    <div class="alert alert-warning d-flex align-items-center gap-3 mb-3" style="backdrop-filter:blur(10px)">
      <span style="font-size:1.75rem">⛈️</span>
      <div>
        <strong>Orage prévu dans les 48h</strong>
        {% if storm_hours|first %}<span class="ms-2 text-muted small">{{ storm_hours|first.datetime|date('D d/m H\\h', 'Europe/Paris') }} — Rafales {{ storm_hours|first.gusts }} km/h</span>{% endif %}
      </div>
    </div>
  {% endif %}

  {# ═══ ROW 3 : HERO + LUNE ═══ #}
  <div class="row g-2">

    {% if current and today %}
    <div class="col-lg-8">
      <div class="card h-100">
        <div class="card-header border-bottom d-flex align-items-center gap-2">
          <span style="font-size:1.6rem;line-height:1">{{ current.emoji }}</span>
          <h3 class="card-title mb-0 flex-grow-1">Aujourd'hui</h3>
          <span id="hero-current-time" style="font-size:1.1rem;font-weight:700;color:rgba(255,255,255,.75);font-variant-numeric:tabular-nums;letter-spacing:.03em">--:--</span>
        </div>
        <div class="card-body p-0">
        <div class="weather-hero" style="background:transparent;border:none;box-shadow:none;backdrop-filter:none;-webkit-backdrop-filter:none;border-radius:0">
        <div class="hero-topbar">
          <div class="hero-icon">{{ current.emoji }}</div>
          <div class="flex-grow-1">
            <div class="hero-temp">{{ current.temp }}°</div>
            <div class="hero-label">{{ current.label }}</div>
            <div class="hero-feels">Ressenti {{ current.feels_like }}° · {{ today.date_label }}</div>
            <div class="hero-badges">
              <span class="hero-badge">🌡️ {{ today.temp_max is not null ? today.temp_max|round ~ '° / ' ~ today.temp_min|round ~ '°' : '—' }}</span>
              {% if today.sunrise %}<span class="hero-badge">🌅 {{ today.sunrise|date('H:i') }} · 🌇 {{ today.sunset|date('H:i') }}</span>{% endif %}
              <span class="hero-badge">☀️ {{ today.sunshine_hours }}h soleil</span>
              {% if today.uv_max > 0 %}<span class="hero-badge" style="color:{{ current.uv_color }}">UV {{ today.uv_max }} · {{ current.uv_label }}</span>{% endif %}
            </div>
          </div>
        <div id="hero-next-hours" style="flex-shrink:0;display:flex;flex-direction:column;gap:.35rem;border-left:1px solid rgba(255,255,255,.1);padding-left:1.25rem;min-width:150px;align-self:center">
          <div style="font-size:.6rem;text-transform:uppercase;letter-spacing:.07em;color:rgba(255,255,255,.4);margin-bottom:.2rem">Prochaines heures</div>
          <div id="hero-next-rows"></div>
        </div>
        </div>

        <div class="metric-grid">

          <div class="metric-tile">
            <div class="mt-icon" style="background:rgba(96,165,250,.13)">
              <svg viewBox="0 0 24 24" fill="none" stroke="#60a5fa" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2s-6 7-6 11a6 6 0 0 0 12 0c0-4-6-11-6-11z"/></svg>
            </div>
            <div><div class="mt-lbl">Humidité</div><div class="mt-val">{{ current.humidity }}%</div><div class="mt-sub">Rosée {{ current.dew_point }}°C</div></div>
          </div>

          <div class="metric-tile">
            <div class="mt-icon" style="background:rgba(148,163,184,.1)">
              <svg viewBox="0 0 24 24" fill="none" stroke="#94a3b8" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>
            </div>
            <div>
              <div class="mt-lbl">Vent</div>
              <div class="mt-val"><span style="display:inline-block;transform:rotate({{ today.wind_dir }}deg)">↑</span> {{ today.wind_dir_label }} {{ current.wind }} km/h</div>
              <div class="mt-sub">Rafales {{ current.gusts }} km/h</div>
            </div>
          </div>

          <div class="metric-tile">
            <div class="mt-icon" style="background:rgba(168,85,247,.12)">
              <svg viewBox="0 0 24 24" fill="none" stroke="#a855f7" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 7v5l3 3"/></svg>
            </div>
            <div>
              <div class="mt-lbl">Pression</div>
              <div class="mt-val">{{ current.pressure }} hPa</div>
              <div class="mt-sub">{{ current.pressure > 1013 ? '⬆ Haute' : (current.pressure < 1000 ? '⬇ Basse' : '— Normale') }}</div>
            </div>
          </div>

          <div class="metric-tile">
            <div class="mt-icon" style="background:rgba(34,197,94,.1)">
              <svg viewBox="0 0 24 24" fill="none" stroke="#22c55e" xmlns="http://www.w3.org/2000/svg"><ellipse cx="12" cy="12" rx="10" ry="4"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <div>
              <div class="mt-lbl">Visibilité</div>
              <div class="mt-val">{{ current.visibility_km }} km</div>
              <div class="mt-sub">Nuages {{ current.cloud }}%</div>
            </div>
          </div>

          <div class="metric-tile">
            <div class="mt-icon" style="background:rgba(100,116,139,.12)">
              <svg viewBox="0 0 24 24" fill="none" stroke="#94a3b8" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
            </div>
            <div>
              <div class="mt-lbl">Couverture</div>
              <div class="mt-val">{{ current.cloud }}%</div>
              <div class="mt-sub">{% if current.cloud < 20 %}Dégagé{% elseif current.cloud < 50 %}Partiel{% elseif current.cloud < 80 %}Nuageux{% else %}Couvert{% endif %}</div>
            </div>
          </div>

          <div class="metric-tile">
            <div class="mt-icon" style="background:rgba(253,224,71,.1)">
              <svg viewBox="0 0 24 24" fill="none" stroke="{{ current.uv_color }}" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="4"/><path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            </div>
            <div>
              <div class="mt-lbl">UV Index</div>
              <div class="mt-val" style="color:{{ current.uv_color }}">{{ current.uv }}</div>
              <div class="mt-sub">{{ current.uv_label }}</div>
            </div>
          </div>

          <div class="metric-tile">
            <div class="mt-icon" style="background:rgba(59,130,246,.12)">
              <svg viewBox="0 0 24 24" fill="none" stroke="#3b82f6" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/><path stroke-linecap="round" d="M11 13v4M8 14.5l3 3 3-3"/></svg>
            </div>
            <div>
              <div class="mt-lbl">Précip. aujourd'hui</div>
              <div class="mt-val">{{ today.precip_sum }} mm</div>
              <div class="mt-sub">{{ today.precip_prob }}% prob · {{ today.precip_hours }}h</div>
            </div>
          </div>

          <div class="metric-tile">
            <div class="mt-icon" style="background:rgba(251,191,36,.1)">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fbbf24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2M9.6 4.6A2 2 0 1 1 11 8H2M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>
            </div>
            <div>
              <div class="mt-lbl">Rafales max</div>
              <div class="mt-val">{{ today.wind_gusts }} km/h</div>
              <div class="mt-sub">Moy. {{ today.wind_max }} · {{ today.wind_dir_label }}</div>
            </div>
          </div>

        </div>{# /metric-grid #}

        {# ── Boussole vent ── #}
        <div class="wind-section">
          <canvas id="compass-canvas" width="148" height="148"
                  data-dir="{{ current.wind_dir }}"
                  data-speed="{{ current.wind }}"
                  data-gusts="{{ current.gusts }}"></canvas>
          <div class="wind-stats">
            <div class="text-uppercase text-muted fw-semibold mb-1" style="font-size:.6rem;letter-spacing:.07em">Vent actuel</div>
            <div class="d-flex align-items-baseline gap-1">
              <span class="wind-speed-big">{{ current.wind }}</span>
              <span class="wind-speed-unit">km/h</span>
            </div>
            <div class="wind-dir-badge">
              <span style="display:inline-block;transform:rotate({{ current.wind_dir }}deg)">↑</span>
              {{ current.wind_dir_label }} — {{ current.wind_dir }}°
            </div>
            <div class="text-muted small mt-2">Rafales <strong class="text-warning">{{ current.gusts }} km/h</strong> · Max journée {{ today.wind_max }} km/h</div>
            <div class="wind-bars mt-2">
              {% set wmax = [today.wind_gusts, current.wind, today.wind_max, 1]|sort|last %}
              <div class="wb-row">
                <span class="wb-lbl">Actuel</span>
                <div class="wb-track"><div class="wb-fill wb-blue" style="width:{{ (current.wind / wmax * 100)|round }}%"></div></div>
                <span class="wb-val">{{ current.wind }}</span>
              </div>
              <div class="wb-row">
                <span class="wb-lbl">Max j.</span>
                <div class="wb-track"><div class="wb-fill wb-amber" style="width:{{ (today.wind_max / wmax * 100)|round }}%"></div></div>
                <span class="wb-val">{{ today.wind_max }}</span>
              </div>
              <div class="wb-row">
                <span class="wb-lbl">Rafales</span>
                <div class="wb-track"><div class="wb-fill wb-red" style="width:100%"></div></div>
                <span class="wb-val">{{ today.wind_gusts }}</span>
              </div>
            </div>
          </div>
          {# ── Événements météo — à droite de la boussole ── #}
          <div class="wx-events-side">
            <div class="text-uppercase text-muted fw-semibold mb-2" style="font-size:.58rem;letter-spacing:.07em">🌦️ Événements à venir</div>
            {% set notable = days|slice(1)|filter(d => d.type in ['storm','snow','heavy_rain','rain']) %}
            {% if notable is empty %}
              <div class="text-muted" style="font-size:.78rem;padding:.4rem 0">☀️ Pas de précipitations prévues</div>
            {% else %}
              {% for day in notable %}
              <div class="ev-row">
                <div class="ev-name" style="min-width:90px"><span style="font-size:1rem">{{ day.emoji }}</span> <span class="ms-1" style="font-size:.78rem">{{ day.date_label }}</span></div>
                <div class="flex-grow-1">
                  {% if day.type == 'storm' %}<span class="badge bg-warning-lt text-warning me-1">⛈️</span>
                  {% elseif day.type == 'snow' %}<span class="badge bg-info-lt text-info me-1">❄️</span>
                  {% elseif day.type == 'heavy_rain' %}<span class="badge bg-blue-lt text-blue me-1">🌧️+</span>
                  {% else %}<span class="badge bg-azure-lt text-azure me-1">🌦️</span>{% endif %}
                  <span class="text-muted" style="font-size:.7rem">{{ day.temp_max is not null ? day.temp_max|round ~ '°' : '' }}{% if day.precip_sum > 0 %} · {{ day.precip_sum }}mm{% endif %}</span>
                </div>
              </div>
              {% endfor %}
            {% endif %}
          </div>
        </div>

        </div>{# /weather-hero #}
        </div>{# /card-body #}
      </div>{# /card #}
    </div>
    {% endif %}

    {# ── Lune (Canvas 3D) ── #}
    {% if moon %}
    <div class="col-lg-4">
    <div class="card h-100">
        <div class="card-header border-bottom">
          <h3 class="card-title">🌕 Phase lunaire</h3>
        </div>
        <div class="card-body d-flex flex-column">
          <div class="moon-canvas-wrap">
            <canvas id="moon-canvas" data-phase="{{ moon.current_phase }}" style="width:110px;height:110px;border-radius:50%;flex-shrink:0"></canvas>
            <div class="flex-grow-1">
              <div class="fw-bold fs-5">{{ moon.current_label }}</div>
              <div class="text-muted small mb-2">Illumination {{ moon.illumination }}%</div>
              <div class="moon-bar"><div class="moon-fill" style="width:{{ moon.illumination }}%"></div></div>
            </div>
          </div>
          <div class="text-uppercase text-muted fw-semibold mb-2" style="font-size:.62rem;letter-spacing:.07em">Prochaines phases</div>
          {% for phase in moon.next %}
          <div class="moon-row">
            <div class="moon-em">{{ phase.emoji }}</div>
            <div class="flex-grow-1">
              <div class="fw-medium" style="font-size:.87rem">{{ phase.label }}</div>
              <div class="text-muted" style="font-size:.73rem">{{ phase.date|date('D d/m', 'Europe/Paris') }}</div>
            </div>
            <div>
              {% if phase.days_until <= 1 %}
                <span class="badge bg-warning-lt text-warning">{{ phase.days_until == 0 ? "Auj." : 'Demain' }}</span>
              {% elseif phase.days_until <= 3 %}
                <span class="badge bg-info-lt text-info">J−{{ phase.days_until }}</span>
              {% else %}
                <span class="text-muted" style="font-size:.77rem">{{ phase.days_until }} j</span>
              {% endif %}
            </div>
          </div>
          {% endfor %}
          {% if today and today.sunrise %}
          <div class="mt-auto">
            <canvas id="sun-arc-canvas"
                    data-sunrise="{{ today.sunrise|date('G') * 60 + today.sunrise|date('i') }}"
                    data-sunset="{{ today.sunset|date('G') * 60 + today.sunset|date('i') }}"
                    data-daylight="{{ today.daylight_hours }}"
                    style="width:100%;height:140px;display:block"></canvas>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
    {% endif %}

  </div>{# /row hero+lune #}

  {# ═══ PRÉVISIONS : sélection jours (gauche) + horaires (droite) ═══ #}
  <div class="card mb-3">
    <div class="card-header border-bottom">
      <h3 class="card-title">📅 Prévisions 14 jours</h3>
      <div class="card-options text-muted small" id="hourly-day-label-header">{{ today ? today.date_label : '' }}</div>
    </div>
    <div class="wx-forecast-wrap">

      {# ── Colonne gauche : 14 jours ── #}
      <div class="days-list">
        {% for day in days %}
        <div class="dlist-row type-{{ day.type }}{% if loop.first %} active{% endif %}"
             data-day="{{ day.date|date('Y-m-d') }}"
             data-label="{{ day.date_label }}"
             onclick="selectDay(this)">
          <div class="dlist-meta">
            <div class="dlist-name">{{ day.date_label }}</div>
            <div class="dlist-date">{{ day.date_short }}</div>
          </div>
          <div class="dlist-emoji">{{ day.emoji }}</div>
          <div class="dlist-temps">
            <span class="mx">{{ day.temp_max is not null ? day.temp_max|round ~ '°' : '—' }}</span>
            <span class="mn">/{{ day.temp_min is not null ? day.temp_min|round ~ '°' : '—' }}</span>
          </div>
          {% if day.precip_prob > 30 or day.precip_sum > 0.5 %}
          <div class="dlist-rain">💧{{ day.precip_prob }}%</div>
          {% endif %}
        </div>
        {% endfor %}
      </div>

      {# ── Colonne droite : prévisions horaires ── #}
      <div class="wx-hourly-col">
        <div class="wx-hourly-header">
          <span class="fw-semibold" id="hourly-day-label">{{ today ? today.date_label : 'Prévisions' }}</span>
          <span class="text-muted small">· prévisions horaires</span>
        </div>
        <div id="hourly-strip" class="wx-hourly-strip"></div>
      </div>

    </div>
  </div>

  {# ═══ ROW 4 : ORAGES + NEIGE ═══ #}
  <div class="row g-2 mb-3">

    {# ── Orages ── #}
    <div class="col-lg-6">
      <div class="card h-100">
        <div class="card-header border-bottom d-flex justify-content-between align-items-center">
          <h3 class="card-title">⛈️ Prochains orages</h3>
          {% if storm_hours is not empty %}<span class="badge bg-warning text-dark">{{ storm_hours|length }} h</span>{% endif %}
        </div>
        <div class="card-body" style="max-height:280px;overflow-y:auto">
          {% if storm_hours is empty %}
            <div class="text-center py-4 text-muted"><div style="font-size:2.5rem">✅</div><div class="mt-2 small">Aucun orage sur 14 jours</div></div>
          {% else %}
            {% for h in storm_hours %}
            <div class="storm-row">
              <div>
                <div class="storm-time">{{ h.datetime|date('D d/m', 'Europe/Paris') }} <span class="text-warning">{{ h.datetime|date('H:i', 'Europe/Paris') }}</span></div>
                <div class="storm-date-sub">{{ h.label }}</div>
              </div>
              <div class="flex-grow-1">
                <div class="storm-metrics">💨 <strong>{{ h.gusts }} km/h</strong> <span class="text-muted">{{ h.wind_dir }}</span></div>
                <div class="storm-sub">💧 {{ h.precip }} mm · {{ h.precip_prob }}% · {{ h.temp }}°C</div>
              </div>
              <div>
                {% if h.code == 99 %}<span class="badge bg-danger">Grêle ++</span>
                {% elseif h.code == 96 %}<span class="badge bg-warning text-dark">Grêle</span>
                {% else %}<span class="badge bg-orange text-white">Orage</span>{% endif %}
              </div>
            </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>
    </div>

    {# ── Neige ── #}
    <div class="col-lg-6">
      <div class="card h-100">
        <div class="card-header border-bottom d-flex justify-content-between align-items-center">
          <h3 class="card-title">❄️ Neige à venir</h3>
          {% set snow_days = days|filter(d => d.snowfall > 0 or d.type == 'snow') %}
          {% if snow_days is not empty %}<span class="badge bg-info text-dark">{{ snow_days|length }} j</span>{% endif %}
        </div>
        <div class="card-body" style="max-height:280px;overflow-y:auto">
          {% set snow_days = days|filter(d => d.snowfall > 0 or d.type == 'snow') %}
          {% if snow_days is empty %}
            <div class="text-center py-4 text-muted"><div style="font-size:2.5rem">🌿</div><div class="mt-2 small">Pas de neige sur 14 jours</div></div>
          {% else %}
            {% for day in snow_days %}
            <div class="storm-row">
              <div>
                <div class="storm-time">{{ day.date_label }}</div>
                <div class="storm-date-sub">{{ day.label }}</div>
              </div>
              <div class="flex-grow-1">
                <div class="storm-metrics">❄️ <strong>{{ day.snowfall }} cm</strong></div>
                <div class="storm-sub">🌡️ {{ day.temp_max is not null ? day.temp_max|round ~ '°' : '—' }} / {{ day.temp_min is not null ? day.temp_min|round ~ '°' : '—' }}{% if day.precip_sum > 0 %} · 💧 {{ day.precip_sum }}mm{% endif %}</div>
              </div>
              <div>
                {% if day.snowfall >= 20 %}<span class="badge bg-danger">Forte neige</span>
                {% elseif day.snowfall >= 5 %}<span class="badge bg-info text-dark">Neige</span>
                {% else %}<span class="badge bg-info-lt text-info">Légère</span>{% endif %}
              </div>
            </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>
    </div>

  </div>

  {# ═══ STATS 14J ═══ #}
  {% if week_stats %}
  <div class="card">
    <div class="card-header border-bottom"><h3 class="card-title">📊 Statistiques — {{ week_stats.days_count }} prochains jours</h3></div>
    <div class="card-body p-0">
      <div class="stat-grid">
        <div class="stat-cell"><span class="sc-icon">🌡️</span><div class="sc-val text-danger">{{ week_stats.max_temp is not null ? week_stats.max_temp ~ '°' : '—' }}</div><div class="sc-lbl">Temp. max</div></div>
        <div class="stat-cell"><span class="sc-icon">🥶</span><div class="sc-val text-info">{{ week_stats.min_temp is not null ? week_stats.min_temp ~ '°' : '—' }}</div><div class="sc-lbl">Temp. min</div></div>
        <div class="stat-cell"><span class="sc-icon">💧</span><div class="sc-val text-azure">{{ week_stats.total_precip }} mm</div><div class="sc-lbl">Précip. totales</div></div>
        <div class="stat-cell"><span class="sc-icon">☀️</span><div class="sc-val text-yellow">{{ week_stats.sunshine_hours }}h</div><div class="sc-lbl">Ensoleillement</div></div>
        <div class="stat-cell"><span class="sc-icon">⛈️</span><div class="sc-val {{ week_stats.storm_days > 0 ? 'text-warning' : 'text-muted' }}">{{ week_stats.storm_days }}</div><div class="sc-lbl">Jours orage</div></div>
        <div class="stat-cell"><span class="sc-icon">🌧️</span><div class="sc-val {{ week_stats.rain_days > 0 ? 'text-blue' : 'text-muted' }}">{{ week_stats.rain_days }}</div><div class="sc-lbl">Jours pluie</div></div>
        <div class="stat-cell"><span class="sc-icon">❄️</span><div class="sc-val {{ week_stats.snow_days > 0 ? 'text-cyan' : 'text-muted' }}">{{ week_stats.snow_days }}</div><div class="sc-lbl">Jours neige</div></div>
        <div class="stat-cell"><span class="sc-icon">🌤️</span><div class="sc-val text-yellow">{{ week_stats.clear_days }}</div><div class="sc-lbl">Jours dégagés</div></div>
      </div>
    </div>
  </div>
  {% endif %}

  {% endif %}{# /error #}
