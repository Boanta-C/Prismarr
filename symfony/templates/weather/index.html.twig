<script type="module">
/* ═══════════════════════════════════════════════
   LUNE 3D SUR CANVAS
═══════════════════════════════════════════════ */
function drawMoon(canvas, phase) {
    const dpr  = Math.min(window.devicePixelRatio || 1, 2);
    const css  = canvas.clientWidth || 110;
    canvas.width  = css * dpr;
    canvas.height = css * dpr;
    const ctx  = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    const size = css;
    const r    = size / 2 - 3;
    const cx   = size / 2;
    const cy   = size / 2;

    ctx.clearRect(0, 0, size, size);

    // 1. Sphère — dégradé radial 3D
    const sphere = ctx.createRadialGradient(cx - r * 0.28, cy - r * 0.32, r * 0.04, cx, cy, r);
    sphere.addColorStop(0.00, '#f8f0df');
    sphere.addColorStop(0.25, '#e8cc8a');
    sphere.addColorStop(0.50, '#c89038');
    sphere.addColorStop(0.72, '#8b5e14');
    sphere.addColorStop(0.88, '#4a2e06');
    sphere.addColorStop(1.00, '#1c0e00');

    ctx.save();
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, 2 * Math.PI);
    ctx.fillStyle = sphere;
    ctx.fill();

    // 2. Cratères
    const craters = [
        [0.28, 0.58, 0.075], [0.62, 0.36, 0.060], [0.46, 0.72, 0.042],
        [0.71, 0.61, 0.068], [0.21, 0.28, 0.042], [0.55, 0.50, 0.032],
    ];
    craters.forEach(([fx, fy, fr]) => {
        const kx = cx + (fx - 0.5) * 2 * r;
        const ky = cy + (fy - 0.5) * 2 * r;
        const kr = fr * 2 * r;
        // Bord sombre
        ctx.beginPath();
        ctx.arc(kx, ky, kr, 0, 2 * Math.PI);
        ctx.fillStyle = 'rgba(0,0,0,.22)';
        ctx.fill();
        // Reflet intérieur
        ctx.beginPath();
        ctx.arc(kx - kr * 0.2, ky - kr * 0.2, kr * 0.55, 0, 2 * Math.PI);
        ctx.fillStyle = 'rgba(255,230,160,.06)';
        ctx.fill();
    });
    ctx.restore();

    // 3. Ombre de phase (clippée au cercle)
    ctx.save();
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, 2 * Math.PI);
    ctx.clip();

    const shadow = 'rgba(0, 6, 18, 0.91)';
    const ex     = Math.abs(Math.cos(phase * 2 * Math.PI)) * r; // semi-axe X de l'ellipse terminatrice

    if (phase > 0.015 && phase < 0.985 && Math.abs(phase - 0.5) > 0.03) {
        ctx.beginPath();
        if (phase < 0.5) {
            // Côté droit éclairé → ombre sur gauche
            ctx.moveTo(cx, cy - r);
            ctx.arc(cx, cy, r, -Math.PI / 2, Math.PI / 2, true);          // demi-gauche CCW
            ctx.ellipse(cx, cy, ex, r, 0, Math.PI / 2, -Math.PI / 2, phase < 0.25); // terminateur
        } else {
            // Côté gauche éclairé → ombre sur droite
            ctx.moveTo(cx, cy - r);
            ctx.arc(cx, cy, r, -Math.PI / 2, Math.PI / 2, false);         // demi-droite CW
            ctx.ellipse(cx, cy, ex, r, 0, Math.PI / 2, -Math.PI / 2, phase >= 0.75);
        }
        ctx.closePath();
        ctx.fillStyle = shadow;
        ctx.fill();
    } else if (phase <= 0.015 || phase >= 0.985) {
        // Nouvelle lune — tout sombre
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, 2 * Math.PI);
        ctx.fillStyle = shadow;
        ctx.fill();
    }
    ctx.restore();

    // 4. Ombrage 3D sphérique (rim shadow en bas-droite)
    ctx.save();
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, 2 * Math.PI);
    ctx.clip();
    const rimShadow = ctx.createRadialGradient(cx + r * 0.28, cy + r * 0.25, r * 0.55, cx + r * 0.38, cy + r * 0.32, r);
    rimShadow.addColorStop(0, 'transparent');
    rimShadow.addColorStop(1, 'rgba(0,0,0,.20)');
    ctx.fillStyle = rimShadow;
    ctx.fillRect(0, 0, size, size);
    // Reflet spéculaire en haut-gauche
    const spec = ctx.createRadialGradient(cx - r * 0.3, cy - r * 0.33, 0, cx - r * 0.3, cy - r * 0.33, r * 0.46);
    spec.addColorStop(0, 'rgba(255,248,220,.18)');
    spec.addColorStop(1, 'transparent');
    ctx.fillStyle = spec;
    ctx.fillRect(0, 0, size, size);
    ctx.restore();

    // 5. Halo lunaire
    const halo = ctx.createRadialGradient(cx, cy, r * 0.82, cx, cy, r * 1.35);
    halo.addColorStop(0, 'transparent');
    halo.addColorStop(0.6, 'rgba(210, 175, 80, 0.07)');
    halo.addColorStop(1, 'transparent');
    ctx.beginPath();
    ctx.arc(cx, cy, r * 1.35, 0, 2 * Math.PI);
    ctx.fillStyle = halo;
    ctx.fill();
}

/* ═══════════════════════════════════════════════
   BOUSSOLE CANVAS
═══════════════════════════════════════════════ */
function drawCompass(canvas) {
    const dir   = parseFloat(canvas.dataset.dir);
    const speed = parseInt(canvas.dataset.speed, 10);
    const ctx   = canvas.getContext('2d');
    const size  = canvas.width;
    const cx    = size / 2, cy = size / 2;
    const r     = size / 2 - 4;

    ctx.clearRect(0, 0, size, size);

    // Fond
    const bg = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
    bg.addColorStop(0,   'rgba(18,28,55,.92)');
    bg.addColorStop(1,   'rgba(8,12,28,.96)');
    ctx.beginPath(); ctx.arc(cx, cy, r, 0, 2*Math.PI);
    ctx.fillStyle = bg; ctx.fill();

    // Cercle extérieur
    ctx.beginPath(); ctx.arc(cx, cy, r, 0, 2*Math.PI);
    ctx.strokeStyle = 'rgba(255,255,255,.14)'; ctx.lineWidth = 1.5; ctx.stroke();

    // Cercles internes
    [0.65, 0.38].forEach(f => {
        ctx.beginPath(); ctx.arc(cx, cy, r * f, 0, 2*Math.PI);
        ctx.strokeStyle = 'rgba(255,255,255,.06)'; ctx.lineWidth = 1; ctx.stroke();
    });

    // Graduations
    for (let d = 0; d < 360; d += 5) {
        const major = d % 45 === 0, minor = d % 15 === 0;
        const len   = major ? 12 : minor ? 8 : 4;
        const rad   = (d - 90) * Math.PI / 180;
        const x1 = cx + Math.cos(rad) * (r - 2);
        const y1 = cy + Math.sin(rad) * (r - 2);
        const x2 = cx + Math.cos(rad) * (r - 2 - len);
        const y2 = cy + Math.sin(rad) * (r - 2 - len);
        ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2);
        ctx.strokeStyle = major ? 'rgba(255,255,255,.35)' : minor ? 'rgba(255,255,255,.15)' : 'rgba(255,255,255,.07)';
        ctx.lineWidth = major ? 1.8 : 1; ctx.stroke();
    }

    // Points cardinaux
    const cards = [[0,'N','#f87171',14],[90,'E','rgba(255,255,255,.75)',11],[180,'S','rgba(255,255,255,.75)',11],[270,'O','rgba(255,255,255,.75)',11]];
    cards.forEach(([d, lbl, color, fs]) => {
        const rad = (d - 90) * Math.PI / 180;
        const x   = cx + Math.cos(rad) * (r - 18);
        const y   = cy + Math.sin(rad) * (r - 18);
        ctx.font = `bold ${fs}px Inter,system-ui,sans-serif`;
        ctx.fillStyle = color; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(lbl, x, y);
    });

    // Sous-cardinaux
    [[45,'NE'],[135,'SE'],[225,'SO'],[315,'NO']].forEach(([d, lbl]) => {
        const rad = (d - 90) * Math.PI / 180;
        ctx.font = '8.5px Inter,system-ui,sans-serif';
        ctx.fillStyle = 'rgba(255,255,255,.38)';
        ctx.fillText(lbl, cx + Math.cos(rad)*(r-20), cy + Math.sin(rad)*(r-20));
    });

    // Aiguille
    const nRad  = (dir - 90) * Math.PI / 180;
    const pRad  = nRad + Math.PI / 2;
    const tipL  = r * 0.56;
    const backL = r * 0.30;
    const hw    = 5;

    const tip  = { x: cx + Math.cos(nRad)*tipL,  y: cy + Math.sin(nRad)*tipL  };
    const back = { x: cx - Math.cos(nRad)*backL,  y: cy - Math.sin(nRad)*backL };

    // Pointe (sens vent → rouge)
    ctx.save();
    ctx.beginPath();
    ctx.moveTo(tip.x, tip.y);
    ctx.lineTo(cx + Math.cos(pRad)*hw, cy + Math.sin(pRad)*hw);
    ctx.lineTo(back.x, back.y);
    ctx.lineTo(cx - Math.cos(pRad)*hw, cy - Math.sin(pRad)*hw);
    ctx.closePath();
    const ng1 = ctx.createLinearGradient(back.x, back.y, tip.x, tip.y);
    ng1.addColorStop(0, 'rgba(251,146,60,.5)'); ng1.addColorStop(1, '#ef4444');
    ctx.fillStyle = ng1; ctx.fill();
    ctx.strokeStyle = 'rgba(255,255,255,.15)'; ctx.lineWidth = .8; ctx.stroke();
    ctx.restore();

    // Contre-pointe (bleu)
    ctx.save();
    ctx.beginPath();
    ctx.moveTo(back.x, back.y);
    ctx.lineTo(cx + Math.cos(pRad)*hw*.7, cy + Math.sin(pRad)*hw*.7);
    ctx.lineTo(cx + Math.cos(nRad)*r*.12, cy + Math.sin(nRad)*r*.12);
    ctx.lineTo(cx - Math.cos(pRad)*hw*.7, cy - Math.sin(pRad)*hw*.7);
    ctx.closePath();
    ctx.fillStyle = 'rgba(96,165,250,.65)'; ctx.fill();
    ctx.restore();

    // Pivot central
    ctx.beginPath(); ctx.arc(cx, cy, 6, 0, 2*Math.PI);
    ctx.fillStyle = '#e2e8f0'; ctx.fill();
    ctx.beginPath(); ctx.arc(cx, cy, 3.5, 0, 2*Math.PI);
    ctx.fillStyle = '#1e293b'; ctx.fill();

    // Vitesse au centre (en bas)
    ctx.font = `bold 13px Inter,system-ui,sans-serif`;
    ctx.fillStyle = 'rgba(255,255,255,.8)';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText(speed + ' km/h', cx, cy + r * 0.52);
}

/* ═══════════════════════════════════════════════
   ARC SOLAIRE / LUNAIRE
═══════════════════════════════════════════════ */
function drawSunArc(canvas) {
    const dpr  = Math.min(window.devicePixelRatio || 1, 2);
    const cssW = canvas.clientWidth  || 280;
    const cssH = canvas.clientHeight || 140;
    canvas.width  = cssW * dpr;
    canvas.height = cssH * dpr;

    const sunrise  = parseInt(canvas.dataset.sunrise, 10);
    const sunset   = parseInt(canvas.dataset.sunset,  10);
    const daylight = parseFloat(canvas.dataset.daylight);
    const now = new Date().getHours() * 60 + new Date().getMinutes();
    const isDay = now >= sunrise && now <= sunset;

    const ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);

    const W   = cssW;
    const H   = cssH;
    const cx  = W / 2;
    const cy  = H - 32;    // plus d'espace en bas pour les labels
    const R   = Math.min(cx - 32, cy - 10);

    ctx.clearRect(0, 0, W, H);

    // Dégradé ciel dans l'arc
    const skyGrad = ctx.createLinearGradient(0, cy - R, 0, cy);
    if (isDay) {
        skyGrad.addColorStop(0,   'rgba(56,132,255,.13)');
        skyGrad.addColorStop(0.7, 'rgba(251,146,60,.07)');
        skyGrad.addColorStop(1,   'rgba(251,146,60,.02)');
    } else {
        skyGrad.addColorStop(0, 'rgba(30,27,75,.18)');
        skyGrad.addColorStop(1, 'rgba(99,102,241,.04)');
    }
    ctx.save();
    ctx.beginPath();
    ctx.moveTo(cx - R, cy);
    ctx.arc(cx, cy, R, Math.PI, 0, false);
    ctx.closePath();
    ctx.fillStyle = skyGrad;
    ctx.fill();
    ctx.restore();

    // Clip : rien ne descend sous la ligne d'horizon
    ctx.save();
    ctx.beginPath();
    ctx.rect(0, 0, W, cy + 10);
    ctx.clip();

    // Arc gradient orange→jaune→orange
    const arcGrad = ctx.createLinearGradient(cx - R, cy, cx + R, cy);
    if (isDay) {
        arcGrad.addColorStop(0,   'rgba(251,146,60,.7)');
        arcGrad.addColorStop(0.5, 'rgba(253,224,71,.85)');
        arcGrad.addColorStop(1,   'rgba(251,146,60,.7)');
    } else {
        arcGrad.addColorStop(0,   'rgba(99,102,241,.45)');
        arcGrad.addColorStop(0.5, 'rgba(148,163,184,.5)');
        arcGrad.addColorStop(1,   'rgba(99,102,241,.45)');
    }

    if (isDay) {
        const progress  = (now - sunrise) / (sunset - sunrise);
        const doneAngle = Math.PI - progress * Math.PI;
        // Partie passée — trait plein gradient
        ctx.beginPath();
        ctx.arc(cx, cy, R, Math.PI, doneAngle, false);
        ctx.strokeStyle = arcGrad;
        ctx.lineWidth = 2.5;
        ctx.stroke();
        // Partie future — pointillée
        ctx.beginPath();
        ctx.setLineDash([5, 6]);
        ctx.arc(cx, cy, R, doneAngle, 0, false);
        ctx.strokeStyle = 'rgba(251,191,36,.22)';
        ctx.lineWidth = 1.5;
        ctx.stroke();
        ctx.setLineDash([]);
    } else {
        ctx.beginPath();
        ctx.setLineDash([4, 6]);
        ctx.arc(cx, cy, R, Math.PI, 0, false);
        ctx.strokeStyle = arcGrad;
        ctx.lineWidth = 1.5;
        ctx.stroke();
        ctx.setLineDash([]);
    }

    ctx.restore(); // fin clip horizon

    // Horizon
    ctx.beginPath();
    ctx.moveTo(cx - R - 8, cy);
    ctx.lineTo(cx + R + 8, cy);
    ctx.strokeStyle = 'rgba(255,255,255,.14)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // Calcul position du corps céleste
    let bodyX, bodyY;
    if (isDay) {
        const angle = Math.PI - ((now - sunrise) / (sunset - sunrise)) * Math.PI;
        bodyX = cx + R * Math.cos(angle);
        bodyY = cy - R * Math.sin(angle);
    } else {
        const nightDur = 24 * 60 - (sunset - sunrise);
        const nightProg = now > sunset
            ? (now - sunset) / nightDur
            : (now + 24 * 60 - sunset) / nightDur;
        const angle = Math.PI - nightProg * Math.PI;
        bodyX = cx + R * Math.cos(angle);
        bodyY = cy - R * Math.sin(angle);
    }

    // Dessin soleil ou lune
    // Ligne de chute du corps céleste → horizon (uniquement si assez haut)
    if (bodyY < cy - 20) {
        ctx.beginPath();
        ctx.moveTo(bodyX, bodyY + (isDay ? 9 : 7));
        ctx.lineTo(bodyX, cy - 1);
        ctx.strokeStyle = isDay ? 'rgba(253,224,71,.2)' : 'rgba(148,163,184,.15)';
        ctx.lineWidth = 1;
        ctx.setLineDash([3, 4]);
        ctx.stroke();
        ctx.setLineDash([]);
    }

    // Soleil ou lune
    if (isDay) {
        // Halo externe
        const halo = ctx.createRadialGradient(bodyX, bodyY, 0, bodyX, bodyY, 26);
        halo.addColorStop(0,   'rgba(253,224,71,.35)');
        halo.addColorStop(0.5, 'rgba(251,146,60,.12)');
        halo.addColorStop(1,   'transparent');
        ctx.beginPath(); ctx.arc(bodyX, bodyY, 26, 0, 2 * Math.PI);
        ctx.fillStyle = halo; ctx.fill();
        // Corps
        ctx.beginPath(); ctx.arc(bodyX, bodyY, 8, 0, 2 * Math.PI);
        ctx.fillStyle = '#fde047'; ctx.fill();
        ctx.strokeStyle = '#f59e0b'; ctx.lineWidth = 1.5; ctx.stroke();
    } else {
        const glow = ctx.createRadialGradient(bodyX, bodyY, 0, bodyX, bodyY, 15);
        glow.addColorStop(0, 'rgba(203,213,225,.35)');
        glow.addColorStop(1, 'transparent');
        ctx.beginPath(); ctx.arc(bodyX, bodyY, 15, 0, 2 * Math.PI);
        ctx.fillStyle = glow; ctx.fill();
        ctx.beginPath(); ctx.arc(bodyX, bodyY, 6.5, 0, 2 * Math.PI);
        ctx.fillStyle = '#cbd5e1'; ctx.fill();
    }

    const fmt = m => `${Math.floor(m/60)}h${String(m%60).padStart(2,'0')}`;

    // Heure actuelle sur le corps
    const nowH2 = Math.floor(now / 60);
    const nowM2 = String(now % 60).padStart(2, '0');
    ctx.font = `bold 11px Inter,system-ui,sans-serif`;
    ctx.fillStyle = isDay ? '#fde047' : '#94a3b8';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    const lblY = bodyY > cy - 22 ? bodyY - 16 : bodyY + 18;
    ctx.fillText(`${nowH2}h${nowM2}`, bodyX, lblY);

    // Ligne 1 : lever · lumière · coucher
    ctx.font = '10.5px Inter,system-ui,sans-serif';
    ctx.textBaseline = 'top';
    ctx.fillStyle = 'rgba(255,200,80,.9)';
    ctx.textAlign = 'left';
    ctx.fillText(`🌅 ${fmt(sunrise)}`, cx - R, cy + 6);
    ctx.textAlign = 'right';
    ctx.fillText(`${fmt(sunset)} 🌇`, cx + R, cy + 6);
    ctx.textAlign = 'center';
    ctx.fillStyle = 'rgba(255,255,255,.4)';
    ctx.fillText(`${daylight}h de lumière`, cx, cy + 6);

    // Ligne 2 : temps restant (si jour) ou avant lever (si nuit)
    ctx.font = '10px Inter,system-ui,sans-serif';
    ctx.textAlign = 'center';
    if (isDay) {
        const rem = sunset - now;
        const rh  = Math.floor(rem / 60);
        const rm  = rem % 60;
        ctx.fillStyle = 'rgba(253,224,71,.6)';
        ctx.fillText(`☀️ encore ${rh}h${String(rm).padStart(2,'0')} de soleil`, cx, cy + 19);
    } else {
        const toSunrise = now < sunrise ? sunrise - now : 24*60 - now + sunrise;
        const th = Math.floor(toSunrise / 60);
        const tm = toSunrise % 60;
        ctx.fillStyle = 'rgba(148,163,184,.55)';
        ctx.fillText(`🌅 lever dans ${th}h${String(tm).padStart(2,'0')}`, cx, cy + 19);
    }
}

/* ═══════════════════════════════════════════════
   GRAPHIQUES CHART.JS
═══════════════════════════════════════════════ */
const DAYS_DATA = JSON.parse(document.getElementById('days-chart-data').textContent);
/* ═══════════════════════════════════════════════
   PRÉVISIONS HORAIRES
═══════════════════════════════════════════════ */
const WMO_EMOJI_DAY   = {0:'☀️',1:'🌤️',2:'⛅',3:'☁️',45:'🌫️',48:'🌫️',51:'🌦️',53:'🌦️',55:'🌧️',56:'🌧️',57:'🌧️',61:'🌧️',63:'🌧️',65:'🌧️',66:'🌨️',67:'🌨️',71:'❄️',73:'❄️',75:'❄️',77:'❄️',80:'🌦️',81:'🌧️',82:'⛈️',85:'🌨️',86:'🌨️',95:'⛈️',96:'⛈️',99:'⛈️'};
const WMO_EMOJI_NIGHT = {...WMO_EMOJI_DAY, 0:'🌙', 1:'🌙', 2:'☁️'};

function wmoEmoji(code, isDay) {
    return (isDay ? WMO_EMOJI_DAY : WMO_EMOJI_NIGHT)[code] ?? '🌡️';
}

function hexToRgba(hex, a) {
    const r = parseInt(hex.slice(1,3), 16);
    const g = parseInt(hex.slice(3,5), 16);
    const b = parseInt(hex.slice(5,7), 16);
    return `rgba(${r},${g},${b},${a})`;
}
function tempColor(t) {
    return t >= 28 ? '#f97316' : t >= 20 ? '#fb923c' : t >= 10 ? '#fbbf24' : t >= 0 ? '#60a5fa' : '#a5f3fc';
}
function precipColor(p) {
    return p >= 70 ? '#3b82f6' : p >= 40 ? '#60a5fa' : p >= 10 ? '#93c5fd' : '#475569';
}
function windColor(w) {
    return w >= 60 ? '#ef4444' : w >= 30 ? '#f59e0b' : '#60a5fa';
}

function buildHourlyStrip(dayKey) {
    const strip = document.getElementById('hourly-strip');
    if (!strip) return;
    const data = DAYS_DATA[dayKey];
    if (!data || !data.labels.length) {
        strip.innerHTML = '<div style="padding:.5rem;color:rgba(255,255,255,.4);font-size:.8rem">Pas de données</div>';
        return;
    }

    const nowH     = new Date().getHours();
    const todayKey = Object.keys(DAYS_DATA)[0];
    const isToday  = dayKey === todayKey;
    const minTemp  = Math.min(...data.temps);
    const maxTemp  = Math.max(...data.temps);

    strip.innerHTML = '';

    data.labels.forEach((lbl, i) => {
        const h     = parseInt(lbl.split('h')[0], 10);
        const isDay = data.isDay?.[i] ?? true;
        const emoji = wmoEmoji(data.weatherCodes?.[i] ?? 0, isDay);
        const temp  = data.temps[i];
        const feels = data.feelsLike?.[i];
        const prob  = data.precipProb?.[i] ?? 0;
        const mm    = data.precip?.[i] ?? 0;
        const wind  = data.wind?.[i] ?? 0;
        const isNow = isToday && h === nowH;
        const tLbl  = isNow ? 'mtn' : lbl.replace('h00', 'h');
        const tCol  = tempColor(temp);

        // Couleur bordure gauche selon condition
        const borderCol = prob >= 60 ? '#3b82f6' : prob >= 30 ? '#93c5fd' : !isDay ? '#818cf8' : tCol;
        const barPct    = maxTemp > minTemp ? Math.round((temp - minTemp) / (maxTemp - minTemp) * 100) : 50;

        const mmLbl = mm > 0 ? ` · 💧 ${mm}mm` : '';
        const altBg = i%2===0 ? 'rgba(255,255,255,.03)' : 'transparent';

        const row = document.createElement('div');
        row.title = `${lbl} · ${Math.round(temp)}°C (ressenti ${feels !== undefined ? Math.round(feels)+'°' : '—'}) · Pluie ${prob}%${mmLbl} · 💨 ${Math.round(wind)} km/h`;
        row.style.cssText = `
            display:grid;
            grid-template-columns:38px 22px 52px 48px 1fr 48px 50px;
            align-items:center; gap:.4rem;
            padding:.38rem .7rem .38rem .6rem;
            border-left:3px solid ${isNow ? '#6366f1' : hexToRgba(borderCol, 0.45)};
            background:${isNow ? 'rgba(99,102,241,.12)' : altBg};
            border-radius:0 .35rem .35rem 0;
            margin-bottom:1px;
        `;
        row.innerHTML = `
            <span style="font-size:.72rem;font-weight:${isNow?700:500};color:${isNow?'#a5b4fc':'rgba(255,255,255,.5)'};letter-spacing:.02em">${tLbl}</span>
            <span style="font-size:1.05rem;line-height:1;text-align:center">${emoji}</span>
            <span style="font-size:.88rem;font-weight:700;color:${tCol}">${Math.round(temp)}°</span>
            <span style="font-size:.64rem;color:rgba(255,255,255,.3)">${feels !== undefined ? 'res.&nbsp;'+Math.round(feels)+'°' : ''}</span>
            <div style="height:6px;background:rgba(255,255,255,.07);border-radius:3px;overflow:hidden;margin:0 .25rem">
                <div style="height:100%;width:${barPct}%;background:linear-gradient(90deg,${hexToRgba(tCol,.55)},${tCol});border-radius:3px;transition:width .3s"></div>
            </div>
            <span style="font-size:.68rem;color:${prob > 20 ? precipColor(prob) : 'rgba(255,255,255,.2)'};text-align:right;white-space:nowrap">💧&nbsp;${prob}%</span>
            <span style="font-size:.68rem;color:${windColor(wind)};text-align:right;white-space:nowrap">💨&nbsp;${Math.round(wind)}</span>
        `;
        strip.appendChild(row);
    });

    // Scroll vers l'heure actuelle
    if (isToday) {
        const nowIdx = data.labels.findIndex(l => parseInt(l.split('h')[0],10) === nowH);
        if (nowIdx > 0) strip.scrollTop = Math.max(0, nowIdx * 34 - 68);
    }
}

/* ═══════════════════════════════════════════════
   INTERACTIONS
═══════════════════════════════════════════════ */
window.selectDay = function(row) {
    document.querySelectorAll('.dlist-row').forEach(r => r.classList.remove('active'));
    row.classList.add('active');
    const lbl = document.getElementById('hourly-day-label');
    if (lbl) lbl.textContent = row.dataset.label;
    buildHourlyStrip(row.dataset.day);
};

function init() {
    // Ne plus forcer dark — le thème utilisateur est respecté
    // Le contenu météo (.wx-content) a data-bs-theme="dark" pour rester sombre

    // Déplace wp-bg directement sous <body> pour sortir du stacking context de Tabler
    const bg = document.querySelector('.wp-bg');
    if (bg && bg.parentNode !== document.body) {
        document.body.insertBefore(bg, document.body.firstChild);
    }
    // Lune
    const moonCanvas = document.getElementById('moon-canvas');
    if (moonCanvas) drawMoon(moonCanvas, parseFloat(moonCanvas.dataset.phase));
    // Boussole
    const compassCanvas = document.getElementById('compass-canvas');
    if (compassCanvas) drawCompass(compassCanvas);
    // Arc solaire/lunaire
    const arcCanvas = document.getElementById('sun-arc-canvas');
    if (arcCanvas) drawSunArc(arcCanvas);

    // Heure exacte dans le header Aujourd'hui
    const heroTime = document.getElementById('hero-current-time');
    if (heroTime) {
        const now = new Date();
        heroTime.textContent = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
    }

    // 2 prochaines heures dans hero-topbar
    const heroNextRows = document.getElementById('hero-next-rows');
    if (heroNextRows && DAYS_DATA) {
        heroNextRows.innerHTML = '';
        const todayKey = Object.keys(DAYS_DATA)[0];
        const data = DAYS_DATA[todayKey];
        if (data) {
            const nowH = new Date().getHours();
            [nowH + 1, nowH + 2, nowH + 3, nowH + 4].forEach(targetH => {
                const h   = targetH % 24;
                const idx = data.labels.findIndex(l => parseInt(l.split('h')[0], 10) === h);
                if (idx === -1) return;
                const temp  = data.temps[idx];
                const prob  = data.precipProb?.[idx] ?? 0;
                const wind  = data.wind?.[idx] ?? 0;
                const isD   = data.isDay?.[idx] ?? true;
                const emoji = wmoEmoji(data.weatherCodes?.[idx] ?? 0, isD);
                const tCol  = tempColor(temp);
                const lbl   = data.labels[idx].replace('h00', 'h');
                const el = document.createElement('div');
                el.style.cssText = `display:flex;align-items:center;gap:.6rem;padding:.45rem .75rem;background:rgba(255,255,255,.07);border-radius:.45rem;margin-bottom:.3rem`;
                el.innerHTML = `
                    <span style="font-size:.82rem;font-weight:700;color:rgba(255,255,255,.55);min-width:28px">${lbl}</span>
                    <span style="font-size:1.4rem;line-height:1">${emoji}</span>
                    <span style="font-size:1.1rem;font-weight:800;color:${tCol}">${Math.round(temp)}°</span>
                    ${prob > 10 ? `<span style="font-size:.75rem;color:#60a5fa">💧${prob}%</span>` : ''}
                    <span style="font-size:.75rem;color:rgba(255,255,255,.35)">💨${Math.round(wind)}</span>
                `;
                heroNextRows.appendChild(el);
            });
        }
    }

    // Temps MAJ
    const fetched_ago = {{ fetched_ago is not null ? fetched_ago : 0 }};
    const lastMAJ = new Date(Date.now() - fetched_ago * 60000);
    const fmtTime = d => `${String(d.getHours()).padStart(2,'0')}h${String(d.getMinutes()).padStart(2,'0')}`;
    const elLast = document.getElementById('last-maj-time');
    if (elLast) elLast.textContent = fmtTime(lastMAJ);
    const elNext = document.getElementById('next-refresh-time');
    if (elNext) elNext.textContent = fmtTime(new Date(Date.now() + 30 * 60000));

    // Bande horaire : premier jour
    const first = document.querySelector('.dlist-row[data-day]');
    if (first) buildHourlyStrip(first.dataset.day);
}

init();

// turbo:load : on vérifie qu'on est toujours sur la page météo avant d'agir
// Sinon le listener zombie force le dark mode sur toutes les autres pages
document.addEventListener('turbo:load', () => {
    if (document.querySelector('.wp-bg')) {
        init();
    } else {
        // On vient de quitter la page météo — restaurer le thème sauvegardé
        const saved = localStorage.getItem('tablerTheme') ?? 'dark';
        document.documentElement.setAttribute('data-bs-theme', saved);
    }
});

// Auto-refresh toutes les 30 minutes
setTimeout(() => { location.reload(); }, 30 * 60 * 1000);
</script>
{% endblock %}
