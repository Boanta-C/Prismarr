{% extends 'base.html.twig' %}

{% block title %}Alertes{% endblock %}
{% block page_title %}Alertes{% endblock %}

{% block body %}
<div class="row row-deck row-cards">

  {# ===== Alertes actives ===== #}
  <div class="col-12" id="active-alerts-card">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">
          Alertes actives
          <span id="sse-alert-page-badge" class="badge bg-danger ms-2{% if active is empty %} d-none{% endif %}">{{ active|length > 0 ? active|length : '' }}</span>
        </h3>
      </div>
      <div class="card-body p-0">
        {% if active is empty %}
          <div class="p-4 text-center text-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round" class="mb-2 opacity-50">
              <path d="M5 12l5 5l10 -10"/>
            </svg>
            <div>Aucune alerte active</div>
          </div>
        {% else %}
          <div class="table-responsive">
            <table class="table table-vcenter table-sm card-table">
              <thead>
                <tr>
                  <th style="width: 90px">Sévérité</th>
                  <th>Message</th>
                  <th>Device</th>
                  <th>Source</th>
                  <th>Depuis</th>
                  <th style="width: 160px"></th>
                </tr>
              </thead>
              <tbody>
                {% for alert in active %}
                <tr>
                  <td>
                    {% if alert.severity == 'critical' %}
                      <span class="badge bg-danger">Critique</span>
                    {% elseif alert.severity == 'warning' %}
                      <span class="badge bg-warning text-dark">Avertissement</span>
                    {% else %}
                      <span class="badge bg-info-lt">Info</span>
                    {% endif %}
                  </td>
                  <td>
                    <span class="fw-medium">{{ alert.message }}</span>
                    {% if alert.acknowledged %}
                      <span class="badge bg-secondary-lt ms-1">Acquittée</span>
                    {% endif %}
                  </td>
                  <td class="text-secondary small">
                    {{ alert.device ? alert.device.name : '—' }}
                  </td>
                  <td class="text-secondary small font-monospace">
                    {{ alert.source ?? '—' }}
                  </td>
                  <td class="text-secondary small">
                    {{ alert.createdAt|date('d/m H:i') }}
                  </td>
                  <td class="text-end">
                    {% if not alert.acknowledged %}
                      <form method="post"
                            action="{{ path('app_alertes_acknowledge', {id: alert.id}) }}"
                            class="d-inline">
                        <input type="hidden" name="_token"
                               value="{{ csrf_token('acknowledge' ~ alert.id) }}">
                        <button type="submit" class="btn btn-sm btn-ghost-secondary">
                          Acquitter
                        </button>
                      </form>
                    {% endif %}
                    <form method="post"
                          action="{{ path('app_alertes_resolve', {id: alert.id}) }}"
                          class="d-inline">
                      <input type="hidden" name="_token"
                             value="{{ csrf_token('resolve' ~ alert.id) }}">
                      <button type="submit" class="btn btn-sm btn-ghost-danger">
                        Résoudre
                      </button>
                    </form>
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {# ===== Alertes résolues (50 dernières) ===== #}
  {% if resolved is not empty %}
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title text-secondary">Alertes résolues <span class="text-muted small">(50 dernières)</span></h3>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-vcenter table-sm card-table">
            <thead>
              <tr>
                <th style="width: 90px">Sévérité</th>
                <th>Message</th>
                <th>Device</th>
                <th>Créée le</th>
                <th>Résolue le</th>
              </tr>
            </thead>
            <tbody>
              {% for alert in resolved %}
              <tr class="opacity-75">
                <td>
                  {% if alert.severity == 'critical' %}
                    <span class="badge bg-danger-lt">Critique</span>
                  {% elseif alert.severity == 'warning' %}
                    <span class="badge bg-warning-lt">Avertissement</span>
                  {% else %}
                    <span class="badge bg-info-lt">Info</span>
                  {% endif %}
                </td>
                <td class="text-secondary">{{ alert.message }}</td>
                <td class="text-secondary small">
                  {{ alert.device ? alert.device.name : '—' }}
                </td>
                <td class="text-secondary small">{{ alert.createdAt|date('d/m H:i') }}</td>
                <td class="text-secondary small">{{ alert.resolvedAt|date('d/m H:i') }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function () {
  var currentCount = {{ active|length }};

  if (window._argosAlertPageListener) {
    document.removeEventListener('argos:alerts', window._argosAlertPageListener);
  }

  window._argosAlertPageListener = function (e) {
    if (e.detail.count === currentCount) return;
    currentCount = e.detail.count;

    // Fetch + injection DOM ciblée — pas de rechargement complet, pas de barre de progression
    fetch(window.location.href, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function (r) { return r.text(); })
      .then(function (html) {
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var newCard = doc.getElementById('active-alerts-card');
        var oldCard = document.getElementById('active-alerts-card');
        if (newCard && oldCard) { oldCard.replaceWith(newCard); }
      });
  };

  document.addEventListener('argos:alerts', window._argosAlertPageListener);
})();
</script>
{% endblock %}
