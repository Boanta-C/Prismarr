{% extends 'base.html.twig' %}

{% block title %}Bienvenue{% endblock %}

{% block body %}
  <div class="container-xl py-5">
    <div class="text-center mb-5">
      <img src="{{ asset('img/prismarr/prismarr-logo-horizontal.png') }}"
           alt="Prismarr"
           style="height: 64px; margin-bottom: 1rem;"/>
      <h1 class="h2 mb-2">Bienvenue dans Prismarr</h1>
      <p class="text-secondary">Aucun service n'est encore configuré. Choisissez une section pour commencer.</p>
    </div>

    <div class="row row-cards row-deck">
      <div class="col-md-6 col-lg-4">
        <a href="{{ path('app_setup_tmdb') }}" class="card card-link">
          <div class="card-body text-center">
            <div class="mb-2" style="font-size: 2rem;">🎬</div>
            <h3 class="card-title">Découverte (TMDb)</h3>
            <p class="text-secondary small mb-0">Films & séries tendance, watchlist.</p>
          </div>
        </a>
      </div>
      <div class="col-md-6 col-lg-4">
        <a href="{{ path('app_setup_managers') }}" class="card card-link">
          <div class="card-body text-center">
            <div class="mb-2" style="font-size: 2rem;">📽️</div>
            <h3 class="card-title">Radarr & Sonarr</h3>
            <p class="text-secondary small mb-0">Gestion films & séries.</p>
          </div>
        </a>
      </div>
      <div class="col-md-6 col-lg-4">
        <a href="{{ path('app_setup_indexers') }}" class="card card-link">
          <div class="card-body text-center">
            <div class="mb-2" style="font-size: 2rem;">🔍</div>
            <h3 class="card-title">Prowlarr & Jellyseerr</h3>
            <p class="text-secondary small mb-0">Indexeurs & requêtes.</p>
          </div>
        </a>
      </div>
      <div class="col-md-6 col-lg-4">
        <a href="{{ path('app_setup_downloads') }}" class="card card-link">
          <div class="card-body text-center">
            <div class="mb-2" style="font-size: 2rem;">⬇️</div>
            <h3 class="card-title">qBittorrent</h3>
            <p class="text-secondary small mb-0">Client de téléchargement.</p>
          </div>
        </a>
      </div>
    </div>
  </div>
{% endblock %}
