{% extends 'base.html.twig' %}

{% block title %}Éditer #{{ pk_val }} — {{ table }}{% endblock %}
{% block page_title %}Éditer ligne #{{ pk_val }}{% endblock %}

{% block breadcrumb %}
  <ol class="breadcrumb" aria-label="breadcrumbs">
    <li class="breadcrumb-item"><a href="{{ path('admin_db_index') }}">Base de données</a></li>
    <li class="breadcrumb-item"><a href="{{ path('admin_db_browse', {table: table}) }}">{{ table }}</a></li>
    <li class="breadcrumb-item active">#{{ pk_val }}</li>
  </ol>
{% endblock %}

{% block body %}
<div class="page-body">
  <div class="container-xl">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <div class="card">
          <div class="card-header">
            <h3 class="card-title mb-0">
              <code>{{ table }}</code> — ligne #{{ pk_val }}
            </h3>
          </div>
          <div class="card-body">
            <form method="post" data-turbo="false">
              <input type="hidden" name="_token" value="{{ csrf_token('edit_' ~ table ~ '_' ~ pk_val) }}">
              <input type="hidden" name="_back"  value="{{ app.request.query.get('_back') }}">

              {% for col in columns %}
                {% set val = row[col] %}
                {% set is_pk = col == pk_col %}
                <div class="mb-3">
                  <label class="form-label fw-semibold d-flex align-items-center gap-2">
                    {{ col }}
                    {% if is_pk %}
                      <span class="badge bg-blue-lt" style="font-size:.65rem;">PK</span>
                    {% endif %}
                  </label>
                  {% if is_pk %}
                    <input type="text" class="form-control form-control-sm bg-secondary-subtle text-secondary"
                           value="{{ val }}" disabled>
                    <input type="hidden" name="{{ col }}" value="{{ val }}">
                  {% elseif val is not null and val|length > 100 %}
                    <textarea name="{{ col }}" class="form-control form-control-sm" rows="4">{{ val }}</textarea>
                  {% else %}
                    <input type="text" name="{{ col }}" class="form-control form-control-sm"
                           value="{{ val is null ? '' : val }}"
                           {% if val is null %}placeholder="null"{% endif %}>
                  {% endif %}
                </div>
              {% endfor %}

              <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><path d="M6 4h10l4 4v10a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2z"/><path d="M12 14m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"/><path d="M14 4l0 4l-6 0l0 -4"/></svg>
                  Enregistrer
                </button>
                <a href="{{ path('admin_db_browse', {table: table}) }}" class="btn btn-ghost-secondary">Annuler</a>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
{% endblock %}
