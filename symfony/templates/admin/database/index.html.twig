{% extends 'base.html.twig' %}

{% block title %}Admin — Base de données{% endblock %}
{% block page_title %}Base de données{% endblock %}

{% block body %}
<div class="container-xl py-2">
  <div class="d-flex align-items-center justify-content-end">
    <a href="{{ path('admin_db_query') }}" class="btn btn-sm btn-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><path d="M7 7h10m-10 4h10m-5 4h5M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
      Query runner
    </a>
  </div>
</div>
<div class="page-body">
  <div class="container-xl">

    {% for type, messages in app.flashes %}
      {% for msg in messages %}
        <div class="alert alert-{{ type == 'success' ? 'success' : 'warning' }} mb-3">{{ msg }}</div>
      {% endfor %}
    {% endfor %}

    <div class="row g-4">

      {# Tables #}
      <div class="col-lg-8">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title mb-0">Tables ({{ tables|length }})</h3>
          </div>
          <div class="table-responsive">
            <table class="table table-vcenter table-hover card-table">
              <thead>
                <tr>
                  <th>Table</th>
                  <th class="text-end">Lignes</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {% for t in tables %}
                  <tr>
                    <td>
                      <code class="fw-semibold">{{ t.name }}</code>
                    </td>
                    <td class="text-end text-secondary">{{ t.rows|number_format(0, ',', ' ') }}</td>
                    <td class="text-end">
                      <a href="{{ path('admin_db_browse', {table: t.name}) }}" class="btn btn-sm btn-ghost-secondary">
                        Parcourir →
                      </a>
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="3" class="text-center text-secondary py-4">Aucune table trouvée.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      {# Audit log récent #}
      <div class="col-lg-4">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title mb-0">Dernières actions</h3>
          </div>
          <div class="list-group list-group-flush overflow-auto" style="max-height:420px;">
            {% for log in recent_logs %}
              <div class="list-group-item py-2 px-3">
                <div class="d-flex align-items-center justify-content-between gap-2">
                  <span class="badge
                    {% if log.action == 'delete' %}bg-danger
                    {% elseif log.action in ['update','insert'] %}bg-warning text-dark
                    {% elseif log.action == 'query' %}bg-purple
                    {% else %}bg-secondary{% endif %}
                  " style="font-size:.7rem;min-width:3.5rem;">{{ log.action }}</span>
                  <span class="text-secondary small flex-grow-1">{{ log.tableName ?? 'query' }}</span>
                  <span class="text-muted" style="font-size:.7rem;">{{ log.createdAt|date('H:i:s') }}</span>
                </div>
                <div class="text-muted mt-1" style="font-size:.7rem;">{{ log.userEmail }}</div>
              </div>
            {% else %}
              <div class="text-center text-secondary py-3 small">Aucune action enregistrée.</div>
            {% endfor %}
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
{% endblock %}
