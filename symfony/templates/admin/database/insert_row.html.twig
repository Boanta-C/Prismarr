{% extends 'base.html.twig' %}

{% block title %}Insérer — {{ table }}{% endblock %}
{% block page_title %}Insérer une ligne{% endblock %}

{% block breadcrumb %}
  <ol class="breadcrumb" aria-label="breadcrumbs">
    <li class="breadcrumb-item"><a href="{{ path('admin_db_index') }}">Base de données</a></li>
    <li class="breadcrumb-item"><a href="{{ path('admin_db_browse', {table: table}) }}">{{ table }}</a></li>
    <li class="breadcrumb-item active">Insérer</li>
  </ol>
{% endblock %}

{% block body %}
<div class="page-body">
  <div class="container-xl">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <div class="card">
          <div class="card-header">
            <h3 class="card-title mb-0">
              <code>{{ table }}</code> — nouvelle ligne
            </h3>
          </div>
          <div class="card-body">
            <form method="post">
              <input type="hidden" name="_token" value="{{ csrf_token('insert_' ~ table) }}">

              {% for col in columns %}
                {% set m = meta[col] %}
                <div class="mb-3">
                  <label class="form-label fw-semibold d-flex align-items-center gap-2">
                    {{ col }}
                    {% if m.Key == 'MUL' or m.Key == 'UNI' %}
                      <span class="badge bg-yellow-lt" style="font-size:.65rem;">{{ m.Key == 'UNI' ? 'UNIQUE' : 'INDEX' }}</span>
                    {% endif %}
                    {% if m.Null == 'YES' %}
                      <span class="text-muted" style="font-size:.75rem;">nullable</span>
                    {% else %}
                      <span class="text-danger" style="font-size:.75rem;">*</span>
                    {% endif %}
                    <span class="text-secondary ms-auto" style="font-size:.72rem;font-family:monospace;">{{ m.Type }}</span>
                  </label>

                  {% if 'text' in m.Type or 'blob' in m.Type %}
                    <textarea name="{{ col }}" class="form-control form-control-sm" rows="3"
                              placeholder="{{ m.Default is not null ? m.Default : '' }}"></textarea>
                  {% elseif 'tinyint(1)' == m.Type %}
                    <select name="{{ col }}" class="form-select form-select-sm">
                      {% if m.Null == 'YES' %}<option value="">— null —</option>{% endif %}
                      <option value="0" {{ m.Default == '0' ? 'selected' }}>0 (false)</option>
                      <option value="1" {{ m.Default == '1' ? 'selected' }}>1 (true)</option>
                    </select>
                  {% elseif 'datetime' in m.Type or 'timestamp' in m.Type %}
                    <input type="datetime-local" name="{{ col }}" class="form-control form-control-sm"
                           value="{{ m.Default == 'CURRENT_TIMESTAMP' ? '' : m.Default }}">
                    {% if m.Default == 'CURRENT_TIMESTAMP' %}
                      <div class="form-hint">Laisser vide = valeur automatique (CURRENT_TIMESTAMP)</div>
                    {% endif %}
                  {% elseif 'date' == m.Type %}
                    <input type="date" name="{{ col }}" class="form-control form-control-sm">
                  {% elseif 'int' in m.Type or 'decimal' in m.Type or 'float' in m.Type or 'double' in m.Type %}
                    <input type="number" step="{{ ('decimal' in m.Type or 'float' in m.Type or 'double' in m.Type) ? 'any' : '1' }}"
                           name="{{ col }}" class="form-control form-control-sm"
                           value="{{ m.Default is not null and m.Default != 'NULL' ? m.Default : '' }}"
                           placeholder="{{ m.Default is not null and m.Default != 'NULL' ? m.Default : '' }}">
                  {% else %}
                    <input type="text" name="{{ col }}" class="form-control form-control-sm"
                           value="{{ m.Default is not null and m.Default != 'NULL' ? m.Default : '' }}"
                           placeholder="{{ m.Default is not null and m.Default != 'NULL' ? m.Default : '' }}">
                  {% endif %}
                </div>
              {% endfor %}

              <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><path d="M12 5v14m-7-7h14"/></svg>
                  Insérer
                </button>
                <a href="{{ path('admin_db_browse', {table: table}) }}" class="btn btn-ghost-secondary">Annuler</a>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
{% endblock %}
