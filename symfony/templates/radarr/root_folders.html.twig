{% extends 'base.html.twig' %}
{% block title %}Dossiers racine — Radarr{% endblock %}
{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col"><h2 class="page-title">Dossiers racine</h2></div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modal-rf">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          Ajouter
        </button>
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>
<div class="page-body"><div class="container-xl">
{% if error %}<div class="alert alert-danger">Impossible de joindre Radarr.</div>{% endif %}
<div id="rf-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header"><h3 class="card-title">Dossiers configurés</h3><div class="card-options"><span class="badge bg-secondary-lt">{{ folders|length }}</span></div></div>
  <div class="card-body p-0">
    {% if folders is empty %}
      <div class="text-muted text-center py-5">Aucun dossier racine configuré.</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter mb-0">
          <thead><tr><th>Chemin</th><th>Espace libre</th><th>Espace total</th><th>Films</th><th class="text-end">Actions</th></tr></thead>
          <tbody>
            {% for folder in folders %}
            <tr>
              <td class="fw-medium font-monospace small">{{ folder.path ?? '—' }}</td>
              <td class="text-muted">{{ folder.freeSpace is defined ? (folder.freeSpace / 1073741824)|round(1) ~ ' Go' : '—' }}</td>
              <td class="text-muted">{{ folder.totalSpace is defined ? (folder.totalSpace / 1073741824)|round(1) ~ ' Go' : '—' }}</td>
              <td class="text-muted">{{ folder.unmappedFolders is defined ? folder.unmappedFolders|length : '—' }}</td>
              <td class="text-end">
                <button class="btn btn-ghost-danger btn-sm btn-rf-delete" data-id="{{ folder.id }}" data-path="{{ folder.path ?? '' }}">Supprimer</button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

</div></div>

<div class="modal modal-blur fade" id="modal-rf" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Ajouter un dossier racine</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label fw-medium">Chemin <span class="text-danger">*</span></label>
          <input type="text" id="rf-path" class="form-control font-monospace" placeholder="/data/films">
          <small class="text-muted">Chemin absolu accessible par Radarr.</small>
        </div>
        <div id="rf-modal-feedback" class="alert d-none mt-3"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="button" class="btn btn-success" id="btn-rf-save">Ajouter</button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
const feedback = document.getElementById('rf-feedback');
function showFeedback(msg, type = 'success') {
  feedback.className = `alert alert-${type} mb-3`;
  feedback.textContent = msg;
  feedback.classList.remove('d-none');
  setTimeout(() => feedback.classList.add('d-none'), 4000);
}

document.getElementById('btn-rf-save')?.addEventListener('click', async () => {
  const path = document.getElementById('rf-path').value.trim();
  const mfb  = document.getElementById('rf-modal-feedback');
  if (!path) { mfb.className = 'alert alert-warning mt-3'; mfb.textContent = 'Le chemin est obligatoire.'; mfb.classList.remove('d-none'); return; }
  const r = await fetch('{{ path('radarr_root_folder_add') }}', {
    method: 'POST',
    headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
    body: JSON.stringify({path}),
  });
  const data = await r.json();
  if (data.ok) { location.reload(); return; }
  else { mfb.className = 'alert alert-danger mt-3'; mfb.textContent = data.error || 'Erreur — vérifiez que le chemin existe et est accessible par Radarr.'; mfb.classList.remove('d-none'); }
});

document.querySelectorAll('.btn-rf-delete').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (!confirm(`Supprimer le dossier "${btn.dataset.path}" ?\n⚠️ Les films qu'il contient ne seront pas supprimés.`)) return;
    const r = await fetch(`/radarr/dossiers-racine/${btn.dataset.id}/supprimer`, {
      method: 'POST', headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'}, body: '{}',
    });
    const data = await r.json();
    if (data.ok) location.reload();
    else showFeedback('Erreur lors de la suppression.', 'danger');
  });
});
})();
</script>
{% endblock %}
