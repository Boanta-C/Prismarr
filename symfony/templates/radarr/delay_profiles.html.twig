{% extends 'base.html.twig' %}

{% block title %}Profils de delai — Radarr{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Profils de delai</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modal-dp">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          Ajouter
        </button>
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">Impossible de joindre Radarr.</div>
{% endif %}

<div id="delay-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">Profils de delai</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt">{{ profiles|length }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% if profiles is empty %}
      <div class="text-muted text-center py-5">Aucun profil de delai.</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter mb-0">
          <thead>
            <tr>
              <th>Ordre</th>
              <th>Tags</th>
              <th>Usenet</th>
              <th>Torrent</th>
              <th>Protocole pref.</th>
              <th>Delai Usenet (min)</th>
              <th>Delai Torrent (min)</th>
              <th>Bypass si cutoff atteint</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for profile in profiles %}
            <tr>
              <td>{{ profile.order ?? '—' }}</td>
              <td>
                {% if profile.tags is defined and profile.tags %}
                  {% for tag in profile.tags %}
                    <span class="badge bg-secondary-lt me-1">{{ tag }}</span>
                  {% endfor %}
                {% else %}
                  <span class="text-muted small">Global</span>
                {% endif %}
              </td>
              <td>
                {% if profile.enableUsenet ?? false %}
                  <span class="badge bg-success-lt text-success">Oui</span>
                {% else %}
                  <span class="badge bg-secondary-lt">Non</span>
                {% endif %}
              </td>
              <td>
                {% if profile.enableTorrent ?? false %}
                  <span class="badge bg-success-lt text-success">Oui</span>
                {% else %}
                  <span class="badge bg-secondary-lt">Non</span>
                {% endif %}
              </td>
              <td class="text-muted">{{ profile.preferredProtocol ?? '—' }}</td>
              <td class="text-muted">{{ profile.usenetDelay ?? '—' }}</td>
              <td class="text-muted">{{ profile.torrentDelay ?? '—' }}</td>
              <td>
                {% if profile.bypassIfHighestQuality ?? false %}
                  <span class="badge bg-success-lt text-success">Oui</span>
                {% else %}
                  <span class="badge bg-secondary-lt">Non</span>
                {% endif %}
              </td>
              <td class="text-end d-flex gap-2 justify-content-end">
                <button class="btn btn-ghost-secondary btn-icon"
                        data-bs-toggle="modal" data-bs-target="#modal-dp"
                        data-edit-item="{{ profile|json_encode|e('html_attr') }}" title="Modifier">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                </button>
                {% if profile.id is defined and profiles|length > 1 %}
                  <button class="btn btn-ghost-danger btn-icon btn-delay-delete"
                          data-id="{{ profile.id }}" title="Supprimer">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                  </button>
                {% else %}
                  <span class="text-muted small">Defaut</span>
                {% endif %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

</div>
</div>

{# Modal creation/edition profil de delai #}
<div class="modal modal-blur fade" id="modal-dp" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modal-dp-title">Nouveau profil de delai</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-6">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="dp-enable-usenet" checked>
              <label class="form-check-label" for="dp-enable-usenet">Activer Usenet</label>
            </div>
          </div>
          <div class="col-6">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="dp-enable-torrent" checked>
              <label class="form-check-label" for="dp-enable-torrent">Activer Torrent</label>
            </div>
          </div>
          <div class="col-12">
            <label class="form-label fw-medium">Protocole prefere</label>
            <select class="form-select form-select-sm" id="dp-preferred-protocol">
              <option value="usenet">Usenet</option>
              <option value="torrent">Torrent</option>
            </select>
          </div>
          <div class="col-6">
            <label class="form-label fw-medium">Delai Usenet (min)</label>
            <input type="number" class="form-control form-control-sm" id="dp-usenet-delay" value="0" min="0">
          </div>
          <div class="col-6">
            <label class="form-label fw-medium">Delai Torrent (min)</label>
            <input type="number" class="form-control form-control-sm" id="dp-torrent-delay" value="0" min="0">
          </div>
          <div class="col-12">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="dp-bypass-highest">
              <label class="form-check-label" for="dp-bypass-highest">Bypass si meilleure qualite atteinte</label>
            </div>
          </div>
          <div class="col-12">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="dp-bypass-cf-score">
              <label class="form-check-label" for="dp-bypass-cf-score">Bypass si score format custom depasse</label>
            </div>
          </div>
          <div class="col-6">
            <label class="form-label fw-medium">Score min. format custom</label>
            <input type="number" class="form-control form-control-sm" id="dp-min-cf-score" value="0" min="0">
          </div>
          <div class="col-6">
            <label class="form-label fw-medium">Tags (IDs, virgules)</label>
            <input type="text" class="form-control form-control-sm" id="dp-tags" placeholder="Ex: 1,3,5">
            <small class="text-muted">Identifiants des tags, separes par des virgules.</small>
          </div>
        </div>
        <div id="dp-modal-feedback" class="alert d-none mt-3"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="button" class="btn btn-primary" id="btn-dp-save">Creer</button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
  var feedback = document.getElementById('delay-feedback');
  var editingItem = null;

  function showFeedback(msg, type) {
    feedback.className = 'alert alert-' + type + ' mb-3';
    feedback.textContent = msg;
    feedback.classList.remove('d-none');
    setTimeout(function(){ feedback.classList.add('d-none'); }, 4000);
  }

  function showModalFeedback(msg, type) {
    var mfb = document.getElementById('dp-modal-feedback');
    mfb.className = 'alert alert-' + type + ' mt-3';
    mfb.textContent = msg;
    mfb.classList.remove('d-none');
  }

  function hideModalFeedback() {
    document.getElementById('dp-modal-feedback').classList.add('d-none');
  }

  // Modal show — populate for edit or reset for create
  document.getElementById('modal-dp').addEventListener('show.bs.modal', function(e) {
    hideModalFeedback();
    var raw = e.relatedTarget ? (e.relatedTarget.dataset.editItem || null) : null;
    editingItem = raw ? JSON.parse(raw) : null;

    if (editingItem) {
      document.getElementById('modal-dp-title').textContent = 'Modifier le profil #' + editingItem.id;
      document.getElementById('dp-enable-usenet').checked = editingItem.enableUsenet !== false;
      document.getElementById('dp-enable-torrent').checked = editingItem.enableTorrent !== false;
      document.getElementById('dp-preferred-protocol').value = editingItem.preferredProtocol || 'usenet';
      document.getElementById('dp-usenet-delay').value = editingItem.usenetDelay || 0;
      document.getElementById('dp-torrent-delay').value = editingItem.torrentDelay || 0;
      document.getElementById('dp-bypass-highest').checked = editingItem.bypassIfHighestQuality || false;
      document.getElementById('dp-bypass-cf-score').checked = editingItem.bypassIfAboveCustomFormatScore || false;
      document.getElementById('dp-min-cf-score').value = editingItem.minimumCustomFormatScore || 0;
      document.getElementById('dp-tags').value = (editingItem.tags || []).join(',');
      document.getElementById('btn-dp-save').textContent = 'Enregistrer';
    } else {
      document.getElementById('modal-dp-title').textContent = 'Nouveau profil de delai';
      document.getElementById('dp-enable-usenet').checked = true;
      document.getElementById('dp-enable-torrent').checked = true;
      document.getElementById('dp-preferred-protocol').value = 'usenet';
      document.getElementById('dp-usenet-delay').value = 0;
      document.getElementById('dp-torrent-delay').value = 0;
      document.getElementById('dp-bypass-highest').checked = false;
      document.getElementById('dp-bypass-cf-score').checked = false;
      document.getElementById('dp-min-cf-score').value = 0;
      document.getElementById('dp-tags').value = '';
      document.getElementById('btn-dp-save').textContent = 'Creer';
    }
  });

  // Save handler
  document.getElementById('btn-dp-save').addEventListener('click', function() {
    hideModalFeedback();
    var tagsRaw = document.getElementById('dp-tags').value.trim();
    var tags = [];
    if (tagsRaw) {
      tags = tagsRaw.split(',').map(function(t){ return parseInt(t.trim()); }).filter(function(n){ return !isNaN(n); });
    }

    var payload = {
      enableUsenet: document.getElementById('dp-enable-usenet').checked,
      enableTorrent: document.getElementById('dp-enable-torrent').checked,
      preferredProtocol: document.getElementById('dp-preferred-protocol').value,
      usenetDelay: parseInt(document.getElementById('dp-usenet-delay').value) || 0,
      torrentDelay: parseInt(document.getElementById('dp-torrent-delay').value) || 0,
      bypassIfHighestQuality: document.getElementById('dp-bypass-highest').checked,
      bypassIfAboveCustomFormatScore: document.getElementById('dp-bypass-cf-score').checked,
      minimumCustomFormatScore: parseInt(document.getElementById('dp-min-cf-score').value) || 0,
      tags: tags
    };

    var url, verb;
    if (editingItem) {
      payload.id = editingItem.id;
      payload.order = editingItem.order;
      url = '/radarr/profils-delai/' + editingItem.id + '/modifier';
    } else {
      url = {{ path('radarr_delay_profile_add')|json_encode|raw }};
    }

    fetch(url, {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: JSON.stringify(payload)
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if (data.ok) {
        location.reload();
      } else {
        showModalFeedback(data.error || 'Erreur lors de l\'enregistrement.', 'danger');
      }
    })
    .catch(function(err){
      showModalFeedback('Erreur reseau : ' + (err.message || err), 'danger');
    });
  });

  // Delete handlers
  document.querySelectorAll('.btn-delay-delete').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (!confirm('Supprimer ce profil de delai ?')) return;
      fetch('/radarr/profils-delai/' + btn.dataset.id + '/supprimer', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: '{}'
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.ok) location.reload();
        else showFeedback('Erreur lors de la suppression.', 'danger');
      });
    });
  });
})();
</script>
{% endblock %}
