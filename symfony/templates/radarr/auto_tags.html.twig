{% extends 'base.html.twig' %}

{% block title %}Auto-Tags — Radarr{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Auto-Tags</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modal-at">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          Ajouter
        </button>
        <a href="{{ path('radarr_tags') }}" class="btn btn-ghost-secondary btn-sm">Tags</a>
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">Impossible de joindre Radarr.</div>
{% endif %}

<div id="at-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">Regles d'auto-tagging</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt">{{ tags|length }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% if tags is empty %}
      <div class="text-muted text-center py-5">Aucune regle d'auto-tagging.</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter mb-0">
          <thead>
            <tr>
              <th>Nom</th>
              <th>Conditions</th>
              <th>Tags appliques</th>
              <th>Supprimer si non correspondant</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for tag in tags %}
            <tr>
              <td class="fw-medium">{{ tag.name ?? '—' }}</td>
              <td class="text-muted small">{{ tag.specifications is defined ? tag.specifications|length : 0 }} condition(s)</td>
              <td>
                <div class="d-flex flex-wrap gap-1">
                  {% if tag.tags is defined %}
                    {% for t in tag.tags %}
                      <span class="badge bg-blue-lt">{{ t }}</span>
                    {% endfor %}
                  {% endif %}
                </div>
              </td>
              <td>
                {% if tag.removeTagsAutomatically ?? false %}
                  <span class="badge bg-warning-lt text-warning">Oui</span>
                {% else %}
                  <span class="badge bg-secondary-lt">Non</span>
                {% endif %}
              </td>
              <td class="text-end d-flex gap-2 justify-content-end">
                <button class="btn btn-ghost-secondary btn-icon"
                        data-bs-toggle="modal" data-bs-target="#modal-at"
                        data-edit-item="{{ tag|json_encode|e('html_attr') }}" title="Modifier">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                </button>
                <button class="btn btn-ghost-danger btn-icon btn-at-delete"
                        data-id="{{ tag.id }}"
                        data-name="{{ tag.name ?? '' }}" title="Supprimer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                </button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

</div>
</div>

{# Modal creation/edition auto-tag #}
<div class="modal modal-blur fade" id="modal-at" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modal-at-title">Nouvelle regle d'auto-tagging</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label fw-medium">Nom <span class="text-danger">*</span></label>
            <input type="text" class="form-control form-control-sm" id="at-name" placeholder="Nom de la regle">
          </div>
          <div class="col-6">
            <label class="form-label fw-medium">Tags (IDs, virgules)</label>
            <input type="text" class="form-control form-control-sm" id="at-tags" placeholder="Ex: 1,3,5">
            <small class="text-muted">Identifiants des tags a appliquer.</small>
          </div>
          <div class="col-6 d-flex align-items-end">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="at-remove-auto">
              <label class="form-check-label" for="at-remove-auto">Retirer les tags si non correspondant</label>
            </div>
          </div>
          <div class="col-12">
            <hr>
            <div class="d-flex align-items-center justify-content-between mb-2">
              <label class="form-label fw-medium mb-0">Specifications (conditions)</label>
              <button type="button" class="btn btn-outline-primary btn-sm" id="btn-at-add-spec">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
                Ajouter
              </button>
            </div>
            <div id="at-specs-container"></div>
            <div id="at-no-specs" class="text-muted small text-center py-3">Aucune condition. Cliquez sur "Ajouter" pour commencer.</div>
          </div>
        </div>
        <div id="at-modal-feedback" class="alert d-none mt-3"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="button" class="btn btn-primary" id="btn-at-save">Creer</button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
.at-spec-card {
  border: 1px solid var(--tblr-border-color);
  border-radius: .5rem;
  padding: .75rem;
  margin-bottom: .5rem;
  background: var(--tblr-bg-surface-secondary);
}
.at-spec-card .at-spec-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: .5rem;
}
.at-spec-card .at-spec-title {
  font-weight: 600;
  font-size: .85rem;
}
</style>
{% endblock %}

{% block javascripts %}
<script>
(function(){
  var feedback = document.getElementById('at-feedback');
  var editingItem = null;
  var specIndex = 0;

  function showFeedback(msg, type) {
    feedback.className = 'alert alert-' + type + ' mb-3';
    feedback.textContent = msg;
    feedback.classList.remove('d-none');
    setTimeout(function(){ feedback.classList.add('d-none'); }, 4000);
  }

  function showModalFeedback(msg, type) {
    var mfb = document.getElementById('at-modal-feedback');
    mfb.className = 'alert alert-' + type + ' mt-3';
    mfb.textContent = msg;
    mfb.classList.remove('d-none');
  }

  function hideModalFeedback() {
    document.getElementById('at-modal-feedback').classList.add('d-none');
  }

  function updateNoSpecsMsg() {
    var container = document.getElementById('at-specs-container');
    var msg = document.getElementById('at-no-specs');
    msg.style.display = container.children.length === 0 ? '' : 'none';
  }

  // Known implementation types for auto-tagging conditions
  var SPEC_TYPES = [
    {value: 'RootFolderSpecification', label: 'Dossier racine'},
    {value: 'QualityProfileSpecification', label: 'Profil de qualite'},
    {value: 'GenreSpecification', label: 'Genre'},
    {value: 'YearSpecification', label: 'Annee'},
    {value: 'OriginalLanguageSpecification', label: 'Langue originale'},
    {value: 'MovieStatusSpecification', label: 'Statut du film'}
  ];

  function createSpecCard(existingSpec) {
    var idx = specIndex++;
    var card = document.createElement('div');
    card.className = 'at-spec-card';
    card.dataset.specIdx = idx;

    var nameVal = existingSpec ? (existingSpec.name || '') : '';
    var implVal = existingSpec ? (existingSpec.implementation || '') : '';
    var negateChecked = (existingSpec && existingSpec.negate) ? ' checked' : '';
    var requiredChecked = (existingSpec && existingSpec.required) ? ' checked' : '';

    // Build implementation select
    var implOptions = '<option value="">-- Type de condition --</option>';
    SPEC_TYPES.forEach(function(t) {
      var selected = (t.value === implVal) ? ' selected' : '';
      implOptions += '<option value="' + t.value + '"' + selected + '>' + t.label + '</option>';
    });
    // If the implementation is not in our known list, add it as option
    if (implVal && !SPEC_TYPES.some(function(t){ return t.value === implVal; })) {
      implOptions += '<option value="' + implVal + '" selected>' + implVal + '</option>';
    }

    // Fields JSON from existing spec
    var fieldsJson = '';
    if (existingSpec && existingSpec.fields && existingSpec.fields.length > 0) {
      fieldsJson = JSON.stringify(existingSpec.fields, null, 2);
    }

    card.innerHTML = '<div class="at-spec-header">'
      + '<span class="at-spec-title">Condition #' + (idx + 1) + '</span>'
      + '<button type="button" class="btn btn-ghost-danger btn-sm btn-remove-spec">'
      + '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>'
      + '</button>'
      + '</div>'
      + '<div class="row g-2 mb-2">'
      + '<div class="col-md-5">'
      + '<label class="form-label small">Type</label>'
      + '<select class="form-select form-select-sm spec-impl-select">' + implOptions + '</select>'
      + '</div>'
      + '<div class="col-md-4">'
      + '<label class="form-label small">Nom</label>'
      + '<input type="text" class="form-control form-control-sm spec-name-input" value="' + nameVal.replace(/"/g, '&quot;') + '" placeholder="Nom...">'
      + '</div>'
      + '<div class="col-md-3 d-flex align-items-end gap-2">'
      + '<div class="form-check">'
      + '<input class="form-check-input spec-negate-check" type="checkbox"' + negateChecked + '>'
      + '<label class="form-check-label small">Inverser</label>'
      + '</div>'
      + '<div class="form-check">'
      + '<input class="form-check-input spec-required-check" type="checkbox"' + requiredChecked + '>'
      + '<label class="form-check-label small">Requis</label>'
      + '</div>'
      + '</div>'
      + '</div>'
      + '<div class="mb-1">'
      + '<label class="form-label small">Champs (JSON)</label>'
      + '<textarea class="form-control form-control-sm font-monospace spec-fields-json" rows="3" placeholder=\'[{"name":"value","value":"..."}]\'>' + fieldsJson.replace(/</g, '&lt;') + '</textarea>'
      + '<small class="text-muted">Format : tableau JSON des champs de la condition.</small>'
      + '</div>';

    card.querySelector('.btn-remove-spec').addEventListener('click', function() {
      card.remove();
      updateNoSpecsMsg();
    });

    document.getElementById('at-specs-container').appendChild(card);
    updateNoSpecsMsg();
    return card;
  }

  function collectSpecs() {
    var cards = document.querySelectorAll('#at-specs-container .at-spec-card');
    var specs = [];
    cards.forEach(function(card) {
      var impl = card.querySelector('.spec-impl-select').value;
      if (!impl) return;
      var name = card.querySelector('.spec-name-input').value.trim() || impl;
      var negate = card.querySelector('.spec-negate-check').checked;
      var required = card.querySelector('.spec-required-check').checked;

      var fieldsRaw = card.querySelector('.spec-fields-json').value.trim();
      var fields = [];
      if (fieldsRaw) {
        try { fields = JSON.parse(fieldsRaw); } catch(e) { /* ignore parse errors */ }
      }

      specs.push({
        name: name,
        implementation: impl,
        negate: negate,
        required: required,
        fields: fields
      });
    });
    return specs;
  }

  // Modal show — populate for edit or reset for create
  document.getElementById('modal-at').addEventListener('show.bs.modal', function(e) {
    hideModalFeedback();
    specIndex = 0;
    document.getElementById('at-specs-container').innerHTML = '';

    var raw = e.relatedTarget ? (e.relatedTarget.dataset.editItem || null) : null;
    editingItem = raw ? JSON.parse(raw) : null;

    if (editingItem) {
      document.getElementById('modal-at-title').textContent = 'Modifier : ' + (editingItem.name || 'Regle');
      document.getElementById('at-name').value = editingItem.name || '';
      document.getElementById('at-tags').value = (editingItem.tags || []).join(',');
      document.getElementById('at-remove-auto').checked = editingItem.removeTagsAutomatically || false;
      document.getElementById('btn-at-save').textContent = 'Enregistrer';

      // Populate existing specs
      if (editingItem.specifications && editingItem.specifications.length > 0) {
        editingItem.specifications.forEach(function(spec) {
          createSpecCard(spec);
        });
      }
    } else {
      document.getElementById('modal-at-title').textContent = 'Nouvelle regle d\'auto-tagging';
      document.getElementById('at-name').value = '';
      document.getElementById('at-tags').value = '';
      document.getElementById('at-remove-auto').checked = false;
      document.getElementById('btn-at-save').textContent = 'Creer';
    }
    updateNoSpecsMsg();
  });

  // Add spec button
  document.getElementById('btn-at-add-spec').addEventListener('click', function() {
    createSpecCard(null);
  });

  // Save handler
  document.getElementById('btn-at-save').addEventListener('click', function() {
    hideModalFeedback();
    var name = document.getElementById('at-name').value.trim();
    if (!name) {
      showModalFeedback('Le nom est obligatoire.', 'warning');
      return;
    }

    var tagsRaw = document.getElementById('at-tags').value.trim();
    var tags = [];
    if (tagsRaw) {
      tags = tagsRaw.split(',').map(function(t){ return parseInt(t.trim()); }).filter(function(n){ return !isNaN(n); });
    }

    var payload = {
      name: name,
      removeTagsAutomatically: document.getElementById('at-remove-auto').checked,
      tags: tags,
      specifications: collectSpecs()
    };

    var url;
    if (editingItem) {
      payload.id = editingItem.id;
      url = '/radarr/auto-tags/' + editingItem.id + '/modifier';
    } else {
      url = {{ path('radarr_auto_tag_add')|json_encode|raw }};
    }

    fetch(url, {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: JSON.stringify(payload)
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if (data.ok) {
        location.reload();
      } else {
        showModalFeedback(data.error || 'Erreur lors de l\'enregistrement.', 'danger');
      }
    })
    .catch(function(err){
      showModalFeedback('Erreur reseau : ' + (err.message || err), 'danger');
    });
  });

  // Delete handlers
  document.querySelectorAll('.btn-at-delete').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (!confirm('Supprimer la regle "' + btn.dataset.name + '" ?')) return;
      fetch('/radarr/auto-tags/' + btn.dataset.id + '/supprimer', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: '{}'
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.ok) location.reload();
        else showFeedback('Erreur lors de la suppression.', 'danger');
      });
    });
  });
})();
</script>
{% endblock %}
