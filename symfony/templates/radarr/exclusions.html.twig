{% extends 'base.html.twig' %}

{% block title %}Exclusions d'import Radarr{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Exclusions d'import</h2>
      </div>
      <div class="col-auto ms-auto">
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">Impossible de joindre Radarr.</div>
{% endif %}

<div id="excl-feedback" class="alert d-none mb-3"></div>

{# Form ajout #}
<div class="card mb-3">
  <div class="card-header">
    <h3 class="card-title">Ajouter une exclusion</h3>
  </div>
  <div class="card-body">
    <form id="form-add-exclusion" class="row g-2 align-items-end">
      <div class="col-sm-3">
        <label class="form-label">TMDB ID</label>
        <input type="number" name="tmdbId" class="form-control" placeholder="12345" required>
      </div>
      <div class="col-sm-5">
        <label class="form-label">Titre du film</label>
        <input type="text" name="movieTitle" class="form-control" placeholder="Titre original" required>
      </div>
      <div class="col-sm-2">
        <label class="form-label">Année</label>
        <input type="number" name="year" class="form-control" placeholder="{{ "now"|date('Y') }}" min="1900" max="2099">
      </div>
      <div class="col-sm-2">
        <button type="submit" class="btn btn-success w-100">Ajouter</button>
      </div>
    </form>
  </div>
</div>

{# Table #}
<div class="card">
  <div class="card-header">
    <h3 class="card-title">Exclusions</h3>
    <div class="card-options gap-2">
      <button id="btn-bulk-delete" class="btn btn-ghost-danger btn-sm d-none">
        Supprimer la sélection
      </button>
      <span class="badge bg-secondary-lt">{{ (exclusions.totalRecords ?? exclusions|length) }} au total</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% set records = exclusions.records ?? exclusions %}
    {% if records is empty %}
      <div class="text-muted text-center py-5">Aucune exclusion.</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter table-hover mb-0">
          <thead>
            <tr>
              <th><input type="checkbox" id="check-all" class="form-check-input"></th>
              <th>Titre</th>
              <th>Année</th>
              <th>TMDB ID</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for ex in records %}
            <tr>
              <td><input type="checkbox" class="form-check-input check-row" value="{{ ex.id }}"></td>
              <td class="fw-medium">{{ ex.movieTitle ?? '—' }}</td>
              <td class="text-muted">{{ ex.year ?? '—' }}</td>
              <td class="text-muted small">{{ ex.tmdbId ?? '—' }}</td>
              <td class="text-end">
                <button class="btn btn-ghost-danger btn-sm btn-excl-delete" data-id="{{ ex.id }}">
                  Supprimer
                </button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
  {% if exclusions.totalPages is defined and exclusions.totalPages > 1 %}
  <div class="card-footer d-flex align-items-center">
    <p class="m-0 text-muted">Page {{ page }} / {{ exclusions.totalPages }}</p>
    <ul class="pagination m-0 ms-auto">
      {% if page > 1 %}
      <li class="page-item"><a class="page-link" href="?page={{ page - 1 }}">«</a></li>
      {% endif %}
      {% if page < exclusions.totalPages %}
      <li class="page-item"><a class="page-link" href="?page={{ page + 1 }}">»</a></li>
      {% endif %}
    </ul>
  </div>
  {% endif %}
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
const feedback = document.getElementById('excl-feedback');
function showFeedback(msg, type = 'success') {
  feedback.className = `alert alert-${type} mb-3`;
  feedback.textContent = msg;
  feedback.classList.remove('d-none');
  setTimeout(() => feedback.classList.add('d-none'), 4000);
}

// Check all
const checkAll = document.getElementById('check-all');
if (checkAll) {
  checkAll.addEventListener('change', () => {
    document.querySelectorAll('.check-row').forEach(c => c.checked = checkAll.checked);
    updateBulkBtn();
  });
  document.querySelectorAll('.check-row').forEach(c => c.addEventListener('change', updateBulkBtn));
}

function updateBulkBtn() {
  const checked = document.querySelectorAll('.check-row:checked');
  const btn = document.getElementById('btn-bulk-delete');
  if (btn) btn.classList.toggle('d-none', checked.length === 0);
}

// Bulk delete
const bulkBtn = document.getElementById('btn-bulk-delete');
if (bulkBtn) {
  bulkBtn.addEventListener('click', async () => {
    const ids = [...document.querySelectorAll('.check-row:checked')].map(c => parseInt(c.value));
    if (!confirm(`Supprimer ${ids.length} exclusion(s) ?`)) return;
    const r = await fetch('{{ path('radarr_exclusion_bulk_delete') }}', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: JSON.stringify({ids}),
    });
    const data = await r.json();
    if (data.ok) location.reload();
    else showFeedback('Erreur suppression.', 'danger');
  });
}

// Supprimer ligne
document.querySelectorAll('.btn-excl-delete').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (!confirm('Supprimer cette exclusion ?')) return;
    const r = await fetch(`/radarr/exclusions/${btn.dataset.id}/supprimer`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}',
    });
    const data = await r.json();
    if (data.ok) location.reload();
    else showFeedback('Erreur.', 'danger');
  });
});

// Form ajout
document.getElementById('form-add-exclusion').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = {
    tmdbId: parseInt(fd.get('tmdbId')),
    movieTitle: fd.get('movieTitle'),
    year: parseInt(fd.get('year') || 0),
  };
  const r = await fetch('{{ path('radarr_exclusion_add') }}', {
    method: 'POST',
    headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
    body: JSON.stringify(body),
  });
  const data = await r.json();
  if (data.ok) {
    showFeedback('Exclusion ajoutée.');
    e.target.reset();
    setTimeout(() => location.reload(), 1000);
  } else {
    showFeedback('Erreur lors de l\'ajout.', 'danger');
  }
});
})();
</script>
{% endblock %}
