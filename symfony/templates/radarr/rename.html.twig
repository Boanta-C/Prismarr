{% extends 'base.html.twig' %}

{% block title %}Renommer — Radarr{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Renommer des fichiers</h2>
      </div>
      <div class="col-auto ms-auto">
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">Impossible de joindre Radarr.</div>
{% endif %}

<div class="row g-3">
  <div class="col-12 col-md-4">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Choisir un film</h3>
      </div>
      <div class="card-body">
        <select class="form-select" id="movie-select">
          <option value="">— Sélectionner un film —</option>
          {% for movie in movies %}
          <option value="{{ movie.id }}">{{ movie.title }}{% if movie.year %} ({{ movie.year }}){% endif %}</option>
          {% endfor %}
        </select>
        <div id="proposals-loading" class="text-center mt-3 d-none">
          <div class="spinner-border spinner-border-sm"></div>
          <span class="ms-2 text-muted small">Chargement...</span>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-8">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Propositions de renommage</h3>
        <div class="card-options">
          <button id="btn-rename-all" class="btn btn-warning btn-sm d-none">
            Renommer tout
          </button>
        </div>
      </div>
      <div class="card-body" id="proposals-container">
        <div class="text-muted text-center py-5">Sélectionnez un film pour voir les propositions.</div>
      </div>
    </div>
  </div>
</div>

<div id="rename-progress" class="alert alert-info d-none mt-3">
  <div class="d-flex align-items-center gap-2">
    <div class="spinner-border spinner-border-sm"></div>
    <span id="rename-msg">Renommage en cours...</span>
  </div>
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
let currentMovieId = null;

document.getElementById('movie-select').addEventListener('change', async (e) => {
  const id = e.target.value;
  if (!id) {
    document.getElementById('proposals-container').innerHTML = '<div class="text-muted text-center py-5">Sélectionnez un film pour voir les propositions.</div>';
    document.getElementById('btn-rename-all').classList.add('d-none');
    currentMovieId = null;
    return;
  }
  currentMovieId = parseInt(id);
  document.getElementById('proposals-loading').classList.remove('d-none');
  document.getElementById('btn-rename-all').classList.add('d-none');

  try {
    const r = await fetch(`/radarr/renommer/${id}/propositions`, {
      headers: {'X-Requested-With': 'XMLHttpRequest'},
    });
    const proposals = await r.json();
    document.getElementById('proposals-loading').classList.add('d-none');

    if (!proposals || proposals.length === 0) {
      document.getElementById('proposals-container').innerHTML = '<div class="text-muted text-center py-5">Aucun renommage nécessaire.</div>';
      return;
    }

    document.getElementById('btn-rename-all').classList.remove('d-none');
    let html = '<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Chemin actuel</th><th>Nouveau chemin</th></tr></thead><tbody>';
    proposals.forEach(p => {
      const current = p.existingPath ?? '—';
      const newPath = p.newPath ?? '—';
      const changed = current !== newPath;
      html += `<tr class="${changed ? '' : 'text-muted'}">
        <td class="small text-muted" style="word-break:break-all;max-width:300px">${current}</td>
        <td class="small fw-medium" style="word-break:break-all;max-width:300px">${newPath}</td>
      </tr>`;
    });
    html += '</tbody></table></div>';
    document.getElementById('proposals-container').innerHTML = html;
  } catch(e) {
    document.getElementById('proposals-loading').classList.add('d-none');
    document.getElementById('proposals-container').innerHTML = '<div class="alert alert-danger">Erreur lors du chargement.</div>';
  }
});

document.getElementById('btn-rename-all').addEventListener('click', async () => {
  if (!currentMovieId) return;
  document.getElementById('btn-rename-all').disabled = true;
  const progress = document.getElementById('rename-progress');
  const msg = document.getElementById('rename-msg');
  progress.classList.remove('d-none');
  msg.textContent = 'Lancement du renommage...';

  try {
    const r = await fetch(`/radarr/renommer/${currentMovieId}/executer`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}',
    });
    const data = await r.json();
    if (!data.ok || !data.cmdId) { msg.textContent = 'Erreur.'; return; }

    const poll = setInterval(async () => {
      const sr = await fetch(`{{ path('radarr_command_status', {cmdId: '__ID__'}) }}`.replace('__ID__', data.cmdId));
      const s = await sr.json();
      msg.textContent = `Renommage : ${s.status ?? '?'}`;
      if (s.status === 'completed' || s.status === 'failed') {
        clearInterval(poll);
        document.getElementById('btn-rename-all').disabled = false;
        if (s.status === 'completed') msg.textContent = 'Renommage terminé.';
      }
    }, 3000);
  } catch(e) {
    msg.textContent = 'Erreur réseau.';
  }
});
})();
</script>
{% endblock %}
