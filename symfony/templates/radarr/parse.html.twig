{% extends 'base.html.twig' %}
{% block title %}Parser un titre — Radarr{% endblock %}
{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col"><h2 class="page-title">Parser un titre</h2></div>
      <div class="col-auto ms-auto">{% include 'media/_radarr_nav.html.twig' %}</div>
    </div>
  </div>
</div>
<div class="page-body"><div class="container-xl">

<div class="card mb-4">
  <div class="card-body">
    <form method="GET" action="{{ path('radarr_parse') }}" class="d-flex gap-2">
      <input type="text" name="title" class="form-control" placeholder="Ex: The.Dark.Knight.2008.1080p.BluRay.x264" value="{{ title }}">
      <button type="submit" class="btn btn-primary">Parser</button>
    </form>
  </div>
</div>

{% if error %}
  <div class="alert alert-danger">Erreur lors du parsing.</div>
{% elseif result %}
  <div class="card">
    <div class="card-header"><h3 class="card-title">Résultat du parsing</h3></div>
    <div class="card-body">
      <dl class="row">
        <dt class="col-sm-3">Titre parsé</dt>
        <dd class="col-sm-9">{{ result.title ?? result.parsedMovieInfo.movieTitle ?? '—' }}</dd>
        <dt class="col-sm-3">Année</dt>
        <dd class="col-sm-9">{{ result.parsedMovieInfo.year ?? '—' }}</dd>
        <dt class="col-sm-3">Qualité</dt>
        <dd class="col-sm-9">{{ result.parsedMovieInfo.quality.quality.name ?? '—' }}</dd>
        <dt class="col-sm-3">Edition</dt>
        <dd class="col-sm-9">{{ result.parsedMovieInfo.edition ?? '—' }}</dd>
        <dt class="col-sm-3">Langues</dt>
        <dd class="col-sm-9">
          {% for lang in (result.parsedMovieInfo.languages ?? []) %}
            <span class="badge bg-blue-lt">{{ lang.name ?? lang }}</span>
          {% else %}—{% endfor %}
        </dd>
        {% if result.movie is defined and result.movie %}
        <dt class="col-sm-3">Film correspondant</dt>
        <dd class="col-sm-9">
          <a href="{{ path('app_media_films') }}" class="fw-medium">{{ result.movie.title ?? '—' }}</a>
          ({{ result.movie.year ?? '' }})
        </dd>
        {% endif %}
      </dl>
    </div>
  </div>
{% elseif title %}
  <div class="alert alert-warning">Aucun résultat pour ce titre.</div>
{% endif %}

</div></div>
{% endblock %}
