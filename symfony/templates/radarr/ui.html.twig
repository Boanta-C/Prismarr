{% extends 'base.html.twig' %}

{% block title %}Interface — Radarr{% endblock %}

{% block stylesheets %}
<style>
.setting-row {
  display: flex;
  align-items: flex-start;
  padding: .6rem 0;
  border-bottom: 1px solid var(--tblr-border-color);
}
.setting-row:last-child { border-bottom: none; }
.setting-label {
  min-width: 200px;
  max-width: 200px;
  font-weight: 600;
  font-size: .85rem;
  padding-top: .4rem;
}
.setting-field { flex: 1; }
.setting-hint {
  font-size: .75rem;
  color: var(--tblr-secondary);
  margin-top: .2rem;
}
</style>
{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col"><h2 class="page-title">Interface (UI)</h2></div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">Impossible de joindre Radarr.</div>
{% endif %}

<div class="d-flex justify-content-between align-items-center mb-3">
  <div id="ui-feedback" class="alert d-none mb-0 flex-fill me-3"></div>
  <button type="submit" form="form-ui" class="btn btn-primary btn-sm flex-shrink-0">
    <span class="spinner-border spinner-border-sm d-none me-1" id="ui-spinner"></span>
    Enregistrer
  </button>
</div>

{% if uiConfig %}
<form id="form-ui">

{# ── Dates & Heures ────────────────────────────────────────────────── #}
<div class="card mb-3">
  <div class="card-header"><h3 class="card-title">Dates & Heures</h3></div>
  <div class="card-body py-2">
    <div class="setting-row">
      <div class="setting-label">Premier jour</div>
      <div class="setting-field">
        <select name="firstDayOfWeek" class="form-select form-select-sm" style="max-width:200px;">
          <option value="0" {{ (uiConfig.firstDayOfWeek ?? 0) == 0 ? 'selected' }}>Dimanche</option>
          <option value="1" {{ (uiConfig.firstDayOfWeek ?? 0) == 1 ? 'selected' }}>Lundi</option>
        </select>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">En-tête calendrier</div>
      <div class="setting-field">
        <input type="text" name="calendarWeekColumnHeader" class="form-control form-control-sm" value="{{ uiConfig.calendarWeekColumnHeader ?? 'ddd M/D' }}" style="max-width:200px;">
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">Date courte</div>
      <div class="setting-field">
        <select name="shortDateFormat" class="form-select form-select-sm" style="max-width:250px;">
          {% for fmt in ['MMM D YYYY', 'DD/MM/YYYY', 'YYYY-MM-DD', 'DD MMM YYYY'] %}
          <option value="{{ fmt }}" {{ (uiConfig.shortDateFormat ?? '') == fmt ? 'selected' }}>{{ fmt }}</option>
          {% endfor %}
        </select>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">Date longue</div>
      <div class="setting-field">
        <select name="longDateFormat" class="form-select form-select-sm" style="max-width:300px;">
          {% for fmt in ['dddd, MMMM D YYYY', 'dddd D MMMM YYYY', 'D MMMM YYYY'] %}
          <option value="{{ fmt }}" {{ (uiConfig.longDateFormat ?? '') == fmt ? 'selected' }}>{{ fmt }}</option>
          {% endfor %}
        </select>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">Heure</div>
      <div class="setting-field">
        <select name="timeFormat" class="form-select form-select-sm" style="max-width:200px;">
          <option value="h(:mm)a" {{ (uiConfig.timeFormat ?? '') == 'h(:mm)a' ? 'selected' }}>12h (4:00pm)</option>
          <option value="HH:mm" {{ (uiConfig.timeFormat ?? '') == 'HH:mm' ? 'selected' }}>24h (16:00)</option>
        </select>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">Dates relatives</div>
      <div class="setting-field">
        <label class="form-check form-switch mb-0">
          <input class="form-check-input" type="checkbox" name="showRelativeDates" {{ (uiConfig.showRelativeDates ?? true) ? 'checked' }}>
        </label>
        <div class="setting-hint">Afficher « il y a 2 jours » au lieu de la date exacte</div>
      </div>
    </div>
  </div>
</div>

{# ── Style ─────────────────────────────────────────────────────────── #}
<div class="card mb-3">
  <div class="card-header"><h3 class="card-title">Style</h3></div>
  <div class="card-body py-2">
    <div class="setting-row">
      <div class="setting-label">Thème</div>
      <div class="setting-field">
        <select name="theme" class="form-select form-select-sm" style="max-width:200px;">
          <option value="auto" {{ (uiConfig.theme ?? 'auto') == 'auto' ? 'selected' }}>Auto</option>
          <option value="light" {{ (uiConfig.theme ?? '') == 'light' ? 'selected' }}>Clair</option>
          <option value="dark" {{ (uiConfig.theme ?? '') == 'dark' ? 'selected' }}>Sombre</option>
        </select>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">Mode daltonien</div>
      <div class="setting-field">
        <label class="form-check form-switch mb-0">
          <input class="form-check-input" type="checkbox" name="enableColorImpairedMode" {{ (uiConfig.enableColorImpairedMode ?? false) ? 'checked' }}>
        </label>
        <div class="setting-hint">Couleurs adaptées pour les personnes daltoniennes</div>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">Durée film</div>
      <div class="setting-field">
        <select name="movieRuntimeFormat" class="form-select form-select-sm" style="max-width:200px;">
          <option value="hoursMinutes" {{ (uiConfig.movieRuntimeFormat ?? '') == 'hoursMinutes' ? 'selected' }}>Heures & Minutes (1h 37m)</option>
          <option value="minutes" {{ (uiConfig.movieRuntimeFormat ?? '') == 'minutes' ? 'selected' }}>Minutes (97 min)</option>
        </select>
      </div>
    </div>
  </div>
</div>

{# ── Langue ────────────────────────────────────────────────────────── #}
<div class="card mb-3">
  <div class="card-header"><h3 class="card-title">Langue</h3></div>
  <div class="card-body py-2">
    <div class="setting-row">
      <div class="setting-label">Langue interface</div>
      <div class="setting-field">
        <select name="uiLanguage" class="form-select form-select-sm" style="max-width:250px;">
          {% for lang in languages %}
            {% if lang.id is defined and lang.id > 0 %}
            <option value="{{ lang.id }}" {{ (uiConfig.uiLanguage ?? 1) == lang.id ? 'selected' }}>{{ lang.name ?? lang.id }}</option>
            {% endif %}
          {% endfor %}
        </select>
        <div class="setting-hint">Langue de l'interface Radarr</div>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">Langue infos film</div>
      <div class="setting-field">
        <select name="movieInfoLanguage" class="form-select form-select-sm" style="max-width:250px;">
          {% for lang in languages %}
            {% if lang.id is defined and lang.id >= -1 %}
            <option value="{{ lang.id }}" {{ (uiConfig.movieInfoLanguage ?? 1) == lang.id ? 'selected' }}>{{ lang.name ?? lang.id }}</option>
            {% endif %}
          {% endfor %}
        </select>
        <div class="setting-hint">Langue utilisée pour les titres et synopsis des films</div>
      </div>
    </div>
  </div>
</div>

</form>
{% else %}
<div class="alert alert-info">Configuration UI indisponible.</div>
{% endif %}

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
var feedback = document.getElementById('ui-feedback');
function showFeedback(msg, type) {
  feedback.className = 'alert alert-' + (type || 'success') + ' mb-3';
  feedback.textContent = msg;
  feedback.classList.remove('d-none');
  setTimeout(function(){ feedback.classList.add('d-none'); }, 5000);
}

var form = document.getElementById('form-ui');
if (form) {
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var spinner = document.getElementById('ui-spinner');
    spinner.classList.remove('d-none');

    var fd = new FormData(form);
    var body = {};
    fd.forEach(function(v, k) {
      body[k] = /^\d+$/.test(v) ? Number(v) : v;
      if (/^-?\d+$/.test(v)) body[k] = Number(v);
    });
    ['showRelativeDates', 'enableColorImpairedMode'].forEach(function(field) {
      body[field] = form.querySelector('[name="' + field + '"]').checked;
    });

    fetch('{{ path('radarr_ui_save') }}', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: JSON.stringify(body),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      spinner.classList.add('d-none');
      if (data.ok !== false && !data.error) showFeedback('Configuration UI sauvegardée.');
      else showFeedback(data.error || 'Erreur lors de la sauvegarde.', 'danger');
    })
    .catch(function() {
      spinner.classList.add('d-none');
      showFeedback('Erreur réseau.', 'danger');
    });
  });
}
})();
</script>
{% endblock %}
