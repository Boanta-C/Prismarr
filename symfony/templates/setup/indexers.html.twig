{% extends 'setup/_layout.html.twig' %}

{% block title %}Indexeurs & requêtes — Prismarr{% endblock %}

{% block max_width %}720px{% endblock %}

{% block wizard_body %}
  <div class="wizard-eyebrow">Étape 5 sur 7 · Optionnel</div>
  <h2 class="wizard-title">Indexeurs & requêtes</h2>
  <p class="wizard-subtitle">
    Prowlarr centralise vos indexeurs trackers. Jellyseerr permet aux utilisateurs
    de faire des demandes de films et séries qui sont ensuite envoyées à Radarr/Sonarr.
  </p>

  <form action="{{ path('app_setup_indexers') }}" method="post" autocomplete="off" novalidate>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('setup_indexers') }}"/>

    <div class="wizard-section">
      <div class="wizard-section-title">🔎 Prowlarr — Indexeurs</div>
      <div class="wizard-section-subtitle">Agrégateur d'indexeurs compatible Radarr/Sonarr.</div>
      <div class="row g-3">
        <div class="col-md-7">
          <label class="form-label" for="prowlarr_url">URL</label>
          <input type="text" id="prowlarr_url" name="prowlarr_url" class="form-control"
                 placeholder="http://host.docker.internal:9696" value="{{ values.prowlarr_url }}"/>
        </div>
        <div class="col-md-5">
          <label class="form-label" for="prowlarr_api_key">Clé API</label>
          <input type="text" id="prowlarr_api_key" name="prowlarr_api_key" class="form-control"
                 placeholder="X-Api-Key" value="{{ values.prowlarr_api_key }}"/>
        </div>
      </div>
    </div>

    <div class="wizard-section">
      <div class="wizard-section-title">🙋 Jellyseerr — Requêtes utilisateurs</div>
      <div class="wizard-section-subtitle">Interface de requêtes pour les utilisateurs finaux.</div>
      <div class="row g-3">
        <div class="col-md-7">
          <label class="form-label" for="jellyseerr_url">URL</label>
          <input type="text" id="jellyseerr_url" name="jellyseerr_url" class="form-control"
                 placeholder="http://host.docker.internal:5055" value="{{ values.jellyseerr_url }}"/>
        </div>
        <div class="col-md-5">
          <label class="form-label" for="jellyseerr_api_key">Clé API</label>
          <input type="text" id="jellyseerr_api_key" name="jellyseerr_api_key" class="form-control"
                 placeholder="X-Api-Key" value="{{ values.jellyseerr_api_key }}"/>
        </div>
      </div>
    </div>

    <div class="wizard-actions">
      <button type="submit" name="_action" value="back" class="btn-wizard-back" formnovalidate>← Précédent</button>
      <div class="wizard-actions-right">
        <button type="submit" name="_action" value="skip" class="btn-wizard-skip" formnovalidate>Passer cette étape</button>
        <button type="submit" name="_action" value="save" class="btn-wizard-next">Enregistrer et continuer →</button>
      </div>
    </div>
  </form>
{% endblock %}
