{% extends 'base.html.twig' %}
{% block title %}Mises à jour — Prowlarr{% endblock %}
{% block head_meta %}<meta name="turbo-visit-control" content="reload">{% endblock %}

{% block body %}
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title d-flex align-items-center gap-2">
                    <svg width="28" height="28" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 32C132.3 32 32 132.3 32 256s100.3 224 224 224 224-100.3 224-224S379.7 32 256 32zm0 400c-97 0-176-79-176-176S159 80 256 80s176 79 176 176-79 176-176 176z" fill="#E88D1A"/><path d="M256 120c-75 0-136 61-136 136s61 136 136 136 136-61 136-136-61-136-136-136zm0 224c-48.6 0-88-39.4-88-88s39.4-88 88-88 88 39.4 88 88-39.4 88-88 88z" fill="#E88D1A"/><circle cx="256" cy="256" r="48" fill="#E88D1A"/></svg>
                    Mises à jour
                </h2>
            </div>
            <div class="col-auto ms-auto">{% include 'prowlarr/_prowlarr_nav.html.twig' %}</div>
        </div>
    </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
    <div class="alert alert-danger d-flex align-items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4"/><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z"/><path d="M12 16h.01"/></svg>
        <div><strong>Impossible de contacter Prowlarr</strong></div>
    </div>
{% endif %}

{% if status is defined and status.packageUpdateMechanism is defined and status.packageUpdateMechanism == 'docker' %}
<div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0"><path d="M12 9v4"/><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z"/><path d="M12 16h.01"/></svg>
    <div class="small">Prowlarr tourne en conteneur Docker. Pour mettre à jour, mettez à jour l'image Docker (ex: <code>docker pull</code> ou via Portainer).</div>
</div>
{% endif %}

{# ── Version actuelle ── #}
{% if status is defined and status is not null %}
<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex align-items-center gap-3">
            <div class="text-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M12 8l0 4"/><path d="M12 16l.01 0"/></svg>
            </div>
            <div>
                <div class="text-secondary small mb-1">Version installée</div>
                <div class="fw-bold fs-4" style="color:#E88D1A">{{ status.version ?? '—' }}</div>
            </div>
            <div class="ms-auto">
                {% set hasInstallable = false %}
                {% for u in updates %}
                    {% if u.installable ?? false %}{% set hasInstallable = true %}{% endif %}
                {% endfor %}
                {% if hasInstallable %}
                    <span class="badge bg-warning-lt text-warning fs-6">Mise à jour disponible</span>
                {% else %}
                    <span class="badge bg-success-lt text-success fs-6">A jour</span>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endif %}

{# ── Liste des mises à jour ── #}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">Historique des versions</h3>
        <div class="card-options">
            <span class="badge bg-secondary-lt">{{ updates|length }}</span>
        </div>
    </div>
    <div class="card-body p-0">
        {% if updates is empty %}
            <div class="text-muted text-center py-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="mb-2 text-success d-block mx-auto"><path d="M5 12l5 5l10 -10"/></svg>
                Prowlarr est à jour.
            </div>
        {% else %}
            <div id="install-progress" class="alert alert-info d-none m-3">
                <div class="d-flex align-items-center gap-2">
                    <div class="spinner-border spinner-border-sm"></div>
                    <span id="install-msg">Installation en cours...</span>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Version</th>
                            <th>Date de sortie</th>
                            <th>Branche</th>
                            <th>Statut</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for update in updates %}
                        <tr>
                            <td class="fw-medium">
                                {{ update.version ?? '—' }}
                                {% if update.latest ?? false %}
                                    <span class="badge bg-purple-lt ms-1" style="font-size:.65rem">Dernière</span>
                                {% endif %}
                            </td>
                            <td class="text-muted small">
                                {% if update.releaseDate is defined %}
                                    {{ update.releaseDate|date('d/m/Y') }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge bg-secondary-lt">{{ update.branch ?? '—' }}</span>
                            </td>
                            <td>
                                {% if update.installed ?? false %}
                                    <span class="badge bg-success-lt text-success">Installée</span>
                                {% elseif update.installable ?? false %}
                                    <span class="badge bg-warning-lt text-warning">Disponible</span>
                                {% else %}
                                    <span class="badge bg-secondary-lt">Ancienne</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                {% if update.installable ?? false %}
                                    {% if status is defined and status.packageUpdateMechanism is defined and status.packageUpdateMechanism == 'docker' %}
                                        <span class="text-secondary small fst-italic">Mettre à jour via Docker</span>
                                    {% else %}
                                        <button class="btn btn-warning btn-sm btn-install"
                                                data-version="{{ update.version ?? '' }}">
                                            Installer {{ update.version ?? '' }}
                                        </button>
                                    {% endif %}
                                {% endif %}
                            </td>
                        </tr>
                        {# Changelog #}
                        {% if update.changes is defined and update.changes %}
                        <tr>
                            <td colspan="5" style="padding:.5rem 1rem;background:rgba(255,255,255,.015);">
                                {% if update.changes.new is defined and update.changes.new %}
                                <div class="mb-2">
                                    <div class="small fw-semibold" style="color:#22c55e;">Nouveautés</div>
                                    <ul class="mb-0" style="font-size:.75rem;padding-left:1.2rem;color:rgba(255,255,255,.6);">
                                        {% for item in update.changes.new %}
                                            <li>{{ item }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                                {% endif %}
                                {% if update.changes.fixed is defined and update.changes.fixed %}
                                <div>
                                    <div class="small fw-semibold" style="color:#38bdf8;">Corrections</div>
                                    <ul class="mb-0" style="font-size:.75rem;padding-left:1.2rem;color:rgba(255,255,255,.6);">
                                        {% for item in update.changes.fixed %}
                                            <li>{{ item }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                                {% endif %}
                            </td>
                        </tr>
                        {% endif %}
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
document.querySelectorAll('.btn-install').forEach(function(btn) {
    btn.addEventListener('click', function() {
        var progress = document.getElementById('install-progress');
        var msg = document.getElementById('install-msg');
        btn.disabled = true;
        progress.classList.remove('d-none');
        msg.textContent = 'Lancement de la mise à jour...';

        fetch('/prowlarr/command', {
            method: 'POST',
            headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
            body: JSON.stringify({name: 'ApplicationUpdateCheck'}),
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.ok) {
                var errMsg = 'Erreur lors du lancement.';
                if (data.error) errMsg = typeof data.error === 'string' ? data.error : JSON.stringify(data.error);
                else if (data.command && data.command.message) errMsg = data.command.message;
                msg.textContent = errMsg;
                progress.classList.remove('alert-info');
                progress.classList.add('alert-danger');
                btn.disabled = false;
                return;
            }
            msg.textContent = 'Vérification des mises à jour lancée. Actualisation dans 5 secondes…';
            setTimeout(function(){ location.reload(); }, 5000);
        })
        .catch(function(err) {
            msg.textContent = 'Erreur réseau : ' + (err.message || 'connexion impossible');
            progress.classList.remove('alert-info');
            progress.classList.add('alert-danger');
            btn.disabled = false;
        });
    });
});
})();
</script>
{% endblock %}
