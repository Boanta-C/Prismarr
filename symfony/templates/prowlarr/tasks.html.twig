{% extends 'base.html.twig' %}
{% block title %}Tâches système — Prowlarr{% endblock %}
{% block head_meta %}<meta name="turbo-visit-control" content="reload">{% endblock %}

{% block body %}
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title d-flex align-items-center gap-2">
                    <svg width="28" height="28" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 32C132.3 32 32 132.3 32 256s100.3 224 224 224 224-100.3 224-224S379.7 32 256 32zm0 400c-97 0-176-79-176-176S159 80 256 80s176 79 176 176-79 176-176 176z" fill="#E88D1A"/><path d="M256 120c-75 0-136 61-136 136s61 136 136 136 136-61 136-136-61-136-136-136zm0 224c-48.6 0-88-39.4-88-88s39.4-88 88-88 88 39.4 88 88-39.4 88-88 88z" fill="#E88D1A"/><circle cx="256" cy="256" r="48" fill="#E88D1A"/></svg>
                    Tâches système
                </h2>
            </div>
            <div class="col-auto ms-auto">{% include 'prowlarr/_prowlarr_nav.html.twig' %}</div>
        </div>
    </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
    <div class="alert alert-danger d-flex align-items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4"/><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z"/><path d="M12 16h.01"/></svg>
        <div><strong>Impossible de contacter Prowlarr</strong></div>
    </div>
{% endif %}

<div id="tasks-feedback" class="alert d-none mb-3"></div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Tâches planifiées</h3>
        <div class="card-options">
            <span class="badge bg-secondary-lt">{{ tasks|length }}</span>
        </div>
    </div>
    <div class="card-body p-0">
        {% if tasks is empty %}
            <div class="text-muted text-center py-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-2 d-block mx-auto text-secondary"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
                Aucune tâche.
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-vcenter table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Intervalle</th>
                            <th>Dernière exécution</th>
                            <th>Durée</th>
                            <th>Prochaine exécution</th>
                            <th class="w-1"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for task in tasks %}
                        <tr>
                            <td class="fw-medium">{{ task.name ?? task.taskName ?? '—' }}</td>
                            <td class="text-muted small">
                                {% if task.interval is defined %}
                                    {% set mins = task.interval %}
                                    {% if mins >= 60 %}
                                        {{ (mins / 60)|round(0, 'floor') }}h{% if (mins % 60) > 0 %} {{ mins % 60 }}min{% endif %}
                                    {% else %}
                                        {{ mins }} min
                                    {% endif %}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td class="text-muted small">
                                {% if task.lastExecution is defined %}
                                    {{ task.lastExecution|date('d/m/Y H:i') }}
                                {% else %}
                                    <span class="text-secondary">Jamais</span>
                                {% endif %}
                            </td>
                            <td class="text-muted small">
                                {% if task.lastDuration is defined %}
                                    {{ task.lastDuration }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td class="text-muted small">
                                {% if task.nextExecution is defined %}
                                    {{ task.nextExecution|date('d/m/Y H:i') }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>
                                <button class="btn btn-ghost-secondary btn-icon btn-sm btn-task-run"
                                        data-command="{{ task.taskName ?? task.name ?? '' }}"
                                        title="Exécuter maintenant">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
var feedback = document.getElementById('tasks-feedback');
function showFeedback(msg, type) {
    feedback.className = 'alert alert-' + (type || 'success') + ' mb-3';
    feedback.textContent = msg;
    feedback.classList.remove('d-none');
    setTimeout(function(){ feedback.classList.add('d-none'); }, 4000);
}

var SVG_PLAY = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg>';
var SVG_SPIN = '<span class="spinner-border spinner-border-sm" style="width:12px;height:12px;"></span>';

document.querySelectorAll('.btn-task-run').forEach(function(btn) {
    btn.addEventListener('click', function() {
        var commandName = btn.dataset.command;
        if (!commandName) return;
        btn.disabled = true;
        btn.innerHTML = SVG_SPIN;

        fetch('{{ path('prowlarr_task_run') }}', {
            method: 'POST',
            headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
            body: JSON.stringify({name: commandName}),
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.ok) {
                showFeedback('Tâche "' + commandName + '" lancée.');
                setTimeout(function(){ location.reload(); }, 1500);
            } else {
                showFeedback(data.error || 'Erreur lors du lancement.', 'danger');
                btn.disabled = false;
                btn.innerHTML = SVG_PLAY;
            }
        })
        .catch(function() {
            showFeedback('Erreur réseau.', 'danger');
            btn.disabled = false;
            btn.innerHTML = SVG_PLAY;
        });
    });
});
})();
</script>
{% endblock %}
