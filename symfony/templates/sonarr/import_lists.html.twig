{% extends 'base.html.twig' %}

{% block title %}Listes d'import — Sonarr{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Listes d'import</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modal-il">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          Ajouter
        </button>
        <a href="{{ path('sonarr_suggestions') }}" class="btn btn-ghost-primary btn-sm">Suggestions</a>
        {% include 'media/_sonarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">Impossible de joindre Sonarr.</div>
{% endif %}

<div id="il-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">Listes d'import configurées</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt">{{ lists|length }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% if lists is empty %}
      <div class="text-muted text-center py-5">Aucune liste d'import configurée.</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter mb-0">
          <thead>
            <tr>
              <th>Nom</th>
              <th>Type</th>
              <th>Activé</th>
              <th>Profil qualité</th>
              <th>Dossier racine</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for list in lists %}
            <tr data-list="{{ list|json_encode|e('html_attr') }}">
              <td class="fw-medium">{{ list.name ?? '—' }}</td>
              <td><span class="badge bg-secondary-lt">{{ list.implementationName ?? list.implementation ?? '—' }}</span></td>
              <td>
                {% if list.enable ?? list.enabled ?? false %}
                  <span class="badge bg-success-lt text-success">Oui</span>
                {% else %}
                  <span class="badge bg-secondary-lt">Non</span>
                {% endif %}
              </td>
              <td class="text-muted small">{{ list.qualityProfileId ?? '—' }}</td>
              <td class="text-muted small">{{ list.rootFolderPath ?? '—' }}</td>
              <td class="text-end d-flex gap-2 justify-content-end">
                <button class="btn btn-ghost-secondary btn-icon" data-bs-toggle="modal" data-bs-target="#modal-il" data-edit-item="{{ list|json_encode|e('html_attr') }}" title="Modifier">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                </button>
                <button class="btn btn-ghost-danger btn-icon btn-il-delete" data-id="{{ list.id }}" data-name="{{ list.name ?? '' }}" title="Supprimer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                </button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

</div>
</div>

{% include 'radarr/_schema_modal.html.twig' with {
  modal_id: 'modal-il',
  modal_title_add: 'Ajouter une liste d\'import',
  modal_title_edit: 'Modifier la liste',
  schema_url: path('sonarr_import_list_schema'),
  save_url_add: path('sonarr_import_list_add'),
  save_url_edit: '/sonarr/listes-import/__ID__/modifier'
} %}
{% endblock %}

{% block javascripts %}
<script>
(function() {
  const feedback = document.getElementById('il-feedback');
  function showFeedback(msg, type = 'success') {
    feedback.className = `alert alert-${type} mb-3`;
    feedback.textContent = msg;
    feedback.classList.remove('d-none');
    setTimeout(() => feedback.classList.add('d-none'), 4000);
  }

  document.querySelectorAll('.btn-il-delete').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm(`Supprimer la liste "${btn.dataset.name}" ?`)) return;
      const r = await fetch(`/sonarr/listes-import/${btn.dataset.id}/supprimer`, {
        method: 'POST', headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'}, body: '{}',
      });
      const data = await r.json();
      if (data.ok) location.reload();
      else showFeedback('Erreur lors de la suppression.', 'danger');
    });
  });
})();
</script>
{% endblock %}
