{% extends 'base.html.twig' %}

{% block title %}Sauvegardes Sonarr{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Sauvegardes</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button id="btn-create-backup" class="btn btn-primary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M12 5v14m-7-7l7 7l7-7"/></svg>
          Créer une sauvegarde
        </button>
        {% include 'media/_sonarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">Impossible de joindre Sonarr.</div>
{% endif %}

<div id="backup-progress" class="alert alert-info d-none mb-3">
  <div class="d-flex align-items-center gap-2">
    <div class="spinner-border spinner-border-sm"></div>
    <span id="backup-msg">Sauvegarde en cours...</span>
  </div>
</div>

<div class="alert alert-warning d-none" id="restore-alert">
  <span id="restore-msg"></span>
</div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">Sauvegardes disponibles</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt">{{ backups|length }} sauvegarde(s)</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% if backups is empty %}
      <div class="text-muted text-center py-5">Aucune sauvegarde disponible.</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter table-hover mb-0">
          <thead>
            <tr>
              <th>Nom</th>
              <th>Type</th>
              <th>Taille</th>
              <th>Date</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for backup in backups %}
            <tr>
              <td class="fw-medium small">{{ backup.name ?? '—' }}</td>
              <td>
                {% if (backup.type ?? '') == 'scheduled' %}
                  <span class="badge bg-blue-lt">Planifiée</span>
                {% else %}
                  <span class="badge bg-secondary-lt">Manuelle</span>
                {% endif %}
              </td>
              <td class="text-muted small">
                {% if backup.size is defined %}
                  {{ (backup.size / 1048576)|number_format(1) }} Mo
                {% else %}
                  —
                {% endif %}
              </td>
              <td class="text-muted small">
                {{ backup.time is defined ? backup.time|date('d/m/Y H:i') : '—' }}
              </td>
              <td class="text-end">
                <button class="btn btn-ghost-primary btn-sm btn-restore"
                        data-bs-toggle="modal" data-bs-target="#modal-restore"
                        data-id="{{ backup.id }}"
                        data-name="{{ backup.name ?? '' }}">
                  Restaurer
                </button>
                <button class="btn btn-ghost-danger btn-sm btn-backup-delete"
                        data-id="{{ backup.id }}">
                  Supprimer
                </button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

{# Modal de confirmation restauration #}
<div class="modal modal-blur fade" id="modal-restore" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Confirmer la restauration</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>Restaurer <strong id="restore-name"></strong> ?</p>
        <p class="text-muted small">Sonarr va redémarrer après la restauration.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="button" class="btn btn-warning" id="confirm-restore">Restaurer</button>
      </div>
    </div>
  </div>
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
let pendingRestoreId = null;

document.getElementById('btn-create-backup').addEventListener('click', async () => {
  const progress = document.getElementById('backup-progress');
  const msg = document.getElementById('backup-msg');
  document.getElementById('btn-create-backup').disabled = true;
  progress.classList.remove('d-none');
  msg.textContent = 'Lancement de la sauvegarde...';

  try {
    const r = await fetch('{{ path('sonarr_backup_create') }}', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}',
    });
    const data = await r.json();
    if (!data.ok) { msg.textContent = 'Erreur.'; return; }

    const cmdId = data.cmdId;
    const poll = setInterval(async () => {
      const sr = await fetch(`{{ path('sonarr_command_status', {cmdId: '__ID__'}) }}`.replace('__ID__', cmdId));
      const s = await sr.json();
      msg.textContent = `Sauvegarde : ${s.status ?? '?'}`;
      if (s.status === 'completed' || s.status === 'failed') {
        clearInterval(poll);
        if (s.status === 'completed') {
          msg.textContent = 'Sauvegarde créée ! Rechargement...';
          setTimeout(() => location.reload(), 2000);
        } else {
          msg.textContent = 'Echec de la sauvegarde.';
        }
      }
    }, 3000);
  } catch(e) {
    msg.textContent = 'Erreur réseau.';
  }
});

document.querySelectorAll('.btn-backup-delete').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (!confirm('Supprimer cette sauvegarde ?')) return;
    const id = btn.dataset.id;
    const r = await fetch(`/sonarr/sauvegardes/${id}/supprimer`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}',
    });
    const data = await r.json();
    if (data.ok) location.reload();
    else alert('Erreur lors de la suppression.');
  });
});

document.getElementById('modal-restore').addEventListener('show.bs.modal', (e) => {
  const btn = e.relatedTarget;
  if (btn) {
    pendingRestoreId = btn.dataset.id;
    document.getElementById('restore-name').textContent = btn.dataset.name;
  }
});

document.getElementById('confirm-restore').addEventListener('click', async () => {
  const alert = document.getElementById('restore-alert');
  const msg = document.getElementById('restore-msg');
  alert.classList.remove('d-none');
  msg.textContent = 'Restauration en cours...';

  const r = await fetch(`/sonarr/sauvegardes/${pendingRestoreId}/restaurer`, {
    method: 'POST',
    headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
    body: '{}',
  });
  const data = await r.json();
  if (data.ok) {
    msg.textContent = 'Restauration lancée. Sonarr va redémarrer.';
    alert.classList.remove('alert-warning');
    alert.classList.add('alert-success');
  } else {
    msg.textContent = 'Erreur lors de la restauration.';
    alert.classList.remove('alert-warning');
    alert.classList.add('alert-danger');
  }
});
})();
</script>
{% endblock %}
